<UserControl x:Class="SevenDaysManager.Controls.HudTitle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:SevenDaysManager.Controls"
             x:Name="Root">

    <!-- "// DASHBOARD ▊"  — the rust slashes, the uppercase mono title, and a blinking
         accent block cursor. Straight from the RustPanel reference. -->
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

        <TextBlock Text="//"
                   FontFamily="{DynamicResource Hud.Mono}"
                   FontSize="19" FontWeight="Bold"
                   Foreground="{DynamicResource Hud.Rust}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>

        <c:TrackedText Text="{Binding Title, ElementName=Root}"
                       LetterSpacing="0.14"
                       FontFamily="{DynamicResource Hud.Mono}"
                       FontSize="19" FontWeight="Bold"
                       Foreground="{DynamicResource Hud.Fg}"
                       VerticalAlignment="Center"/>

        <!-- Blinking block cursor -->
        <Rectangle x:Name="Cursor"
                   Width="9" Height="20"
                   Margin="6,0,0,0"
                   VerticalAlignment="Center"
                   Fill="{DynamicResource Hud.Accent}">
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                           Duration="0:0:1.1">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0"   Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.55" Value="0"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>
    </StackPanel>
</UserControl>
