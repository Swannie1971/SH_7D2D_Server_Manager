<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <!-- Default style for HudIcon (keyed by type — DefaultStyleKey in the control). -->
    <Style TargetType="{x:Type c:HudIcon}">
        <Setter Property="Width"  Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <!-- Inherit the surrounding text colour unless a caller overrides Foreground. -->
        <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:HudIcon}">
                    <!-- STROKED, never filled. Flat caps + miter joins are the whole point:
                         MaterialDesign's PackIcon is a filled, round-cornered glyph, which
                         is exactly what the brutalist style rejects.

                         StrokeThickness comes from ScaledStroke, not a literal 1.5 —
                         Stretch="Uniform" scales the stroke with the geometry, so the
                         control pre-divides by the scale factor to land back on ~1.5px
                         on screen at any icon size. -->
                    <!-- TemplateBinding is a one-way, non-tracking optimisation that resolves at
                         template-apply time. Data and ScaledStroke are both computed AFTER that
                         (on Loaded/SizeChanged), so a TemplateBinding would latch the initial
                         null/default and never update — the icon renders blank. RelativeSource
                         TemplatedParent is a real binding and does track. -->
                    <Path Data="{Binding Data, RelativeSource={RelativeSource TemplatedParent}}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                          StrokeThickness="{Binding ScaledStroke, RelativeSource={RelativeSource TemplatedParent}}"
                          StrokeLineJoin="Miter"
                          StrokeStartLineCap="Flat"
                          StrokeEndLineCap="Flat"
                          StrokeMiterLimit="4"
                          Fill="{x:Null}"
                          Stretch="Uniform"
                          SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
