<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:c="clr-namespace:SevenDaysManager.Controls"
                    xmlns:conv="clr-namespace:SevenDaysManager.Converters"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Zero radius, everywhere. This is the whole point. -->
    <CornerRadius x:Key="Hud.Zero">0</CornerRadius>
    <sys:Double x:Key="Hud.NoRadius">0</sys:Double>

    <!-- Corner-cut (chamfer) clip — the HUD's replacement for a rounded corner -->
    <conv:ChamferClipConverter x:Key="ChamferClip"/>

    <!-- ═══════════════════════════════════════════ TYPOGRAPHY STYLES ══ -->

    <!-- ══ TRACKED TEXT ══
         These use c:TrackedText, NOT TextBlock. WPF has no letter-spacing, and faking it by
         injecting space characters cannot work in a monospace font (every glyph, including a
         "thin" space, is one identical cell wide — so word gaps and letter gaps come out the
         same and multi-word labels read as one word). TrackedText lays out the glyphs itself
         with real per-glyph advances. See TrackedText.cs. -->

    <!-- Panel header (h2): mono 11.5 / 700 / 0.16em UPPER -->
    <Style x:Key="Hud.PanelHeader" TargetType="c:TrackedText">
        <Setter Property="FontFamily"    Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"      Value="11.5"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="LetterSpacing" Value="0.16"/>
    </Style>

    <!-- Section label (sidebar): mono 9 / 700 / 0.26em UPPER, RUST -->
    <Style x:Key="Hud.SectionLabel" TargetType="c:TrackedText">
        <Setter Property="FontFamily"    Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"      Value="9"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="{DynamicResource Hud.Rust}"/>
        <Setter Property="LetterSpacing" Value="0.26"/>
    </Style>

    <!-- Stat caption: mono 8.5 / 700 / 0.2em UPPER, RUST -->
    <Style x:Key="Hud.StatCaption" TargetType="c:TrackedText">
        <Setter Property="FontFamily"    Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"      Value="8.5"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="{DynamicResource Hud.Rust}"/>
        <Setter Property="LetterSpacing" Value="0.2"/>
    </Style>

    <!-- Big stat value: mono 32 / 600, tabular figures so digits don't jitter -->
    <Style x:Key="Hud.StatValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"   Value="32"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
    </Style>

    <!-- Page title: mono 19 / 700 / 0.14em UPPER -->
    <Style x:Key="Hud.PageTitle" TargetType="c:TrackedText">
        <Setter Property="FontFamily"    Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"      Value="19"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="LetterSpacing" Value="0.14"/>
    </Style>

    <!-- Body / description: sans, normal case -->
    <Style x:Key="Hud.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Hud.Sans}"/>
        <Setter Property="FontSize"   Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.FgMuted}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Generic mono readout (IDs, ports, versions, counts) -->
    <Style x:Key="Hud.Mono.Text" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
    </Style>

    <!-- Sidebar section header: RUST uppercase label + a dashed rule trailing right.
         Set the label via Tag:   <ContentControl Template="{StaticResource Hud.SectionRule}" Tag="MY SERVERS"/> -->
    <ControlTemplate x:Key="Hud.SectionRule" TargetType="ContentControl">
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <c:TrackedText Grid.Column="0"
                           Text="{TemplateBinding Tag}"
                           Style="{StaticResource Hud.SectionLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
            <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center"
                       Fill="{DynamicResource Hud.DashRule}"/>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════ BUTTONS ══ -->

    <!-- Base: square, 1px machined edge, uppercase mono 10.5/700/0.12em -->
    <Style x:Key="Hud.Button" TargetType="Button">
        <Setter Property="Height"           Value="30"/>
        <Setter Property="Padding"          Value="13,0"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Hud.BorderStrong}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"         Value="10.5"/>
        <Setter Property="FontWeight"       Value="Bold"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Hud.SurfaceHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary: accent fill, near-black ink, accent glow, chamfered TL/BR corners -->
    <!-- Chamfered (corner-cut) button. Background is a solid fill; Foreground is the ink.
         The clip is computed from the live size so the 8px cut never distorts (a Path with
         Stretch=Fill would scale the chamfer into a huge wedge on a wide button). -->
    <Style x:Key="Hud.Button.Chamfered" TargetType="Button" BasedOn="{StaticResource Hud.Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <Border.Clip>
                                <MultiBinding Converter="{StaticResource ChamferClip}" ConverterParameter="8">
                                    <Binding Path="ActualWidth"  RelativeSource="{RelativeSource AncestorType=Border}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                </MultiBinding>
                            </Border.Clip>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary: accent fill, near-black ink, accent glow, chamfered -->
    <Style x:Key="Hud.Button.Primary" TargetType="Button" BasedOn="{StaticResource Hud.Button.Chamfered}">
        <Setter Property="Background" Value="{DynamicResource Hud.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.AccentInk}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#C1F24A" BlurRadius="14" ShadowDepth="0" Opacity="0.25"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Server actions. START is the primary/affirmative action (accent, chamfered).
         STOP is destructive (red). RESTART is a ghost outline. -->
    <Style x:Key="Hud.Button.Start" TargetType="Button" BasedOn="{StaticResource Hud.Button.Primary}"/>

    <Style x:Key="Hud.Button.Stop" TargetType="Button" BasedOn="{StaticResource Hud.Button.Chamfered}">
        <Setter Property="Background" Value="{DynamicResource Hud.Red}"/>
        <Setter Property="Foreground" Value="#12060A"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#EF4444" BlurRadius="14" ShadowDepth="0" Opacity="0.25"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hud.Button.Restart" TargetType="Button" BasedOn="{StaticResource Hud.Button}">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="Foreground"  Value="{DynamicResource Hud.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hud.AccentSoft}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Danger: transparent fill, red text + red-tinted border -->
    <Style x:Key="Hud.Button.Danger" TargetType="Button" BasedOn="{StaticResource Hud.Button}">
        <Setter Property="Foreground"  Value="{DynamicResource Hud.Red}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Red}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hud.RedSoft}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#EF4444" BlurRadius="14" ShadowDepth="0" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Ghost: transparent, faint border -->
    <Style x:Key="Hud.Button.Ghost" TargetType="Button" BasedOn="{StaticResource Hud.Button}">
        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Border}"/>
        <Setter Property="Foreground"  Value="{DynamicResource Hud.FgMuted}"/>
    </Style>

    <!-- Icon button: square, borderless until hover -->
    <Style x:Key="Hud.Button.Icon" TargetType="Button">
        <Setter Property="Width"            Value="30"/>
        <Setter Property="Height"           Value="30"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="Foreground"       Value="{DynamicResource Hud.FgMuted}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ NAV CARD ══ -->
    <!-- The clickable tiles on the MainWindow home grid. Square, gunmetal, no shadow;
         on hover the border and icon light to accent and a 2px accent bar slides in on
         the left — the same "acquiring lock" language as HudPanel's brackets. -->
    <!-- IMPORTANT: Padding is 0. The HudBrackets overlay must sit flush to the card's edge,
         so it cannot live inside the card's padding — the content Grid applies its own margin
         instead. Setting Padding here pushes the brackets inward and they stop reading as
         corner brackets entirely.
         No border either: the brackets ARE the outline. -->
    <Style x:Key="Hud.NavCard" TargetType="materialDesign:Card">
        <Setter Property="UniformCornerRadius" Value="0"/>
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
        <Setter Property="Background"      Value="{DynamicResource GlassBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin"          Value="4"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hud.SurfaceHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Nav card title: uppercase mono, tracked -->
    <Style x:Key="Hud.NavCard.Title" TargetType="c:TrackedText">
        <Setter Property="FontFamily"    Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"      Value="12"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="LetterSpacing" Value="0.12"/>
        <Setter Property="Margin"        Value="0,0,0,6"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Nav card description: sans, muted -->
    <Style x:Key="Hud.NavCard.Desc" TargetType="TextBlock" BasedOn="{StaticResource Hud.Body}">
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.FgSubtle}"/>
    </Style>

    <!-- Nav card icon: rust by default, accent on hover (trigger lives on the card) -->
    <Style x:Key="Hud.NavCard.Icon" TargetType="materialDesign:PackIcon">
        <Setter Property="Width"      Value="26"/>
        <Setter Property="Height"     Value="26"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.Rust}"/>
        <Setter Property="Margin"     Value="0,0,0,12"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=materialDesign:Card}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════ PILL / BADGE ══ -->
    <!-- Chamfered 5px, square leading dot, {Status}Soft fill + {Status} text.
         Set Tag to the status brush; Background to the soft brush. -->
    <Style x:Key="Hud.Pill" TargetType="Border">
        <Setter Property="Height"          Value="22"/>
        <Setter Property="Padding"         Value="8,0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="Hud.PillText" TargetType="c:TrackedText">
        <Setter Property="FontFamily"    Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"      Value="10"/>
        <Setter Property="FontWeight"    Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="LetterSpacing" Value="0.09"/>
    </Style>

    <!-- ═══════════════════════════════════════════ TEXTBOX ══ -->
    <Style x:Key="Hud.TextBox" TargetType="TextBox">
        <Setter Property="Background"      Value="{DynamicResource Hud.Surface2}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Hud.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="CaretBrush"      Value="{DynamicResource Hud.Accent}"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource Hud.Accent}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="10,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.BorderStrong}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ COMBOBOX ══ -->
    <Style x:Key="Hud.ComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="10,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Hud.AccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Hud.AccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default item template: shows the item's `Label` if it has one, else the item itself.
         This is what makes DisplayMemberPath unnecessary — and DisplayMemberPath CANNOT work
         with Hud.ComboBox anyway (see the note on the ContentPresenter below).
         Handles both option records (LabeledValue) and plain string lists. -->
    <conv:ComboItemLabelConverter x:Key="ComboItemLabel"/>
    <DataTemplate x:Key="Hud.ComboBox.ItemTemplate">
        <TextBlock Text="{Binding Converter={StaticResource ComboItemLabel}}"/>
    </DataTemplate>

    <Style x:Key="Hud.ComboBox" TargetType="ComboBox">
        <Setter Property="Background"      Value="{DynamicResource Hud.Surface2}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Hud.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="10,7"/>
        <Setter Property="Height"          Value="34"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource Hud.ComboBoxItem}"/>
        <Setter Property="ItemTemplate"       Value="{StaticResource Hud.ComboBox.ItemTemplate}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- ⚠ Style MUST be cleared, exactly as in Hud.Expander's header.
                             An ambient ToggleButton style (Hud.Toggle) carries a fixed Width/Height
                             for the switch pill. If it leaks in here, this button stops filling the
                             ComboBox: the bordered box + caret shrink to a stub floating beside the
                             selected-item text, instead of framing it. -->
                        <ToggleButton x:Name="Toggle"
                                      Style="{x:Null}"
                                      MinWidth="0" MinHeight="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            Background="{DynamicResource Hud.Surface2}"
                                            BorderBrush="{DynamicResource Hud.Border}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Square caret, miter joints — no rounded chevron -->
                                            <Path Grid.Column="1" Margin="0,0,10,0"
                                                  Data="M 0,0 L 8,0 L 4,5 Z"
                                                  Fill="{DynamicResource Hud.Rust}"
                                                  VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.BorderStrong}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- ⚠ SelectionBoxItemTemplate is a READ-ONLY DP that WPF only populates
                             for its own default ComboBox template. With a custom ControlTemplate
                             it stays NULL, so DisplayMemberPath never reaches this presenter and
                             it falls back to ToString() — printing the raw object, e.g.
                             "VisibilityOption { Value = 2, Label = Public }". (Verified by test.)

                             Fix: drive the selection box from ItemTemplate, which we control.
                             Callers must therefore set ItemTemplate (or Hud.ComboBox.DisplayPath
                             below), NOT DisplayMemberPath. -->
                        <ContentPresenter Margin="10,0,26,0"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding ItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="None">
                            <Border Background="{DynamicResource Hud.BgElevated}"
                                    BorderBrush="{DynamicResource Hud.Accent}"
                                    BorderThickness="1"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="260">
                                <ScrollViewer>
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Field label above an input — uppercase mono, rust -->
    <Style x:Key="Hud.FieldLabel" TargetType="c:TrackedText" BasedOn="{StaticResource Hud.StatCaption}">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <!-- ═══════════════════════════════════════════ EXPANDER ══ -->
    <!-- Collapsible instrument section. Header: ▸/▾ rust caret + uppercase tracked mono title,
         with a rust dashed rule trailing off to the right. Square, no Material chrome. -->
    <Style x:Key="Hud.Expander" TargetType="Expander">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ⚠ Header binding — do not "simplify" this.
                             The Expander's header area gets the Header VALUE as its DataContext.
                             A string implements IEnumerable<char>, so WPF treats it as a
                             collection and the DataContext resolves to the FIRST CHARACTER. Any
                             {Binding Header, RelativeSource=AncestorType=Expander} inside the
                             header therefore resolves "Header" against a *char* and renders a
                             single letter ("D", "T", "Z"...).

                             TemplatedParent binds to the templated Expander directly and does not
                             go through that char DataContext, so it yields the full string. The
                             whole header row is built inline here (not in a nested ToggleButton
                             template) so TemplatedParent still refers to the Expander. -->
                        <!-- ⚠ Height/MinHeight MUST be explicitly cleared.
                             An ambient ToggleButton style (Hud.Toggle) sets a fixed Height. If it
                             leaks in here the header is clamped (measured avail height came back
                             as 6px against a 13px glyph run), and the title renders as a clipped
                             sliver that looks like a single letter. Diagnosed by dumping the
                             visual tree: the ToggleButton showed H=32. -->
                        <ToggleButton x:Name="Toggle" Grid.Row="0"
                                      Style="{x:Null}"
                                      MinHeight="0"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Cursor="Hand"
                                      Focusable="False"
                                      VerticalAlignment="Stretch"
                                      VerticalContentAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Hd" Background="Transparent" Padding="16,13">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Hd" Property="Background" Value="{DynamicResource Hud.SurfaceHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>

                            <!-- Header row lives in the Expander's template scope, so
                                 TemplatedParent == the Expander. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Square miter caret: ▸ collapsed, ▾ expanded -->
                                <Path x:Name="Caret" Grid.Column="0"
                                      Data="M 0,0 L 6,4 L 0,8 Z"
                                      Fill="{DynamicResource Hud.Rust}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      RenderTransformOrigin="0.5,0.5"/>

                                <c:TrackedText Grid.Column="1"
                                               Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                               LetterSpacing="0.16"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="11.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.Fg}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>

                                <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Fill="{DynamicResource Hud.DashRule}"/>
                            </Grid>
                        </ToggleButton>

                        <!-- Body -->
                        <ContentPresenter x:Name="Body" Grid.Row="1" Visibility="Collapsed"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Expanded: body shows, caret turns accent and rotates to point down -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="Body" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Caret" Property="Fill" Value="{DynamicResource Hud.Accent}"/>
                            <Setter TargetName="Caret" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Setting label + hint inside an expander body -->
    <Style x:Key="Hud.SettingLabel" TargetType="c:TrackedText" BasedOn="{StaticResource Hud.StatCaption}">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="Hud.SettingHint" TargetType="TextBlock" BasedOn="{StaticResource Hud.Body}">
        <Setter Property="FontSize"   Value="10.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
        <Setter Property="Margin"     Value="0,0,0,7"/>
    </Style>

    <!-- ═══════════════════════════════════════════ TOGGLE SWITCH ══ -->
    <!-- Square throw-switch, not a rounded pill. Off = gunmetal track, thumb hard left.
         On = accent track with a glow, thumb slams to the right. No check icon, no rounding. -->
    <Style x:Key="Hud.Toggle" TargetType="ToggleButton">
        <Setter Property="Width"  Value="46"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Background="Transparent">
                        <!-- Track -->
                        <Border x:Name="Track"
                                Background="{DynamicResource Hud.Surface2}"
                                BorderBrush="{DynamicResource Hud.BorderStrong}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"/>

                        <!-- Thumb: a square slug that slides between the two ends -->
                        <Border x:Name="Thumb"
                                Width="16" Height="16"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="2,0,0,0"
                                Background="{DynamicResource Hud.FgFaint}"
                                SnapsToDevicePixels="True">
                            <!-- Unnamed: a Storyboard cannot target a name declared inside a
                                 RenderTransform (it isn't in the template's namescope) — that
                                 throws at runtime. Target the Border and reach the transform via
                                 a property path instead. -->
                            <Border.RenderTransform>
                                <TranslateTransform X="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"  Value="{DynamicResource Hud.AccentSoft}"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                            <Setter TargetName="Thumb" Property="Background"  Value="{DynamicResource Hud.Accent}"/>
                            <Setter TargetName="Thumb" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#C1F24A" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                </Setter.Value>
                            </Setter>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="24" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ CHECKBOX ══ -->
    <!-- Square box, accent fill + AccentInk tick when checked. No rounding, no ripple. -->
    <Style x:Key="Hud.CheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box"
                                Width="15" Height="15"
                                Background="{DynamicResource Hud.Surface2}"
                                BorderBrush="{DynamicResource Hud.BorderStrong}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Tick"
                                  Data="M 2,5 L 5,9 L 11,2"
                                  Stroke="{DynamicResource Hud.AccentInk}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Flat"
                                  StrokeEndLineCap="Flat"
                                  StrokeLineJoin="Miter"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box"  Property="Background"  Value="{DynamicResource Hud.Accent}"/>
                            <Setter TargetName="Box"  Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                            <Setter TargetName="Tick" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ RADIO BUTTON ══ -->
    <!-- Square selector with an inset accent block — never a circle. -->
    <Style x:Key="Hud.RadioButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box"
                                Width="15" Height="15"
                                Background="{DynamicResource Hud.Surface2}"
                                BorderBrush="{DynamicResource Hud.BorderStrong}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Rectangle x:Name="Dot"
                                       Width="7" Height="7"
                                       Fill="{DynamicResource Hud.Accent}"
                                       Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                            <Setter TargetName="Dot" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ PROGRESS BAR ══ -->
    <!-- Square, 5px, status-colour fill with a glow + crawling hazard stripes -->
    <Style x:Key="Hud.ProgressBar" TargetType="ProgressBar">
        <Setter Property="Height"          Value="5"/>
        <Setter Property="Background"      Value="{DynamicResource Hud.Bg}"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Accent}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Hud.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Grid x:Name="PART_Track" ClipToBounds="True">
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#C1F24A" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                </Rectangle.Effect>
                            </Rectangle>
                            <!-- Crawling hazard stripes over the fill.
                                 ⚠ The animation is declared on the Rectangle's OWN Triggers, not
                                 on ControlTemplate.Triggers. A Storyboard inside a ControlTemplate
                                 cannot resolve Storyboard.TargetName — the template has its own
                                 namescope and throws "name cannot be found in the name scope of
                                 ControlTemplate" at runtime, taking down any window that contains
                                 a progress bar. Declaring it locally needs no TargetName at all. -->
                            <Rectangle x:Name="Stripes"
                                       HorizontalAlignment="Left"
                                       Width="{Binding ActualWidth, ElementName=PART_Indicator}"
                                       Fill="{DynamicResource Hud.ProgressStripeTile}"
                                       IsHitTestVisible="False"
                                       RenderTransformOrigin="0,0">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Rectangle.RenderTransform>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                    From="0" To="8" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ SCROLLBAR ══ -->
    <Style x:Key="Hud.ScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd" Background="{DynamicResource Hud.BorderStrong}"
                            SnapsToDevicePixels="True"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Hud.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Hud.ScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="10"/>
                            <Setter Property="Width"  Value="Auto"/>
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════ DATAGRID ══ -->
    <Style x:Key="Hud.DataGridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Hud.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Rust}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"        Value="9"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Padding"         Value="12,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style x:Key="Hud.DataGridRow" TargetType="DataGridRow">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource Hud.Mono}"/>
        <Setter Property="FontSize"        Value="11.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Hud.Border}"
                            BorderThickness="0,0,0,1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- 2px accent left edge appears on hover / selection -->
                            <Rectangle x:Name="Edge" Width="2" HorizontalAlignment="Left"
                                       Fill="{DynamicResource Hud.Accent}" Visibility="Collapsed"/>
                            <DataGridCellsPresenter/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd"   Property="Background" Value="#08C1F24A"/>
                            <Setter TargetName="Edge" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd"   Property="Background" Value="{DynamicResource Hud.AccentSoft}"/>
                            <Setter TargetName="Edge" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hud.DataGridCell" TargetType="DataGridCell">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource Hud.Fg}"/>
        <Setter Property="Padding"         Value="12,9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hud.DataGrid" TargetType="DataGrid">
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="RowBackground"         Value="Transparent"/>
        <Setter Property="GridLinesVisibility"   Value="None"/>
        <Setter Property="HeadersVisibility"     Value="Column"/>
        <Setter Property="AutoGenerateColumns"   Value="False"/>
        <Setter Property="CanUserAddRows"        Value="False"/>
        <Setter Property="CanUserDeleteRows"     Value="False"/>
        <Setter Property="IsReadOnly"            Value="True"/>
        <Setter Property="SelectionMode"         Value="Single"/>
        <Setter Property="ColumnHeaderStyle"     Value="{StaticResource Hud.DataGridHeader}"/>
        <Setter Property="RowStyle"              Value="{StaticResource Hud.DataGridRow}"/>
        <Setter Property="CellStyle"             Value="{StaticResource Hud.DataGridCell}"/>
    </Style>

</ResourceDictionary>
