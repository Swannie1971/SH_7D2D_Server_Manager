    <!-- Cog: square body, four square teeth on the axes, square bore.
         An earlier attempt walked one continuous path in and out to fake teeth; at 13px it
         collapsed into a lumpy blob with concave sides. Distinct body + teeth survives
         downscaling because each element stays a recognisable rectangle. -->
    <Geometry x:Key="Icon.Cog">M 6,6 L 18,6 L 18,18 L 6,18 Z M 9.5,2 L 14.5,2 L 14.5,6 M 9.5,2 L 9.5,6 M 9.5,22 L 14.5,22 L 14.5,18 M 9.5,22 L 9.5,18 M 2,9.5 L 2,14.5 L 6,14.5 M 2,9.5 L 6,9.5 M 22,9.5 L 22,14.5 L 18,14.5 M 22,9.5 L 18,9.5 M 10,10 L 14,10 L 14,14 L 10,14 Z</Geometry>

    <!-- ── Transport ────────────────────────────────────────────────────────── -->

    <!-- Play: hard triangle -->
    <Geometry x:Key="Icon.Play">M 6,3 L 20,12 L 6,21 Z</Geometry>
    <!-- Stop: square -->
    <Geometry x:Key="Icon.Stop">M 5,5 L 19,5 L 19,19 L 5,19 Z</Geometry>
    <!-- Restart / Refresh: a square cycle broken at the top-right, with an arrowhead.
         No arcs — an arc rounds the silhouette, which the style forbids, and the earlier
         arc-based Refresh rendered as a stray hook. -->
    <!-- Open square loop: starts mid-top, runs anticlockwise all the way round, and ends
         with a chevron arrowhead pointing back into the gap. -->
    <!-- The gap sits mid-top; the arrowhead is a chevron ON the line, opening into the gap,
         so it reads as the end of the loop rather than a detached tick floating above it. -->
    <Geometry x:Key="Icon.Restart">M 11,4 L 4,4 L 4,20 L 20,20 L 20,4 L 14,4 L 16.5,1.5 M 14,4 L 16.5,6.5</Geometry>
    <Geometry x:Key="Icon.Refresh">M 13,4 L 20,4 L 20,20 L 4,20 L 4,4 L 10,4 L 7.5,1.5 M 10,4 L 7.5,6.5</Geometry>

