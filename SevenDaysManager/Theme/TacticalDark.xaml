<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════ RAW COLOURS ══ -->
    <Color x:Key="Hud.Color.Bg">#08080A</Color>
    <Color x:Key="Hud.Color.BgElevated">#0B0C0E</Color>
    <Color x:Key="Hud.Color.Surface">#0E0F12</Color>
    <Color x:Key="Hud.Color.Surface2">#13151A</Color>
    <Color x:Key="Hud.Color.SurfaceHover">#191C22</Color>
    <Color x:Key="Hud.Color.Border">#23262B</Color>
    <Color x:Key="Hud.Color.BorderStrong">#343941</Color>

    <Color x:Key="Hud.Color.Fg">#E8E6E3</Color>
    <Color x:Key="Hud.Color.FgMuted">#9BA1A6</Color>
    <Color x:Key="Hud.Color.FgSubtle">#6E767D</Color>
    <Color x:Key="Hud.Color.FgFaint">#4D545B</Color>

    <Color x:Key="Hud.Color.Accent">#C1F24A</Color>
    <Color x:Key="Hud.Color.AccentInk">#0A1500</Color>
    <Color x:Key="Hud.Color.Rust">#D97757</Color>

    <Color x:Key="Hud.Color.Green">#22C55E</Color>
    <Color x:Key="Hud.Color.Amber">#F59E0B</Color>
    <Color x:Key="Hud.Color.Red">#EF4444</Color>
    <Color x:Key="Hud.Color.Blue">#3B82F6</Color>
    <Color x:Key="Hud.Color.Violet">#A78BFA</Color>

    <!-- ═══════════════════════════════════════════ BRUSHES ══ -->
    <SolidColorBrush x:Key="Hud.Bg"            Color="{StaticResource Hud.Color.Bg}"/>
    <SolidColorBrush x:Key="Hud.BgElevated"    Color="{StaticResource Hud.Color.BgElevated}"/>
    <SolidColorBrush x:Key="Hud.Surface"       Color="{StaticResource Hud.Color.Surface}"/>
    <SolidColorBrush x:Key="Hud.Surface2"      Color="{StaticResource Hud.Color.Surface2}"/>
    <SolidColorBrush x:Key="Hud.SurfaceHover"  Color="{StaticResource Hud.Color.SurfaceHover}"/>
    <SolidColorBrush x:Key="Hud.Border"        Color="{StaticResource Hud.Color.Border}"/>
    <SolidColorBrush x:Key="Hud.BorderStrong"  Color="{StaticResource Hud.Color.BorderStrong}"/>

    <SolidColorBrush x:Key="Hud.Fg"            Color="{StaticResource Hud.Color.Fg}"/>
    <SolidColorBrush x:Key="Hud.FgMuted"       Color="{StaticResource Hud.Color.FgMuted}"/>
    <SolidColorBrush x:Key="Hud.FgSubtle"      Color="{StaticResource Hud.Color.FgSubtle}"/>
    <SolidColorBrush x:Key="Hud.FgFaint"       Color="{StaticResource Hud.Color.FgFaint}"/>

    <SolidColorBrush x:Key="Hud.Accent"        Color="{StaticResource Hud.Color.Accent}"/>
    <SolidColorBrush x:Key="Hud.AccentInk"     Color="{StaticResource Hud.Color.AccentInk}"/>
    <SolidColorBrush x:Key="Hud.Rust"          Color="{StaticResource Hud.Color.Rust}"/>

    <SolidColorBrush x:Key="Hud.Green"         Color="{StaticResource Hud.Color.Green}"/>
    <SolidColorBrush x:Key="Hud.Amber"         Color="{StaticResource Hud.Color.Amber}"/>
    <SolidColorBrush x:Key="Hud.Red"           Color="{StaticResource Hud.Color.Red}"/>
    <SolidColorBrush x:Key="Hud.Blue"          Color="{StaticResource Hud.Color.Blue}"/>
    <SolidColorBrush x:Key="Hud.Violet"        Color="{StaticResource Hud.Color.Violet}"/>

    <!-- Soft (tinted-fill) variants — status colours at 14%, accent at 12%, rust at 16% -->
    <SolidColorBrush x:Key="Hud.AccentSoft"    Color="#C1F24A" Opacity="0.12"/>
    <SolidColorBrush x:Key="Hud.RustSoft"      Color="#D97757" Opacity="0.16"/>
    <SolidColorBrush x:Key="Hud.GreenSoft"     Color="#22C55E" Opacity="0.14"/>
    <SolidColorBrush x:Key="Hud.AmberSoft"     Color="#F59E0B" Opacity="0.14"/>
    <SolidColorBrush x:Key="Hud.RedSoft"       Color="#EF4444" Opacity="0.14"/>
    <SolidColorBrush x:Key="Hud.BlueSoft"      Color="#3B82F6" Opacity="0.14"/>
    <SolidColorBrush x:Key="Hud.VioletSoft"    Color="#A78BFA" Opacity="0.14"/>

    <!-- Bracket resting colour: accent mixed ~38% into BorderStrong -->
    <SolidColorBrush x:Key="Hud.BracketRest"   Color="#5A6B33"/>

    <!-- Console/terminal bed — near-black so log text reads as phosphor on a CRT -->
    <SolidColorBrush x:Key="ConsoleBrush"      Color="#050506"/>

    <!-- Border at 45% for pill outlines -->
    <SolidColorBrush x:Key="Hud.AccentBorder"  Color="#C1F24A" Opacity="0.45"/>

    <!-- ═══════════════════════════════════════════ FONTS ══ -->
    <FontFamily x:Key="Hud.Mono">Cascadia Mono, JetBrains Mono, Consolas, Courier New</FontFamily>
    <FontFamily x:Key="Hud.Sans">Segoe UI, Inter, Arial</FontFamily>

    <!-- ═══════════════════════════════════════════ TILES / TEXTURES ══ -->

    <!-- Engineering grid: 34x34 accent lines @ ~2.6% -->
    <DrawingBrush x:Key="Hud.GridTile" TileMode="Tile"
                  Viewport="0,0,34,34" ViewportUnits="Absolute"
                  Viewbox="0,0,34,34"  ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing>
                <GeometryDrawing.Geometry>
                    <GeometryGroup>
                        <RectangleGeometry Rect="0,0,34,1"/>
                        <RectangleGeometry Rect="0,0,1,34"/>
                    </GeometryGroup>
                </GeometryDrawing.Geometry>
                <GeometryDrawing.Brush>
                    <SolidColorBrush Color="#C1F24A" Opacity="0.026"/>
                </GeometryDrawing.Brush>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Scanlines: 1px line every 4px, white @ 1.5% -->
    <DrawingBrush x:Key="Hud.ScanlineTile" TileMode="Tile"
                  Viewport="0,0,4,4" ViewportUnits="Absolute"
                  Viewbox="0,0,4,4"  ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing>
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,4,1"/>
                </GeometryDrawing.Geometry>
                <GeometryDrawing.Brush>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.015"/>
                </GeometryDrawing.Brush>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Hazard tape: 45-degree rust stripes -->
    <DrawingBrush x:Key="Hud.HazardTile" TileMode="Tile"
                  Viewport="0,0,10,10" ViewportUnits="Absolute"
                  Viewbox="0,0,10,10"  ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#40D97757">
                <GeometryDrawing.Geometry>
                    <PathGeometry Figures="M -2,2 L 2,-2 L 5,-2 L 1,2 Z M 3,7 L 7,3 L 10,3 L 6,7 Z M 8,12 L 12,8 L 15,8 L 11,12 Z"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Hazard stripes for progress-bar fill (accent, denser) -->
    <DrawingBrush x:Key="Hud.ProgressStripeTile" TileMode="Tile"
                  Viewport="0,0,8,8" ViewportUnits="Absolute"
                  Viewbox="0,0,8,8"  ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#30000000">
                <GeometryDrawing.Geometry>
                    <PathGeometry Figures="M -2,2 L 2,-2 L 5,-2 L 1,2 Z M 2,6 L 6,2 L 9,2 L 5,6 Z M 6,10 L 10,6 L 13,6 L 9,10 Z"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Sidebar hazard rail: vertical dashed rust ticks running down the outer edge.
         This is the single most recognisable element of the RustPanel sidebar. -->
    <DrawingBrush x:Key="Hud.RailTile" TileMode="Tile"
                  Viewport="0,0,3,9" ViewportUnits="Absolute"
                  Viewbox="0,0,3,9"  ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#D97757">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,3,5"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Dashed rule that trails a section label off to the right -->
    <DrawingBrush x:Key="Hud.DashRule" TileMode="Tile"
                  Viewport="0,0,6,1" ViewportUnits="Absolute"
                  Viewbox="0,0,6,1"  ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#3AD97757">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,3,1"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Scan sweep band: soft accent gradient, 260px tall -->
    <LinearGradientBrush x:Key="Hud.SweepBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#00C1F24A" Offset="0"/>
        <GradientStop Color="#0DC1F24A" Offset="0.5"/>
        <GradientStop Color="#00C1F24A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Horizon glows -->
    <RadialGradientBrush x:Key="Hud.GlowTopLeft" GradientOrigin="0,0" Center="0,0" RadiusX="1" RadiusY="1">
        <GradientStop Color="#0FC1F24A" Offset="0"/>
        <GradientStop Color="#00C1F24A" Offset="1"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="Hud.GlowBottomRight" GradientOrigin="1,1" Center="1,1" RadiusX="1" RadiusY="1">
        <GradientStop Color="#0FD97757" Offset="0"/>
        <GradientStop Color="#00D97757" Offset="1"/>
    </RadialGradientBrush>

    <!-- Vignette -->
    <RadialGradientBrush x:Key="Hud.Vignette" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
        <GradientStop Color="#00000000" Offset="0.45"/>
        <GradientStop Color="#52000000" Offset="1"/>
    </RadialGradientBrush>

    <!-- Scrim over the background photo. In RustPanel the image is present but heavily
         suppressed — it reads as atmosphere, never as a picture competing with the readouts. -->
    <SolidColorBrush x:Key="Hud.BgScrim" Color="#08080A" Opacity="0.78"/>

    <!-- Panel header gradient: Surface2 -> transparent -->
    <LinearGradientBrush x:Key="Hud.HeaderGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#13151A" Offset="0"/>
        <GradientStop Color="#0013151A" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
