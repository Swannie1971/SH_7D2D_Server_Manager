<Window x:Class="SevenDaysManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:SevenDaysManager.Models"
        xmlns:vm="clr-namespace:SevenDaysManager.ViewModels"
        xmlns:views="clr-namespace:SevenDaysManager.Views"
        xmlns:conv="clr-namespace:SevenDaysManager.Converters"
        mc:Ignorable="d"
        Title="7 Days to Die — Server Manager"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <SolidColorBrush x:Key="ConsoleBrush" Color="#CC080808"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisible"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVisible" Invert="True"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="220" MaxWidth="360"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Background image — full opacity, sits behind everything -->
        <Image Grid.ColumnSpan="3"
               Source="pack://application:,,,/Assets/bg.jpg"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- ═══════════════════════════════════════════════ SIDEBAR ══ -->
        <Grid Grid.Column="0" Background="{DynamicResource MaterialDesign.Brush.Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App header bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="7D2D Server Manager"
                               FontSize="15" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                            ToolTip="Add server"
                            Width="36" Height="36"
                            Click="AddServerButton_Click">
                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Large logo centered in the empty sidebar space -->
            <Image Grid.Row="1"
                   Source="pack://application:,,,/Assets/logo.png"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center"
                   Margin="7,0"
                   MaxHeight="220"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Server list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Servers}"
                     SelectedItem="{Binding SelectedServer}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8,8,8,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <!-- Primary-color left accent bar, only visible when selected -->
                                        <Border x:Name="Accent" Width="4" HorizontalAlignment="Left"
                                                CornerRadius="4,0,0,4"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Visibility="Collapsed"/>
                                        <Border x:Name="Bd" CornerRadius="8" Background="Transparent"
                                                BorderThickness="1" BorderBrush="Transparent"
                                                Margin="0">
                                            <ContentPresenter/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#30009688"/>
                                            <Setter TargetName="Bd" Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Server}">
                        <materialDesign:Card Padding="0" UniformCornerRadius="8"
                                             Background="{DynamicResource GlassBrush}">
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Status dot -->
                                <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#757575"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="running">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="starting">
                                                    <Setter Property="Fill" Value="#FF9800"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="stopping">
                                                    <Setter Property="Fill" Value="#FF5722"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock FontSize="11" Opacity="0.6"
                                               Text="{Binding ServerPort, StringFormat='Port {0}'}"/>
                                </StackPanel>
                                <!-- Status badge -->
                                <TextBlock Grid.Column="2" FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="STOPPED"/>
                                            <Setter Property="Foreground" Value="#757575"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="running">
                                                    <Setter Property="Text" Value="RUNNING"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="starting">
                                                    <Setter Property="Text" Value="STARTING"/>
                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="stopping">
                                                    <Setter Property="Text" Value="STOPPING"/>
                                                    <Setter Property="Foreground" Value="#FF5722"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- App settings button -->
            <Border Grid.Row="2"
                    Background="{DynamicResource GlassBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#33FFFFFF"
                    Padding="12,8">
                <Grid>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Left" Padding="4"
                            Click="AppSettingsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="App Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="v0.2.4"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontSize="11" Opacity="0.8"
                               Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Drag splitter -->
        <GridSplitter Grid.Column="1" Width="4"
                      HorizontalAlignment="Stretch"
                      Background="#33FFFFFF"/>

        <!-- ════════════════════════════════════════ DETAIL PANE ══ -->
        <Grid Grid.Column="2" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    Padding="20,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedServer.Name, FallbackValue='No server selected'}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                        <TextBlock FontSize="11" Opacity="0.7"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                   Text="{Binding SelectedServer.GameWorld, StringFormat='{}7 Days to Die  ·  {0}', FallbackValue='Select a server from the list'}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: left overview + right nav cards -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" MinWidth="260"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: overview panel ── -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="14,14,14,14">

                        <!-- Game banner -->
                        <materialDesign:Card UniformCornerRadius="10" Margin="0,0,0,14" Height="170"
                                             Background="Transparent"
                                             materialDesign:ElevationAssist.Elevation="Dp0">
                            <Grid>
                                <!-- Server logo; transparent PNGs show through to card background -->
                                <Image Source="{Binding SelectedServer.LogoPath, Converter={StaticResource PathToImage}}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Margin="12"/>
                            </Grid>
                        </materialDesign:Card>

                        <!-- Status -->
                        <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold" Opacity="0.4" Margin="2,0,0,6"/>
                        <materialDesign:Card UniformCornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                                             Background="{DynamicResource GlassBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#757575"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="running">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="starting">
                                                    <Setter Property="Fill" Value="#FF9800"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="stopping">
                                                    <Setter Property="Fill" Value="#FF5722"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Stopped"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="running">
                                                    <Setter Property="Text" Value="Running"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="starting">
                                                    <Setter Property="Text" Value="Starting…"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="stopping">
                                                    <Setter Property="Text" Value="Stopping…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Server info -->
                        <TextBlock Text="SERVER INFO" FontSize="10" FontWeight="Bold" Opacity="0.4" Margin="2,0,0,6"/>
                        <materialDesign:Card UniformCornerRadius="8" Padding="14" Margin="0,0,0,12"
                                             Background="{DynamicResource GlassBrush}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="World" Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.GameWorld, FallbackValue='—'}"
                                               HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Save Name" Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.GameName, FallbackValue='—'}"
                                               HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Port" Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.ServerPort, FallbackValue='—'}"
                                               HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Max Players" Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.MaxPlayers, FallbackValue='—'}"
                                               HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="EAC" Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Disabled"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedServer.EacEnabled}" Value="True">
                                                        <Setter Property="Text" Value="Enabled"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Server actions -->
                        <TextBlock Text="SERVER ACTIONS" FontSize="10" FontWeight="Bold" Opacity="0.4" Margin="2,0,0,6"/>
                        <UniformGrid Columns="3" Margin="0,0,0,4">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Background="#388E3C" BorderBrush="#388E3C"
                                    Command="{Binding StartServerCommand}"
                                    Margin="0,0,4,4" Height="38" Padding="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Play" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Start" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Background="#C62828" BorderBrush="#C62828"
                                    Command="{Binding StopServerCommand}"
                                    Margin="4,0,4,4" Height="38" Padding="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Stop" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Stop" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Command="{Binding RestartServerCommand}"
                                    Margin="4,0,0,4" Height="38" Padding="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restart" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Restart" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <!-- Live stats panel -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="LIVE STATS" FontSize="10" FontWeight="Bold" Opacity="0.4" Margin="2,0,0,6"/>
                                <materialDesign:Card UniformCornerRadius="8" Padding="12"
                                                     Background="{DynamicResource GlassBrush}">
                                    <StackPanel>

                                        <!-- Stats table -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Players" Opacity="0.5" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <Run Text="{Binding LivePlayers, Mode=OneWay}"/>
                                                <Run Text="/" Foreground="#80FFFFFF"/>
                                                <Run Text="{Binding SelectedServer.MaxPlayers, FallbackValue='?'}"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="FPS" Opacity="0.5" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Text="{Binding LiveFps, Mode=OneWay, StringFormat='{}{0:F1}'}"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Entities" Opacity="0.5" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Text="{Binding LiveEntities, Mode=OneWay}"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Game Time" Opacity="0.5" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Text="{Binding LiveGameTime, Mode=OneWay}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Uptime" Opacity="0.5" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Text="{Binding LiveUptime, Mode=OneWay}"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Server PID" Opacity="0.5" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Text="{Binding LiveServerPid, Mode=OneWay}"/>
                                        </Grid>

                                        <Separator Margin="0,8" Opacity="0.15"/>

                                        <!-- CPU and RAM gauges -->
                                        <UniformGrid Columns="2">
                                            <StackPanel HorizontalAlignment="Center">
                                                <Grid Width="90" Height="90">
                                                    <Ellipse Width="76" Height="76" Fill="Transparent"
                                                             Stroke="{DynamicResource MaterialDesign.Brush.Secondary}"
                                                             StrokeThickness="6" Opacity="0.2"/>
                                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                                 Width="90" Height="90"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                                                 Value="{Binding LiveCpuPct, Mode=OneWay}"
                                                                 Maximum="100"/>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock HorizontalAlignment="Center">
                                                            <Run Text="{Binding LiveCpuPct, Mode=OneWay, StringFormat='{}{0:F0}'}" FontSize="22" FontWeight="Bold"/>
                                                            <Run Text="%" FontSize="11" Foreground="#80FFFFFF"/>
                                                        </TextBlock>
                                                        <TextBlock Text="CPU" HorizontalAlignment="Center"
                                                                   FontSize="11" Opacity="0.5"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel HorizontalAlignment="Center">
                                                <Grid Width="90" Height="90">
                                                    <Ellipse Width="76" Height="76" Fill="Transparent"
                                                             Stroke="{DynamicResource MaterialDesign.Brush.Secondary}"
                                                             StrokeThickness="6" Opacity="0.2"/>
                                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                                 Width="90" Height="90"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                                                 Value="{Binding LiveRamPct, Mode=OneWay}"
                                                                 Maximum="100"/>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock HorizontalAlignment="Center">
                                                            <Run Text="{Binding LiveRamPct, Mode=OneWay, StringFormat='{}{0:F0}'}" FontSize="22" FontWeight="Bold"/>
                                                            <Run Text="%" FontSize="11" Foreground="#80FFFFFF"/>
                                                        </TextBlock>
                                                        <TextBlock Text="RAM" HorizontalAlignment="Center"
                                                                   FontSize="11" Opacity="0.5"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </UniformGrid>

                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>
                        </Border>

                        <!-- Action error log -->
                        <Border CornerRadius="6" Margin="0,6,0,0" ClipToBounds="True"
                                Visibility="{Binding ActionError, Converter={StaticResource StringToVisibility}}">
                            <!-- Header bar -->
                            <StackPanel>
                                <Border Background="#CC1A1A1A" Padding="8,6" CornerRadius="6,6,0,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                                     Foreground="#FF7043" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Server stopped" Foreground="#FF7043"
                                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Foreground="#AAAAAA" Padding="4,2" Height="24"
                                                MinWidth="0" FontSize="11"
                                                Click="CopyErrorLog_Click"
                                                ToolTip="Copy log to clipboard">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ContentCopy" Width="12" Height="12"
                                                                         VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="Copy" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                                <!-- Log content — selectable TextBox styled as read-only terminal -->
                                <Border Background="#EE0D0D0D" CornerRadius="0,0,6,6" MaxHeight="160">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBox Text="{Binding ActionError, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Consolas, Courier New"
                                                 FontSize="10.5"
                                                 Foreground="#E0E0E0"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="8,6"
                                                 CaretBrush="Transparent"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Divider -->
                <Border Grid.Column="1" Background="#22FFFFFF"/>

                <!-- ── RIGHT: cards home / inline detail ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Back nav bar (visible when a detail is open) -->
                    <Border Grid.Row="0"
                            Background="#CC111111"
                            BorderThickness="0,0,0,1" BorderBrush="#33FFFFFF"
                            Padding="8,6"
                            Visibility="{Binding ActiveDetail, Converter={StaticResource NotNullToVisible}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Width="32" Height="32" Padding="0"
                                    Command="{Binding GoHomeCommand}"
                                    ToolTip="Back to cards">
                                <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18"/>
                            </Button>
                            <TextBlock Text="{Binding ActiveDetailTitle}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Cards grid (home) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent"
                                  Visibility="{Binding ActiveDetail, Converter={StaticResource NullToVisible}}">
                        <UniformGrid Columns="2" Margin="12,12,12,12">

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="OverviewCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Overview" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Live server stats, metrics and system info"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="ConsoleCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Console" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Console" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Live telnet stream and command input"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="ConfigCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="TuneVariant" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Config" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Edit serverconfig.xml — ports, world, gameplay"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="GameSettingsCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="GamepadVariant" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Game Settings" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Difficulty, zombies, blood moon, loot and more"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="PlayersCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroup" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Players" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Online list, kick, ban and broadcast"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="DiscordCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="MessageBadge" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Discord" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Webhook notifications for server events"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="BackupsCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Archive" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Backups" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Create and restore save game backups"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="ScheduleCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="CalendarClock" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Schedule" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Automated restarts with in-game warnings"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="ModsCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="PuzzlePlus" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Mod Management" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Install, enable and manage server mods"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="ServerSettingsCard_Click">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Cog" Width="30" Height="30"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Server settings, wipe options, danger zone"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="10" Margin="4" Padding="20" Cursor="Hand"
                                             Background="{DynamicResource GlassBrush}"
                                             MouseLeftButtonUp="InstallCard_Click">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <materialDesign:PackIcon Kind="Download" Width="30" Height="30"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                             HorizontalAlignment="Left"/>
                                    <!-- Status area top-right: spinner while checking, badge when done -->
                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <!-- Checking spinner -->
                                        <ProgressBar Width="18" Height="18"
                                                     IsIndeterminate="True" Value="0"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InstallCheckBusy}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <!-- Status badge -->
                                        <Border CornerRadius="4" Padding="6,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#33FF5722"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InstallIsUpToDate}" Value="True">
                                                            <Setter Property="Background" Value="#334CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InstallCheckBusy}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding InstallStatusLabel}"
                                                       FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF5722"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding InstallIsUpToDate}" Value="True">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Grid>
                                <TextBlock Text="Install / Update" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding InstallBuildLabel}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Click to install or update via SteamCMD"
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                    </UniformGrid>
                    </ScrollViewer>

                    <!-- Inline detail content -->
                    <ContentControl Grid.Row="1"
                                    Content="{Binding ActiveDetail}"
                                    Visibility="{Binding ActiveDetail, Converter={StaticResource NotNullToVisible}}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
                                <views:OverviewView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:PlayersViewModel}">
                                <views:PlayersView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:BackupsViewModel}">
                                <views:BackupsView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduleViewModel}">
                                <views:ScheduleView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:DiscordViewModel}">
                                <views:DiscordView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ModsViewModel}">
                                <views:ModsView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ConsoleViewModel}">
                                <views:ConsoleView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
                                <views:ConfigView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:GameSettingsViewModel}">
                                <views:GameSettingsView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ServerSettingsViewModel}">
                                <views:ServerSettingsView/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
