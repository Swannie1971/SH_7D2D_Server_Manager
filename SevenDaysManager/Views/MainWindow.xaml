<Window x:Class="SevenDaysManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:SevenDaysManager.Models"
        xmlns:vm="clr-namespace:SevenDaysManager.ViewModels"
        xmlns:views="clr-namespace:SevenDaysManager.Views"
        xmlns:conv="clr-namespace:SevenDaysManager.Converters"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        mc:Ignorable="d"
        Title="7 Days to Die — Server Manager"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Hud.Bg}"
        TextElement.Foreground="{DynamicResource Hud.Fg}"
        FontSize="14">

    <Window.Resources>
        <!-- ConsoleBrush now lives in Theme/TacticalDark.xaml so ConsoleView can see it too -->
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisible"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVisible" Invert="True"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="220" MaxWidth="360"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Background image — sits behind everything -->
        <Image Grid.ColumnSpan="3"
               Source="{DynamicResource AppBackgroundSource}"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Atmosphere: grid, scanlines, glows, scan sweep, vignette.
             Above the image, below the UI, never interactive. -->
        <c:HudAtmosphere Grid.ColumnSpan="3" Panel.ZIndex="1"/>

        <!-- ═══════════════════════════════════════════════ SIDEBAR ══ -->
        <Grid Grid.Column="0" Panel.ZIndex="2" Background="{DynamicResource Hud.BgElevated}">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App header bar — no accent fill; accent is a highlight, not a paint bucket -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Hud.BgElevated}"
                    BorderBrush="{DynamicResource Hud.Border}"
                    BorderThickness="0,0,0,1"
                    Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <c:TrackedText Text="7D2D MANAGER"
                               Style="{StaticResource Hud.PanelHeader}"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource Hud.Button.Icon}"
                            ToolTip="Add server"
                            Click="AddServerButton_Click">
                        <c:HudIcon Kind="Plus" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- MY SERVERS section rule — own row, so it can never overlap the list -->
            <ContentControl Grid.Row="1"
                            Template="{StaticResource Hud.SectionRule}"
                            Tag="MY SERVERS"
                            Margin="12,14,12,2"/>

            <!-- Large logo — sits behind the list, only visible when there are no servers -->
            <Image Grid.Row="2"
                   Source="pack://application:,,,/Assets/logo.png"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center"
                   Margin="7,0"
                   MaxHeight="220"
                   Stretch="Uniform"
                   Opacity="0.9"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Server list -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Servers}"
                     SelectedItem="{Binding SelectedServer}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8,4,8,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <!-- 2px accent left bar + accent-tint gradient when active -->
                                        <Border x:Name="Bar" Width="2" HorizontalAlignment="Left"
                                                Background="{DynamicResource Hud.Accent}"
                                                Visibility="Collapsed"/>
                                        <Border x:Name="Bd" Background="Transparent"
                                                BorderThickness="1" BorderBrush="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Hud.AccentSoft}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.AccentBorder}"/>
                                            <Setter TargetName="Bar" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Hud.SurfaceHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Server}">
                        <Grid Margin="10,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SQUARE status dot — never a circle -->
                            <Rectangle Width="6" Height="6" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Fill" Value="{DynamicResource Hud.FgFaint}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="running">
                                                <Setter Property="Fill" Value="{DynamicResource Hud.Green}"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#22C55E" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="starting">
                                                <Setter Property="Fill" Value="{DynamicResource Hud.Amber}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="stopping">
                                                <Setter Property="Fill" Value="{DynamicResource Hud.Red}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Hud.Fg}"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding ServerPort, StringFormat='PORT {0}'}"
                                               Style="{StaticResource Hud.Mono.Text}"
                                               FontSize="9.5"
                                               Foreground="{DynamicResource Hud.FgSubtle}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <!-- Status pill -->
                                    <Border Padding="5,1" BorderThickness="1" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"  Value="#144D545B"/>
                                                <Setter Property="BorderBrush" Value="#4D545B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="running">
                                                        <Setter Property="Background"  Value="{DynamicResource Hud.GreenSoft}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Green}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="starting">
                                                        <Setter Property="Background"  Value="{DynamicResource Hud.AmberSoft}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Amber}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="stopping">
                                                        <Setter Property="Background"  Value="{DynamicResource Hud.RedSoft}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Red}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="8.5" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="STOPPED"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="running">
                                                            <Setter Property="Text" Value="RUNNING"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Hud.Green}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="starting">
                                                            <Setter Property="Text" Value="STARTING"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Hud.Amber}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="stopping">
                                                            <Setter Property="Text" Value="STOPPING"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Hud.Red}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- SYSTEM strip: app settings + version/credit -->
            <Border Grid.Row="3"
                    Background="{DynamicResource Hud.BgElevated}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource Hud.Border}"
                    Padding="12,10">
                <StackPanel>
                    <Grid>
                        <Button Style="{StaticResource Hud.Button.Ghost}"
                                HorizontalAlignment="Left" Padding="10,0"
                                Click="AppSettingsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <c:HudIcon Kind="Cog" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="SETTINGS" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding AppVersion}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Style="{StaticResource Hud.Mono.Text}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource Hud.Accent}"/>
                    </Grid>
                    <TextBlock Text="Developed by Swannie"
                               HorizontalAlignment="Left"
                               Style="{StaticResource Hud.Mono.Text}"
                               FontSize="9"
                               Foreground="{DynamicResource Hud.FgFaint}"
                               Margin="10,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- ⚠ Hazard rail — dashed rust ticks down the sidebar's outer edge.
                 Spans all rows; the signature RustPanel sidebar element. -->
            <Rectangle Grid.RowSpan="4" Width="3"
                       HorizontalAlignment="Right"
                       Fill="{DynamicResource Hud.RailTile}"
                       Opacity="0.75"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Drag splitter -->
        <GridSplitter Grid.Column="1" Width="4" Panel.ZIndex="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource Hud.Border}"/>

        <!-- ════════════════════════════════════════ DETAIL PANE ══ -->
        <Grid Grid.Column="2" Panel.ZIndex="2" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Command bar — instrument chrome, not a paint bucket.
                 Elevated abyss + a 2px accent underline; the accent stays a highlight. -->
            <Grid Grid.Row="0">
                <Rectangle Fill="{DynamicResource Hud.BgElevated}"/>
                <!-- Faint hazard tape washing in from the right edge -->
                <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.10"
                           HorizontalAlignment="Right" Width="220"/>
                <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                <!-- 2px accent underline, left-anchored -->
                <Rectangle Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                           Width="180" Fill="{DynamicResource Hud.Accent}"/>

                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Live square status dot -->
                    <Rectangle Grid.Column="0" Width="7" Height="7"
                               VerticalAlignment="Center" Margin="0,0,12,0">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="Fill" Value="{DynamicResource Hud.FgFaint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedServer.Status}" Value="running">
                                        <Setter Property="Fill" Value="{DynamicResource Hud.Green}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#22C55E" BlurRadius="9" ShadowDepth="0" Opacity="0.9"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedServer.Status}" Value="starting">
                                        <Setter Property="Fill" Value="{DynamicResource Hud.Amber}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedServer.Status}" Value="stopping">
                                        <Setter Property="Fill" Value="{DynamicResource Hud.Red}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <c:TrackedText Text="{Binding SelectedServer.Name, FallbackValue='NO SERVER SELECTED'}"
                                       Style="{StaticResource Hud.PanelHeader}"
                                       FontSize="14"/>
                        <TextBlock Style="{StaticResource Hud.Mono.Text}"
                                   FontSize="10"
                                   Foreground="{DynamicResource Hud.Rust}"
                                   Margin="0,4,0,0"
                                   Text="{Binding SelectedServer.GameWorld, StringFormat='{}7 DAYS TO DIE  ·  {0}', FallbackValue='SELECT A SERVER FROM THE LIST'}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Body: left overview + right nav cards -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" MinWidth="260"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: overview panel ── -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="14,14,14,14">

                        <!-- Game banner -->
                        <materialDesign:Card UniformCornerRadius="0" Margin="0,0,0,14" Height="170"
                                             Background="Transparent"
                                             materialDesign:ElevationAssist.Elevation="Dp0">
                            <Grid>
                                <!-- Server logo; transparent PNGs show through to card background -->
                                <Image Source="{Binding SelectedServer.LogoPath, Converter={StaticResource PathToImage}}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Margin="12"/>
                            </Grid>
                        </materialDesign:Card>

                        <!-- ══ STATUS ══ -->
                        <c:TrackedText Text="STATUS" Style="{StaticResource Hud.SectionLabel}"
                                       HorizontalAlignment="Left" Margin="2,0,0,6"/>
                        <c:HudPanel Tint="Amber" Padding="12,10" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <!-- SQUARE status dot, glowing when live -->
                                <Rectangle Width="7" Height="7" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="{DynamicResource Hud.FgFaint}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="running">
                                                    <Setter Property="Fill" Value="{DynamicResource Hud.Green}"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#22C55E" BlurRadius="9" ShadowDepth="0" Opacity="0.9"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="starting">
                                                    <Setter Property="Fill" Value="{DynamicResource Hud.Amber}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="stopping">
                                                    <Setter Property="Fill" Value="{DynamicResource Hud.Red}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Text" Value="STOPPED"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Hud.FgMuted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="running">
                                                    <Setter Property="Text" Value="RUNNING"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Green}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="starting">
                                                    <Setter Property="Text" Value="STARTING…"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Amber}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}" Value="stopping">
                                                    <Setter Property="Text" Value="STOPPING…"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Red}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </c:HudPanel>

                        <!-- ══ SERVER INFO ══ -->
                        <c:TrackedText Text="SERVER INFO" Style="{StaticResource Hud.SectionLabel}"
                                       HorizontalAlignment="Left" Margin="2,0,0,6"/>
                        <c:HudPanel Tint="Blue" Padding="14" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,9">
                                    <c:TrackedText Text="WORLD" Style="{StaticResource Hud.StatCaption}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.GameWorld, FallbackValue='—'}"
                                               Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,9">
                                    <c:TrackedText Text="SAVE NAME" Style="{StaticResource Hud.StatCaption}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.GameName, FallbackValue='—'}"
                                               Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,9">
                                    <c:TrackedText Text="PORT" Style="{StaticResource Hud.StatCaption}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.ServerPort, FallbackValue='—'}"
                                               Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,9">
                                    <c:TrackedText Text="MAX PLAYERS" Style="{StaticResource Hud.StatCaption}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedServer.MaxPlayers, FallbackValue='—'}"
                                               Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <c:TrackedText Text="EAC" Style="{StaticResource Hud.StatCaption}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
                                                <Setter Property="FontSize" Value="11.5"/>
                                                <Setter Property="Text" Value="DISABLED"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedServer.EacEnabled}" Value="True">
                                                        <Setter Property="Text" Value="ENABLED"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </c:HudPanel>

                        <!-- ══ SERVER ACTIONS ══ -->
                        <c:TrackedText Text="SERVER ACTIONS" Style="{StaticResource Hud.SectionLabel}"
                                       HorizontalAlignment="Left" Margin="2,0,0,6"/>
                        <UniformGrid Columns="3" Margin="0,0,0,4">
                            <!-- START: chamfered accent — the affirmative action -->
                            <Button Style="{StaticResource Hud.Button.Start}"
                                    Command="{Binding StartServerCommand}"
                                    Margin="0,0,4,4" Height="34" Padding="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <c:HudIcon Kind="Play" Width="13" Height="13"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <c:TrackedText Text="START" LetterSpacing="0.12"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="10.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource Hud.AccentInk}"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- STOP: chamfered red — destructive -->
                            <Button Style="{StaticResource Hud.Button.Stop}"
                                    Click="StopServerButton_Click"
                                    Margin="4,0,4,4" Height="34" Padding="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <c:HudIcon Kind="Stop" Width="13" Height="13"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <c:TrackedText Text="STOP" LetterSpacing="0.12"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="10.5" FontWeight="Bold"
                                                   Foreground="#12060A"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- RESTART: ghost outline -->
                            <Button Style="{StaticResource Hud.Button.Restart}"
                                    Command="{Binding RestartServerCommand}"
                                    IsEnabled="{Binding SelectedServerRunning}"
                                    Margin="4,0,0,4" Height="34" Padding="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <c:HudIcon Kind="Restart" Width="13" Height="13"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <c:TrackedText Text="RESTART" LetterSpacing="0.12"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="10.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource Hud.Accent}"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <!-- Live stats panel -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <c:TrackedText Text="LIVE STATS" Style="{StaticResource Hud.SectionLabel}"
                                               HorizontalAlignment="Left" Margin="2,0,0,6"/>
                                <c:HudPanel Tint="Green" Padding="12">
                                    <StackPanel>

                                        <!-- Stats table -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="23"/>
                                                <RowDefinition Height="23"/>
                                                <RowDefinition Height="23"/>
                                                <RowDefinition Height="23"/>
                                                <RowDefinition Height="23"/>
                                                <RowDefinition Height="23"/>
                                            </Grid.RowDefinitions>

                                            <c:TrackedText Grid.Row="0" Grid.Column="0" Text="PLAYERS" Style="{StaticResource Hud.StatCaption}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Style="{StaticResource Hud.Mono.Text}" FontSize="11.5">
                                                <Run Text="{Binding LivePlayers, Mode=OneWay}"/><Run Text="/" Foreground="#6E767D"/><Run Text="{Binding SelectedServer.MaxPlayers, FallbackValue='?'}" Foreground="#6E767D"/>
                                            </TextBlock>

                                            <c:TrackedText Grid.Row="1" Grid.Column="0" Text="FPS" Style="{StaticResource Hud.StatCaption}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                                       Text="{Binding LiveFps, Mode=OneWay, StringFormat='{}{0:F1}'}"
                                                       Foreground="{DynamicResource Hud.Accent}"/>

                                            <c:TrackedText Grid.Row="2" Grid.Column="0" Text="ENTITIES" Style="{StaticResource Hud.StatCaption}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                                       Text="{Binding LiveEntities, Mode=OneWay}"/>

                                            <c:TrackedText Grid.Row="3" Grid.Column="0" Text="GAME TIME" Style="{StaticResource Hud.StatCaption}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                                       Text="{Binding LiveGameTime, Mode=OneWay}"/>

                                            <c:TrackedText Grid.Row="4" Grid.Column="0" Text="UPTIME" Style="{StaticResource Hud.StatCaption}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                                       Text="{Binding LiveUptime, Mode=OneWay}"/>

                                            <c:TrackedText Grid.Row="5" Grid.Column="0" Text="SERVER PID" Style="{StaticResource Hud.StatCaption}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Style="{StaticResource Hud.Mono.Text}" FontSize="11.5"
                                                       Text="{Binding LiveServerPid, Mode=OneWay}"/>
                                        </Grid>

                                        <Rectangle Height="1" Fill="{DynamicResource Hud.Border}" Margin="0,10"/>

                                        <!-- CPU and RAM gauges. The rings stay circular — they read
                                             as instrument dials, not as rounded corners. -->
                                        <UniformGrid Columns="2">
                                            <StackPanel HorizontalAlignment="Center">
                                                <Grid Width="90" Height="90">
                                                    <Ellipse Width="76" Height="76" Fill="Transparent"
                                                             Stroke="{DynamicResource Hud.Border}"
                                                             StrokeThickness="5"/>
                                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                                 Width="90" Height="90"
                                                                 Foreground="{DynamicResource Hud.Accent}"
                                                                 Value="{Binding LiveCpuPct, Mode=OneWay}"
                                                                 Maximum="100"/>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   Style="{StaticResource Hud.Mono.Text}">
                                                            <Run Text="{Binding LiveCpuPct, Mode=OneWay, StringFormat='{}{0:F0}'}" FontSize="20" FontWeight="Bold"/><Run Text="%" FontSize="10" Foreground="#6E767D"/>
                                                        </TextBlock>
                                                        <c:TrackedText Text="CPU" Style="{StaticResource Hud.StatCaption}"
                                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel HorizontalAlignment="Center">
                                                <Grid Width="90" Height="90">
                                                    <Ellipse Width="76" Height="76" Fill="Transparent"
                                                             Stroke="{DynamicResource Hud.Border}"
                                                             StrokeThickness="5"/>
                                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                                 Width="90" Height="90"
                                                                 Foreground="{DynamicResource Hud.Amber}"
                                                                 Value="{Binding LiveRamPct, Mode=OneWay}"
                                                                 Maximum="100"/>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   Style="{StaticResource Hud.Mono.Text}">
                                                            <Run Text="{Binding LiveRamPct, Mode=OneWay, StringFormat='{}{0:F0}'}" FontSize="20" FontWeight="Bold"/><Run Text="%" FontSize="10" Foreground="#6E767D"/>
                                                        </TextBlock>
                                                        <c:TrackedText Text="RAM" Style="{StaticResource Hud.StatCaption}"
                                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </UniformGrid>

                                    </StackPanel>
                                </c:HudPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action error log -->
                        <Border CornerRadius="0" Margin="0,6,0,0" ClipToBounds="True"
                                Visibility="{Binding ActionError, Converter={StaticResource StringToVisibility}}">
                            <!-- Header bar -->
                            <StackPanel>
                                <Border Background="#CC1A1A1A" Padding="8,6" CornerRadius="0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <c:HudIcon Kind="AlertCircleOutline"
                                                                     Foreground="#FF7043" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Server stopped" Foreground="#FF7043"
                                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Foreground="#AAAAAA" Padding="4,2" Height="24"
                                                MinWidth="0" FontSize="11"
                                                Click="CopyErrorLog_Click"
                                                ToolTip="Copy log to clipboard">
                                            <StackPanel Orientation="Horizontal">
                                                <c:HudIcon Kind="ContentCopy" Width="12" Height="12"
                                                                         VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="Copy" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                                <!-- Log content — selectable TextBox styled as read-only terminal -->
                                <Border Background="#EE0D0D0D" CornerRadius="0" MaxHeight="160">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBox Text="{Binding ActionError, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Consolas, Courier New"
                                                 FontSize="10.5"
                                                 Foreground="#E0E0E0"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="8,6"
                                                 CaretBrush="Transparent"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Divider -->
                <Border Grid.Column="1" Background="{DynamicResource Hud.Border}"/>

                <!-- ── RIGHT: cards home / inline detail ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Back nav bar (visible when a detail is open) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Hud.BgElevated}"
                            BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Hud.Border}"
                            Padding="8,6"
                            Visibility="{Binding ActiveDetail, Converter={StaticResource NotNullToVisible}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource Hud.Button.Icon}"
                                    Command="{Binding GoHomeCommand}"
                                    ToolTip="Back to cards">
                                <c:HudIcon Kind="ArrowLeft" Width="16" Height="16"/>
                            </Button>
                            <c:TrackedText Text="{Binding ActiveDetailTitle}"
                                           Style="{StaticResource Hud.PanelHeader}"
                                           FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Cards grid (home) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent"
                                  Visibility="{Binding ActiveDetail, Converter={StaticResource NullToVisible}}">
                        <UniformGrid Columns="2" Margin="12,12,12,12">

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="OverviewCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="ViewDashboard" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="OVERVIEW" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Live server stats, metrics and system info"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Accent"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="ConsoleCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="Console" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="CONSOLE" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Live telnet stream and command input"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Green"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="ConfigCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="TuneVariant" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="CONFIG" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Edit serverconfig.xml — ports, world, gameplay"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Blue"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="GameSettingsCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="GamepadVariant" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="GAME SETTINGS" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Difficulty, zombies, blood moon, loot and more"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Violet"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="PlayersCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="AccountGroup" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="PLAYERS" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Online list, kick, ban and broadcast"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Amber"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="DiscordCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="MessageBadge" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="DISCORD" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Webhook notifications for server events"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Violet"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="BackupsCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="Archive" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="BACKUPS" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Create and restore save game backups"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Blue"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="ScheduleCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="CalendarClock" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="SCHEDULE" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Automated restarts with in-game warnings"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Rust"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="ModsCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="PuzzlePlus" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="MOD MANAGEMENT" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Install, enable and manage server mods"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Green"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Style="{StaticResource Hud.NavCard}"
                                             MouseLeftButtonUp="ServerSettingsCard_Click">
                            <Grid>
                                <StackPanel Margin="18">
                                <c:HudIcon Kind="Cog" Style="{StaticResource Hud.NavCard.Icon}"/>
                                <c:TrackedText Text="SETTINGS" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="Server settings, wipe options, danger zone"
                                           Style="{StaticResource Hud.NavCard.Desc}"/>
                            </StackPanel>
                                <c:HudBrackets Tint="Neutral"/>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card MouseLeftButtonUp="InstallCard_Click">
                            <materialDesign:Card.Style>
                                <!-- NavCard look, plus: disabled + dimmed while the server runs -->
                                <Style TargetType="materialDesign:Card" BasedOn="{StaticResource Hud.NavCard}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedServerRunning}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity"   Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:Card.Style>
                            <Grid>
                            <StackPanel Margin="18">
                                <Grid Margin="0,0,0,12">
                                    <c:HudIcon Kind="Download"
                                                             Style="{StaticResource Hud.NavCard.Icon}"
                                                             HorizontalAlignment="Left"
                                                             Margin="0"/>
                                    <!-- Status area top-right: spinner while checking, pill when done -->
                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <ProgressBar Width="16" Height="16"
                                                     IsIndeterminate="True" Value="0"
                                                     Foreground="{DynamicResource Hud.Accent}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InstallCheckBusy}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>

                                        <!-- Status pill: square, tinted fill + matching border -->
                                        <Border Padding="6,2" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"  Value="{DynamicResource Hud.AmberSoft}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Hud.Amber}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InstallIsUpToDate}" Value="True">
                                                            <Setter Property="Background"  Value="{DynamicResource Hud.GreenSoft}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Hud.Green}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InstallCheckBusy}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding InstallStatusLabel}"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="9" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource Hud.Amber}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding InstallIsUpToDate}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource Hud.Green}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <c:TrackedText Text="INSTALL / UPDATE" Style="{StaticResource Hud.NavCard.Title}"/>
                                <TextBlock Text="{Binding InstallBuildLabel}"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Hud.Accent}"
                                           Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.NavCard.Desc}">
                                            <Setter Property="Text" Value="Click to install or update via SteamCMD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedServerRunning}" Value="True">
                                                    <Setter Property="Text" Value="⚠ Stop the server before updating"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Amber}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <c:HudBrackets Tint="Amber"/>
                            </Grid>
                        </materialDesign:Card>

                    </UniformGrid>
                    </ScrollViewer>

                    <!-- Inline detail content -->
                    <ContentControl Grid.Row="1"
                                    Content="{Binding ActiveDetail}"
                                    Visibility="{Binding ActiveDetail, Converter={StaticResource NotNullToVisible}}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
                                <views:OverviewView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:PlayersViewModel}">
                                <views:PlayersView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:BackupsViewModel}">
                                <views:BackupsView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduleViewModel}">
                                <views:ScheduleView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:DiscordViewModel}">
                                <views:DiscordView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ModsViewModel}">
                                <views:ModsView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ConsoleViewModel}">
                                <views:ConsoleView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
                                <views:ConfigView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:GameSettingsViewModel}">
                                <views:GameSettingsView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ServerSettingsViewModel}">
                                <views:ServerSettingsView/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
