<Window x:Class="SevenDaysManager.Views.InstallProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Install / Update Server"
        Width="700" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,16">
            <StackPanel>
                <TextBlock Text="{Binding ServerName, StringFormat='Installing: {0}'}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                <TextBlock Text="{Binding InstallDir}"
                           FontSize="11" Opacity="0.7"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- Log output -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="8" Margin="16,16,16,8"
                             Background="#CC080808">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          Padding="12">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="#B0BEC5"
                                       TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </materialDesign:Card>

        <!-- Progress + stats -->
        <StackPanel Grid.Row="2" Margin="16,0,16,10">

            <!-- Determinate bar while downloading, indeterminate otherwise -->
            <Grid>
                <ProgressBar Height="6"
                             Maximum="100" Value="{Binding DownloadPercent}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                             Visibility="{Binding HasProgress, Converter={StaticResource BoolToVis}}"/>
                <ProgressBar Height="6"
                             IsIndeterminate="True"
                             Foreground="{DynamicResource MaterialDesign.Brush.Secondary}">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsRunning}"   Value="True"/>
                                        <Condition Binding="{Binding HasProgress}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </Grid>

            <!-- Stats row -->
            <Grid Margin="0,8,0,0" Visibility="{Binding HasProgress, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding DownloadStats}"
                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DownloadPercent, StringFormat='{}{0}%'}"
                           FontSize="20" FontWeight="Bold" Opacity="0.25"
                           VerticalAlignment="Center"/>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Opacity="0.6" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="3"
                BorderThickness="0,1,0,0"
                BorderBrush="#22FFFFFF"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Content="Cancel" Width="100" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="Close" Width="100"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
