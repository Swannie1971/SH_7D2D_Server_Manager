<UserControl x:Class="SevenDaysManager.Views.PlayersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Players" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#33000000" CornerRadius="10" Padding="10,2" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="{Binding PlayerCount, Mode=OneWay}"/>
                            <Run Text=" online"/>
                        </TextBlock>
                    </Border>
                    <!-- Offline badge -->
                    <Border Background="#44FF5722" CornerRadius="10" Padding="10,2" Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#FF5722" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Not connected" FontSize="11" Foreground="#FF5722" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Opacity="0.5" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Run Text="Refreshed: "/>
                        <Run Text="{Binding LastRefreshed, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="30" Padding="12,0" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Broadcast bar ══ -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="0" Padding="16,10"
                             Background="{DynamicResource GlassBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding BroadcastMessage, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Broadcast message to all players…"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="13" Margin="0,0,10,0"/>
                <Button Grid.Column="1"
                        Command="{Binding BroadcastCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="40" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Bullhorn" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Broadcast" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- ══ Player DataGrid ══ -->
        <Grid Grid.Row="2" Background="#CC0D0D0D">
            <DataGrid ItemsSource="{Binding Players}"
                      SelectedItem="{Binding SelectedPlayer}"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      materialDesign:DataGridAssist.CellPadding="12,8"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#0AFFFFFF"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#18FFFFFF">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"   MinWidth="120"/>
                    <DataGridTextColumn Header="Level"   Binding="{Binding Level}"   Width="60"  MinWidth="50"/>
                    <DataGridTextColumn Header="Health"  Binding="{Binding Health}"  Width="70"  MinWidth="60"/>
                    <DataGridTextColumn Header="Deaths"  Binding="{Binding Deaths}"  Width="70"  MinWidth="60"/>
                    <DataGridTextColumn Header="Zombies" Binding="{Binding Zombies}" Width="80"  MinWidth="65"/>
                    <DataGridTextColumn Header="Score"   Binding="{Binding Score}"   Width="70"  MinWidth="60"/>
                    <DataGridTextColumn Header="Ping"    Binding="{Binding Ping}"    Width="60"  MinWidth="50"/>
                    <DataGridTextColumn Header="IP"      Binding="{Binding Ip}"      Width="130" MinWidth="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state overlay -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}">
                <materialDesign:PackIcon Kind="LanDisconnect" Width="52" Height="52"
                                         HorizontalAlignment="Center" Opacity="0.2"/>
                <TextBlock Text="Not connected to server" HorizontalAlignment="Center"
                           Opacity="0.4" Margin="0,12,0,0" FontSize="14"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsOffline}"    Value="False"/>
                                    <Condition Binding="{Binding PlayerCount}"  Value="0"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="AccountOff" Width="52" Height="52"
                                         HorizontalAlignment="Center" Opacity="0.2"/>
                <TextBlock Text="No players online" HorizontalAlignment="Center"
                           Opacity="0.4" Margin="0,12,0,0" FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- ══ Action panel (shown when a player is selected) ══ -->
        <materialDesign:Card Grid.Row="3" UniformCornerRadius="0" Padding="16,12"
                             Background="#CC1A1A1A"
                             Visibility="{Binding IsPlayerSelected, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Selected player info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Selected player" FontSize="10" Opacity="0.5"/>
                    <TextBlock Text="{Binding SelectedPlayer.Name}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock FontSize="11" Opacity="0.5">
                        <Run Text="ID: "/>
                        <Run Text="{Binding SelectedPlayer.EntityId, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Reason box -->
                <TextBox Grid.Column="1"
                         Text="{Binding ActionReason, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Reason (optional)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- Kick -->
                <Button Grid.Column="2"
                        Command="{Binding KickCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                        Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                        Height="38" Padding="16,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountRemove" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Kick" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Ban -->
                <Button Grid.Column="3"
                        Command="{Binding BanCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#CC3B1A1A"
                        Height="38" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountOff" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Ban (1 yr)" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

    </Grid>
</UserControl>
