<UserControl x:Class="SevenDaysManager.Views.PlayersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- HUD row + the right-click-selects-row behaviour this view needs -->
        <Style x:Key="PlayerRow" TargetType="DataGridRow" BasedOn="{StaticResource Hud.DataGridRow}">
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="Row_RightClick"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Title ══ -->
        <c:HudTitle Grid.Row="0" Title="PLAYERS" HorizontalAlignment="Left" Margin="16,14,0,12"/>

        <!-- ══ Status strip ══ -->
        <Grid Grid.Row="1" Margin="16,0,16,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Online count pill -->
                <Border Background="{DynamicResource Hud.AccentSoft}"
                        BorderBrush="{DynamicResource Hud.Accent}" BorderThickness="1"
                        Padding="9,3" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="6" Height="6" Fill="{DynamicResource Hud.Accent}"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Style="{StaticResource Hud.Mono.Text}" FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Hud.Accent}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding PlayerCount, Mode=OneWay}"/><Run Text=" ONLINE"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Offline pill -->
                <Border Background="{DynamicResource Hud.RedSoft}"
                        BorderBrush="{DynamicResource Hud.Red}" BorderThickness="1"
                        Padding="9,3" Margin="10,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="6" Height="6" Fill="{DynamicResource Hud.Red}"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <c:TrackedText Text="NOT CONNECTED"
                                       Style="{StaticResource Hud.PillText}"
                                       Foreground="{DynamicResource Hud.Red}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <c:TrackedText Text="REFRESHED" Style="{StaticResource Hud.StatCaption}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding LastRefreshed, Mode=OneWay}"
                           Style="{StaticResource Hud.Mono.Text}" FontSize="11"
                           Foreground="{DynamicResource Hud.FgSubtle}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource Hud.Button}"
                        Height="30" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="Refresh" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="REFRESH" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.Fg}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Broadcast bar ══ -->
        <c:HudPanel Grid.Row="2" Tint="Violet" Padding="14,12" Margin="16,0,16,12">
            <StackPanel>
                <c:TrackedText Text="BROADCAST TO ALL PLAYERS"
                               Style="{StaticResource Hud.FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding BroadcastMessage, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Hud.TextBox}"
                             Margin="0,0,10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding BroadcastCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1"
                            Command="{Binding BroadcastCommand}"
                            Style="{StaticResource Hud.Button.Primary}"
                            Height="34" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <c:HudIcon Kind="Bullhorn" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <c:TrackedText Text="BROADCAST" LetterSpacing="0.12"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.AccentInk}"
                                           VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </c:HudPanel>

        <!-- ══ Player roster ══ -->
        <c:HudPanel Grid.Row="3" Tint="Accent" Header="ROSTER" Margin="16,0,16,12">
            <Grid>
                <DataGrid ItemsSource="{Binding Players}"
                          SelectedItem="{Binding SelectedPlayer}"
                          Style="{StaticResource Hud.DataGrid}"
                          RowStyle="{StaticResource PlayerRow}"
                          Margin="1,0,1,1">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Player Info" Click="PlayerInfo_Click">
                                <MenuItem.Icon>
                                    <c:HudIcon Kind="AccountDetails"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <!-- Equal-width columns: every column takes an even share of the grid and
                         scales with it. NAME and IP get a MinWidth so they don't truncate at
                         narrow window sizes. -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME"    Binding="{Binding Name}"    Width="*" MinWidth="110"/>
                        <DataGridTextColumn Header="LEVEL"   Binding="{Binding Level}"   Width="*"/>
                        <DataGridTextColumn Header="HEALTH"  Binding="{Binding Health}"  Width="*"/>
                        <DataGridTextColumn Header="DEATHS"  Binding="{Binding Deaths}"  Width="*"/>
                        <DataGridTextColumn Header="ZOMBIES" Binding="{Binding Zombies}" Width="*"/>
                        <DataGridTextColumn Header="SCORE"   Binding="{Binding Score}"   Width="*"/>
                        <DataGridTextColumn Header="PING"    Binding="{Binding Ping}"    Width="*"/>
                        <DataGridTextColumn Header="IP"      Binding="{Binding Ip}"      Width="*" MinWidth="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state: not connected -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}">
                    <c:HudIcon Kind="LanDisconnect" Width="44" Height="44"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource Hud.FgFaint}"/>
                    <c:TrackedText Text="NO TELNET LINK"
                                   Style="{StaticResource Hud.SectionLabel}"
                                   Foreground="{DynamicResource Hud.FgFaint}"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </StackPanel>

                <!-- Empty state: connected, nobody online -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsOffline}"   Value="False"/>
                                        <Condition Binding="{Binding PlayerCount}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <c:HudIcon Kind="AccountOff" Width="44" Height="44"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource Hud.FgFaint}"/>
                    <c:TrackedText Text="NO PLAYERS ONLINE"
                                   Style="{StaticResource Hud.SectionLabel}"
                                   Foreground="{DynamicResource Hud.FgFaint}"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </StackPanel>
            </Grid>
        </c:HudPanel>

        <!-- ══ Action panel (shown when a player is selected) ══ -->
        <c:HudPanel Grid.Row="4" Tint="Red" Padding="14,12" Margin="16,0,16,14"
                    Visibility="{Binding IsPlayerSelected, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Selected target -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                    <c:TrackedText Text="SELECTED TARGET" Style="{StaticResource Hud.StatCaption}"/>
                    <TextBlock Text="{Binding SelectedPlayer.Name}"
                               Style="{StaticResource Hud.Mono.Text}"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Hud.Accent}"
                               Margin="0,3,0,0"/>
                    <TextBlock Style="{StaticResource Hud.Mono.Text}" FontSize="10"
                               Foreground="{DynamicResource Hud.FgSubtle}" Margin="0,2,0,0">
                        <Run Text="ID "/><Run Text="{Binding SelectedPlayer.EntityId, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Reason -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                    <c:TrackedText Text="REASON" Style="{StaticResource Hud.FieldLabel}"/>
                    <TextBox Text="{Binding ActionReason, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Hud.TextBox}"/>
                </StackPanel>

                <!-- Kick: amber ghost -->
                <Button Grid.Column="2"
                        Command="{Binding KickCommand}"
                        Style="{StaticResource Hud.Button}"
                        BorderBrush="{DynamicResource Hud.Amber}"
                        Height="34" Padding="16,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="AccountRemove" Width="13" Height="13"
                                                 Foreground="{DynamicResource Hud.Amber}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="KICK" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.Amber}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Ban: chamfered red — the destructive action -->
                <Button Grid.Column="3"
                        Command="{Binding BanCommand}"
                        Style="{StaticResource Hud.Button.Stop}"
                        Height="34" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="AccountOff" Width="13" Height="13"
                                                 Foreground="#12060A"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="BAN 1YR" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="#12060A"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </c:HudPanel>

    </Grid>
</UserControl>
