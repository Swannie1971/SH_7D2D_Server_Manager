<UserControl x:Class="SevenDaysManager.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Title ══ -->
        <c:HudTitle Grid.Row="0" Title="SCHEDULE" HorizontalAlignment="Left" Margin="16,14,0,12"/>

        <!-- ══ Master switch + countdown + actions ══ -->
        <Grid Grid.Row="1" Margin="16,0,16,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton IsChecked="{Binding Enabled}"
                              Style="{StaticResource Hud.Toggle}"
                              VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
                            <Setter Property="FontSize"   Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Text"       Value="SCHEDULE DISABLED"/>
                            <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Enabled}" Value="True">
                                    <Setter Property="Text"       Value="SCHEDULE ARMED"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Countdown to next restart -->
                <Border Margin="20,0,0,0" Padding="11,4"
                        Background="{DynamicResource Hud.AmberSoft}"
                        BorderBrush="{DynamicResource Hud.Amber}" BorderThickness="1"
                        VerticalAlignment="Center"
                        Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <c:TrackedText Text="NEXT RESTART" Style="{StaticResource Hud.StatCaption}"
                                       Foreground="{DynamicResource Hud.Amber}"
                                       VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <TextBlock Text="{Binding Countdown, Mode=OneWay}"
                                   Style="{StaticResource Hud.Mono.Text}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource Hud.Amber}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding NextRestartAt, Mode=OneWay}"
                                   Style="{StaticResource Hud.Mono.Text}"
                                   FontSize="10"
                                   Foreground="{DynamicResource Hud.FgSubtle}"
                                   VerticalAlignment="Center" Margin="9,0,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding RestartNowCommand}"
                        Style="{StaticResource Hud.Button}"
                        BorderBrush="{DynamicResource Hud.Amber}"
                        Height="30" Padding="14,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Restart" Width="13" Height="13"
                                                 Foreground="{DynamicResource Hud.Amber}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="RESTART NOW" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.Amber}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ApplyScheduleCommand}"
                        Style="{StaticResource Hud.Button.Primary}"
                        Height="30" Padding="14,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="APPLY" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.AccentInk}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Body ══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <Grid Margin="16,0,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT ── -->
                <StackPanel Grid.Column="0">

                    <!-- Restart schedule -->
                    <c:HudPanel Tint="Accent" Header="RESTART SCHEDULE" Padding="16,4,16,16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton Content="INTERVAL" IsChecked="{Binding ModeInterval}"
                                             GroupName="schedMode" Margin="0,0,20,0"
                                             Style="{StaticResource Hud.RadioButton}"/>
                                <RadioButton Content="DAILY TIMES" IsChecked="{Binding ModeDaily}"
                                             GroupName="schedMode"
                                             Style="{StaticResource Hud.RadioButton}"/>
                            </StackPanel>

                            <!-- Interval mode -->
                            <StackPanel Visibility="{Binding ModeInterval, Converter={StaticResource BoolToVis}}">
                                <c:TrackedText Text="RESTART EVERY" Style="{StaticResource Hud.FieldLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding IntervalHours, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Hud.TextBox}"
                                             Width="70" TextAlignment="Center" FontSize="13"/>
                                    <c:TrackedText Text="HOURS" Style="{StaticResource Hud.StatCaption}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Daily times mode -->
                            <StackPanel Visibility="{Binding ModeDaily, Converter={StaticResource BoolToVis}}">
                                <c:TrackedText Text="RESTART TIMES (HH:MM, 24H)" Style="{StaticResource Hud.FieldLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBox Text="{Binding NewDailyTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Hud.TextBox}"
                                             Width="90" TextAlignment="Center"/>
                                    <Button Command="{Binding AddDailyTimeCommand}"
                                            Style="{StaticResource Hud.Button}"
                                            Height="34" Padding="14,0" Margin="8,0,0,0">
                                        <c:TrackedText Text="ADD" LetterSpacing="0.12"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10.5" FontWeight="Bold"
                                                       Foreground="{DynamicResource Hud.Fg}"
                                                       VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding DailyTimes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource Hud.Surface2}"
                                                    BorderBrush="{DynamicResource Hud.Border}"
                                                    BorderThickness="1"
                                                    Padding="11,5" Margin="0,0,0,5">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Rectangle Width="5" Height="5"
                                                                   Fill="{DynamicResource Hud.Accent}"
                                                                   VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                        <TextBlock Text="{Binding}"
                                                                   Style="{StaticResource Hud.Mono.Text}"
                                                                   FontSize="12.5" FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button HorizontalAlignment="Right"
                                                            Command="{Binding DataContext.RemoveDailyTimeCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource Hud.Button.Icon}"
                                                            Width="22" Height="22">
                                                        <materialDesign:PackIcon Kind="Close" Width="11" Height="11"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </c:HudPanel>

                    <!-- Activity log — phosphor terminal, same treatment as the console -->
                    <c:HudPanel Tint="Blue" Header="ACTIVITY LOG" Padding="16,4,16,16">
                        <Grid Height="200">
                            <Rectangle Fill="{DynamicResource ConsoleBrush}"/>
                            <Rectangle Fill="{DynamicResource Hud.ScanlineTile}" IsHitTestVisible="False"/>
                            <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="1"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                                <ItemsControl ItemsSource="{Binding ActivityLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Style="{StaticResource Hud.Mono.Text}"
                                                       FontSize="10.5"
                                                       Foreground="{DynamicResource Hud.FgMuted}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </c:HudPanel>
                </StackPanel>

                <!-- ── RIGHT: in-game warnings ── -->
                <c:HudPanel Grid.Column="2" Tint="Amber" Header="IN-GAME WARNINGS" Padding="16,4,16,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hud.Body}" Margin="0,0,0,12"
                                   Text="Broadcast a countdown to players before the server restarts."/>

                        <c:TrackedText Text="WARN AT" Style="{StaticResource Hud.FieldLabel}"/>
                        <WrapPanel Margin="0,0,0,16">
                            <CheckBox Content="60 MIN" IsChecked="{Binding Warn60}"
                                      Style="{StaticResource Hud.CheckBox}" Margin="0,0,18,9"/>
                            <CheckBox Content="30 MIN" IsChecked="{Binding Warn30}"
                                      Style="{StaticResource Hud.CheckBox}" Margin="0,0,18,9"/>
                            <CheckBox Content="15 MIN" IsChecked="{Binding Warn15}"
                                      Style="{StaticResource Hud.CheckBox}" Margin="0,0,18,9"/>
                            <CheckBox Content="10 MIN" IsChecked="{Binding Warn10}"
                                      Style="{StaticResource Hud.CheckBox}" Margin="0,0,18,9"/>
                            <CheckBox Content="5 MIN"  IsChecked="{Binding Warn5}"
                                      Style="{StaticResource Hud.CheckBox}" Margin="0,0,18,9"/>
                            <CheckBox Content="1 MIN"  IsChecked="{Binding Warn1}"
                                      Style="{StaticResource Hud.CheckBox}" Margin="0,0,18,9"/>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <c:TrackedText Text="WARNING MESSAGE" Style="{StaticResource Hud.StatCaption}"/>
                            <TextBlock Text="{}{TIMEMIN} = minutes remaining"
                                       Style="{StaticResource Hud.Mono.Text}"
                                       FontSize="9.5"
                                       Foreground="{DynamicResource Hud.FgFaint}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBox Text="{Binding InGameWarning, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Hud.TextBox}"
                                 TextWrapping="Wrap" MinHeight="62"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Margin="0,0,0,16"/>

                        <c:TrackedText Text="FINAL MESSAGE (AT RESTART)" Style="{StaticResource Hud.FieldLabel}"/>
                        <TextBox Text="{Binding InGameNow, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Hud.TextBox}"
                                 TextWrapping="Wrap" MinHeight="62"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </c:HudPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
