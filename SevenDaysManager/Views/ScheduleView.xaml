<UserControl x:Class="SevenDaysManager.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarClock" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Schedule" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ToggleButton IsChecked="{Binding Enabled}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Margin="20,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12" Opacity="0.7">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disabled"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Border Background="#33000000" CornerRadius="8" Padding="16,4" Margin="24,0,0,0"
                            Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Next restart in " FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Countdown, Mode=OneWay}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                       VerticalAlignment="Center" FontFamily="Consolas"/>
                            <TextBlock Text=" at " FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding NextRestartAt, Mode=OneWay}" FontSize="12"
                                       Opacity="0.8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding RestartNowCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Restart" Width="15" Height="15"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Restart Now" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ApplyScheduleCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="30" Padding="14,0" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="15" Height="15"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Apply" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Body ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: Schedule + Log ── -->
                <StackPanel Grid.Column="0">
                    <materialDesign:Card Padding="16" Margin="0,0,0,12"
                                         Background="{DynamicResource GlassBrush}">
                        <StackPanel>
                            <TextBlock Text="RESTART SCHEDULE" Style="{StaticResource SectionHeader}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton Content="Interval" IsChecked="{Binding ModeInterval}"
                                             GroupName="schedMode" Margin="0,0,16,0"
                                             Style="{StaticResource MaterialDesignRadioButton}"/>
                                <RadioButton Content="Daily times" IsChecked="{Binding ModeDaily}"
                                             GroupName="schedMode"
                                             Style="{StaticResource MaterialDesignRadioButton}"/>
                            </StackPanel>

                            <!-- Interval -->
                            <StackPanel Visibility="{Binding ModeInterval, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Every" VerticalAlignment="Center"
                                               Opacity="0.6" Margin="0,0,10,0"/>
                                    <TextBox Text="{Binding IntervalHours, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60" materialDesign:HintAssist.Hint="hours"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             FontSize="14" TextAlignment="Center"/>
                                    <TextBlock Text="hours" VerticalAlignment="Center"
                                               Margin="10,0,0,0" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Daily times -->
                            <StackPanel Visibility="{Binding ModeDaily, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Restart times (HH:mm, 24h)" FontSize="11"
                                           Opacity="0.5" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBox Text="{Binding NewDailyTime, UpdateSourceTrigger=PropertyChanged}"
                                             Width="80" materialDesign:HintAssist.Hint="HH:mm"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             FontSize="13"/>
                                    <Button Command="{Binding AddDailyTimeCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Height="32" Padding="10,0" Margin="8,0,0,0" FontSize="12">Add</Button>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding DailyTimes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#22FFFFFF" CornerRadius="4"
                                                    Padding="10,4" Margin="0,0,0,4">
                                                <Grid>
                                                    <TextBlock Text="{Binding}" FontSize="13"
                                                               FontFamily="Consolas" VerticalAlignment="Center"/>
                                                    <Button HorizontalAlignment="Right"
                                                            Command="{Binding DataContext.RemoveDailyTimeCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="24" Height="24">
                                                        <materialDesign:PackIcon Kind="Close" Width="12" Height="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Activity log -->
                    <materialDesign:Card Padding="16" Background="{DynamicResource GlassBrush}">
                        <StackPanel>
                            <TextBlock Text="ACTIVITY LOG" Style="{StaticResource SectionHeader}"/>
                            <Border Background="#CC0D0D0D" CornerRadius="4" Padding="10" Height="200">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ActivityLog}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas"
                                                           Opacity="0.7" Margin="0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <!-- ── Right: Warnings ── -->
                <materialDesign:Card Grid.Column="2" Padding="16" Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <TextBlock Text="IN-GAME WARNINGS" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Send in-game messages before restart:"
                                   FontSize="12" Opacity="0.6" Margin="0,0,0,12"/>
                        <WrapPanel Margin="0,0,0,16">
                            <CheckBox Content="60 min" IsChecked="{Binding Warn60}"
                                      Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,16,8"/>
                            <CheckBox Content="30 min" IsChecked="{Binding Warn30}"
                                      Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,16,8"/>
                            <CheckBox Content="15 min" IsChecked="{Binding Warn15}"
                                      Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,16,8"/>
                            <CheckBox Content="10 min" IsChecked="{Binding Warn10}"
                                      Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,16,8"/>
                            <CheckBox Content="5 min"  IsChecked="{Binding Warn5}"
                                      Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,16,8"/>
                            <CheckBox Content="1 min"  IsChecked="{Binding Warn1}"
                                      Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,16,8"/>
                        </WrapPanel>

                        <TextBlock Text="WARNING MESSAGE" FontSize="10" FontWeight="SemiBold"
                                   Opacity="0.5" Margin="0,0,0,4"/>
                        <TextBlock Text="{}{TIMEMIN} = minutes remaining" FontSize="10"
                                   Opacity="0.35" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InGameWarning, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="12" TextWrapping="Wrap" MinHeight="60"
                                 AcceptsReturn="True" Margin="0,0,0,16"/>

                        <TextBlock Text="FINAL MESSAGE (AT RESTART)" FontSize="10" FontWeight="SemiBold"
                                   Opacity="0.5" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding InGameNow, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="12" TextWrapping="Wrap" MinHeight="60"
                                 AcceptsReturn="True"/>
                    </StackPanel>
                </materialDesign:Card>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
