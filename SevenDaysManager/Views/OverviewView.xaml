<UserControl x:Class="SevenDaysManager.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Reusable label/value stack used in info grids -->
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Opacity"    Value="0.5"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="InfoValuePlain" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Card section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>

        <!-- Stat tile bottom row -->
        <Style x:Key="StatTileLabel" TargetType="TextBlock">
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Opacity"   Value="0.5"/>
            <Setter Property="Margin"    Value="0,6,0,0"/>
        </Style>
        <Style x:Key="StatTileValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="14">
        <StackPanel>

            <!-- ══════════════════════════════════════════ ROW 1: Overview + System Info ══ -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="290"/>
                </Grid.ColumnDefinitions>

                <!-- Overview info card -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="10"
                                     Padding="18" Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" CornerRadius="2" Margin="0,0,8,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="Overview" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>

                        <UniformGrid Columns="3">

                            <!-- Col 1 -->
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Text="Server Name" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding ServerName}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Text="Server Uptime" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding ServerUptime}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Game Time" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding GameTime}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>

                            <!-- Col 2 -->
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Text="Server IP" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding ServerIp}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,12">
                                <TextBlock Text="Game Name" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding GameName}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Game Mode" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding GameMode}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>

                            <!-- Col 3 -->
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Server Port" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding ServerPortStr}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Game World" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding GameWorld}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="Difficulty" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding GameDifficulty}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>

                        </UniformGrid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- System Information card -->
                <materialDesign:Card Grid.Column="2" UniformCornerRadius="10"
                                     Padding="18" Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" CornerRadius="2" Margin="0,0,8,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="System Information" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Device Name" Style="{StaticResource InfoLabel}" Margin="0,0,12,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceName}" Style="{StaticResource InfoValuePlain}" VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Processor" Style="{StaticResource InfoLabel}" Margin="0,0,12,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProcessorName}" Style="{StaticResource InfoValuePlain}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU Cores" Style="{StaticResource InfoLabel}" Margin="0,0,12,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProcessorCount}" Style="{StaticResource InfoValuePlain}" VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="System RAM" Style="{StaticResource InfoLabel}" Margin="0,0,12,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TotalRam}" Style="{StaticResource InfoValuePlain}" VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="OS" Style="{StaticResource InfoLabel}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding OsDescription}" Style="{StaticResource InfoValuePlain}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Server version -->
                        <Separator Margin="0,4,0,10" Opacity="0.2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Server Version" Style="{StaticResource InfoLabel}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ServerVersion}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- ══════════════════════════════════════════ ROW 2: Status gauges ══ -->
            <materialDesign:Card UniformCornerRadius="10" Padding="18"
                                 Background="#CC1A1A1A" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" CornerRadius="2" Margin="0,0,8,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="Status" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>
                        <!-- Offline badge — visible when Telnet not connected -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                CornerRadius="10" Padding="10,3"
                                Background="#44FF5722"
                                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#FF5722" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Not connected — check Telnet port/password in Server Settings"
                                           FontSize="11" Foreground="#FF5722" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <UniformGrid Columns="4">

                        <!-- Players -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <!-- Track ring — always visible on dark backgrounds -->
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource MaterialDesign.Brush.Primary}"
                                         StrokeThickness="8" Opacity="0.2"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                             Value="{Binding PlayerCount, Mode=OneWay}"
                                             Maximum="{Binding MaxPlayers, Mode=OneWay}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center">
                                        <Run Text="{Binding PlayerCount, Mode=OneWay}" FontSize="26" FontWeight="Bold"/>
                                        <Run Text="/" FontSize="13" Foreground="#80FFFFFF"/>
                                        <Run Text="{Binding MaxPlayers, Mode=OneWay}" FontSize="13" Foreground="#80FFFFFF"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Players" HorizontalAlignment="Center"
                                       FontSize="13" Opacity="0.6" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Zombies -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource MaterialDesign.Brush.Primary}"
                                         StrokeThickness="8" Opacity="0.2"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                             Value="{Binding ZombieCount, Mode=OneWay}"
                                             Maximum="{Binding MaxZombies, Mode=OneWay}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center">
                                        <Run Text="{Binding ZombieCount, Mode=OneWay}" FontSize="26" FontWeight="Bold"/>
                                        <Run Text="/" FontSize="13" Foreground="#80FFFFFF"/>
                                        <Run Text="{Binding MaxZombies, Mode=OneWay}" FontSize="13" Foreground="#80FFFFFF"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Zombies" HorizontalAlignment="Center"
                                       FontSize="13" Opacity="0.6" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Animals -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource MaterialDesign.Brush.Primary}"
                                         StrokeThickness="8" Opacity="0.2"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                             Value="{Binding AnimalCount, Mode=OneWay}"
                                             Maximum="{Binding MaxAnimals, Mode=OneWay}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center">
                                        <Run Text="{Binding AnimalCount, Mode=OneWay}" FontSize="26" FontWeight="Bold"/>
                                        <Run Text="/" FontSize="13" Foreground="#80FFFFFF"/>
                                        <Run Text="{Binding MaxAnimals, Mode=OneWay}" FontSize="13" Foreground="#80FFFFFF"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Animals" HorizontalAlignment="Center"
                                       FontSize="13" Opacity="0.6" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Heap -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource MaterialDesign.Brush.Primary}"
                                         StrokeThickness="8" Opacity="0.2"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                             Value="{Binding HeapPercent, Mode=OneWay}"
                                             Maximum="100"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center">
                                        <Run Text="{Binding HeapPercent, Mode=OneWay}" FontSize="26" FontWeight="Bold"/>
                                        <Run Text="/ 100 %" FontSize="13" Foreground="#80FFFFFF"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <TextBlock HorizontalAlignment="Center" FontSize="13" Opacity="0.6" Margin="0,10,0,0">
                                <Run Text="Heap "/>
                                <Run Text="{Binding HeapUsedMb, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding HeapMaxMb, Mode=OneWay}"/>
                                <Run Text=" MB"/>
                            </TextBlock>
                        </StackPanel>

                    </UniformGrid>
                </StackPanel>
            </materialDesign:Card>

            <!-- ══════════════════════════════════════════ ROW 3: Stat tiles ══ -->
            <UniformGrid Columns="6">

                <!-- FPS -->
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,8,0"
                                     Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Margin="0,0,6,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="FPS" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Fps, StringFormat='{}{0:F1}'}"
                                   Style="{StaticResource StatTileValue}" Margin="0,6,0,0"/>
                        <TextBlock Text="Server game loop speed. 30+ is healthy."
                                   FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Entities -->
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,8,0"
                                     Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Margin="0,0,6,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="Entities" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding EntityCount}"
                                   Style="{StaticResource StatTileValue}" Margin="0,6,0,0"/>
                        <TextBlock Text="All active objects: players, zombies, animals."
                                   FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- RSS -->
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,8,0"
                                     Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Margin="0,0,6,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="RSS" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource StatTileValue}" Margin="0,6,0,0">
                            <Run Text="{Binding RssMb, Mode=OneWay}"/><Run Text=" MB" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Text="Total physical RAM used by the server process."
                                   FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Chunks -->
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,8,0"
                                     Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Margin="0,0,6,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="Chunks" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Chunks, Mode=OneWay}"
                                   Style="{StaticResource StatTileValue}" Margin="0,6,0,0"/>
                        <TextBlock Text="World sections loaded in memory around players."
                                   FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- CGO -->
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,8,0"
                                     Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Margin="0,0,6,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="CGO" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Cgo, Mode=OneWay}"
                                   Style="{StaticResource StatTileValue}" Margin="0,6,0,0"/>
                        <TextBlock Text="Active chunk objects: loot, doors, physics blocks."
                                   FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Items -->
                <materialDesign:Card UniformCornerRadius="10" Padding="16"
                                     Background="{DynamicResource GlassBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Margin="0,0,6,0"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <TextBlock Text="Items" FontSize="12" FontWeight="SemiBold" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Items, Mode=OneWay}"
                                   Style="{StaticResource StatTileValue}" Margin="0,6,0,0"/>
                        <TextBlock Text="Dropped item stacks on the ground in the world."
                                   FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
