<UserControl x:Class="SevenDaysManager.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Readout label: uppercase mono, wide tracking, rust.
             Targets TrackedText (not TextBlock) — see TrackedText.cs for why. -->
        <Style x:Key="Readout.Label" TargetType="c:TrackedText" BasedOn="{StaticResource Hud.StatCaption}">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Readout value: mono, tabular figures, accent -->
        <Style x:Key="Readout.Value" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Plain mono value (system info) -->
        <Style x:Key="Readout.Plain" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.FgMuted}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Gauge centre number -->
        <Style x:Key="Gauge.Value" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize"   Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Faint index stamp on stat tiles (01, 02 …) -->
        <Style x:Key="Tile.Index" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Bottom"/>
        </Style>

        <Style x:Key="Tile.Desc" TargetType="TextBlock" BasedOn="{StaticResource Hud.Body}">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="14">
        <StackPanel>

            <!-- // OVERVIEW ▊ -->
            <c:HudTitle Title="OVERVIEW" HorizontalAlignment="Left" Margin="4,2,0,14"/>

            <!-- ══════════════════════════════ ROW 1: Telemetry + System ══ -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <c:HudPanel Grid.Column="0" Header="TELEMETRY" Tint="Accent" Padding="18">
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,20,14">
                            <c:TrackedText Text="SERVER NAME" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding ServerName}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,14">
                            <c:TrackedText Text="UPTIME" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding ServerUptime}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <c:TrackedText Text="GAME TIME" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding GameTime}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,14">
                            <c:TrackedText Text="SERVER IP" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding ServerIp}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,14">
                            <c:TrackedText Text="GAME NAME" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding GameName}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <c:TrackedText Text="GAME MODE" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding GameMode}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <c:TrackedText Text="PORT" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding ServerPortStr}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <c:TrackedText Text="WORLD" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding GameWorld}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0">
                            <c:TrackedText Text="DIFFICULTY" Style="{StaticResource Readout.Label}"/>
                            <TextBlock Text="{Binding GameDifficulty}" Style="{StaticResource Readout.Value}"/>
                        </StackPanel>
                    </UniformGrid>
                </c:HudPanel>

                <c:HudPanel Grid.Column="2" Header="SYSTEM" Tint="Rust" Padding="18">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <c:TrackedText Grid.Row="0" Grid.Column="0" Text="DEVICE" Style="{StaticResource Hud.StatCaption}" Margin="0,0,12,9" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceName}" Style="{StaticResource Readout.Plain}" VerticalAlignment="Center" Margin="0,0,0,9"/>

                            <c:TrackedText Grid.Row="1" Grid.Column="0" Text="CPU" Style="{StaticResource Hud.StatCaption}" Margin="0,0,12,9" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProcessorName}" Style="{StaticResource Readout.Plain}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,0,9"/>

                            <c:TrackedText Grid.Row="2" Grid.Column="0" Text="CORES" Style="{StaticResource Hud.StatCaption}" Margin="0,0,12,9" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProcessorCount}" Style="{StaticResource Readout.Plain}" VerticalAlignment="Center" Margin="0,0,0,9"/>

                            <c:TrackedText Grid.Row="3" Grid.Column="0" Text="RAM" Style="{StaticResource Hud.StatCaption}" Margin="0,0,12,9" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TotalRam}" Style="{StaticResource Readout.Plain}" VerticalAlignment="Center" Margin="0,0,0,9"/>

                            <c:TrackedText Grid.Row="4" Grid.Column="0" Text="OS" Style="{StaticResource Hud.StatCaption}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding OsDescription}" Style="{StaticResource Readout.Plain}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource Hud.Border}" Margin="0,14"/>

                        <StackPanel Orientation="Horizontal">
                            <c:TrackedText Text="BUILD" Style="{StaticResource Hud.StatCaption}"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ServerVersion}"
                                       Style="{StaticResource Hud.Mono.Text}"
                                       FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Hud.Accent}"/>
                        </StackPanel>
                    </StackPanel>
                </c:HudPanel>
            </Grid>

            <!-- ══════════════════════════════ ROW 2: Status gauges ══ -->
            <c:HudPanel Header="STATUS" Tint="Green" Padding="18" Margin="0,0,0,10">
                <StackPanel>

                    <!-- Offline pill: square dot, chamfer-free border, red-soft fill -->
                    <Border HorizontalAlignment="Left" Margin="0,0,0,16"
                            Background="{DynamicResource Hud.RedSoft}"
                            BorderBrush="{DynamicResource Hud.Red}"
                            BorderThickness="1"
                            Padding="10,4"
                            Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="6" Height="6" Fill="{DynamicResource Hud.Red}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <c:TrackedText Text="NO TELNET LINK — CHECK PORT/PASSWORD IN SERVER SETTINGS"
                                       Style="{StaticResource Hud.PillText}"
                                       Foreground="{DynamicResource Hud.Red}"/>
                        </StackPanel>
                    </Border>

                    <UniformGrid Columns="4">

                        <!-- PLAYERS -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource Hud.Border}" StrokeThickness="7"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource Hud.Accent}"
                                             Value="{Binding PlayerCount, Mode=OneWay}"
                                             Maximum="{Binding MaxPlayers, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource Gauge.Value}" VerticalAlignment="Center">
                                    <Run Text="{Binding PlayerCount, Mode=OneWay}"/><Run Text="/" FontSize="12" Foreground="#6E767D"/><Run Text="{Binding MaxPlayers, Mode=OneWay}" FontSize="12" Foreground="#6E767D"/>
                                </TextBlock>
                            </Grid>
                            <c:TrackedText Text="PLAYERS" Style="{StaticResource Hud.StatCaption}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- ZOMBIES -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource Hud.Border}" StrokeThickness="7"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource Hud.Red}"
                                             Value="{Binding ZombieCount, Mode=OneWay}"
                                             Maximum="{Binding MaxZombies, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource Gauge.Value}" VerticalAlignment="Center">
                                    <Run Text="{Binding ZombieCount, Mode=OneWay}"/><Run Text="/" FontSize="12" Foreground="#6E767D"/><Run Text="{Binding MaxZombies, Mode=OneWay}" FontSize="12" Foreground="#6E767D"/>
                                </TextBlock>
                            </Grid>
                            <c:TrackedText Text="ZOMBIES" Style="{StaticResource Hud.StatCaption}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- ANIMALS -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource Hud.Border}" StrokeThickness="7"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource Hud.Violet}"
                                             Value="{Binding AnimalCount, Mode=OneWay}"
                                             Maximum="{Binding MaxAnimals, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource Gauge.Value}" VerticalAlignment="Center">
                                    <Run Text="{Binding AnimalCount, Mode=OneWay}"/><Run Text="/" FontSize="12" Foreground="#6E767D"/><Run Text="{Binding MaxAnimals, Mode=OneWay}" FontSize="12" Foreground="#6E767D"/>
                                </TextBlock>
                            </Grid>
                            <c:TrackedText Text="ANIMALS" Style="{StaticResource Hud.StatCaption}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- HEAP -->
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="130" Height="130">
                                <Ellipse Width="112" Height="112" Fill="Transparent"
                                         Stroke="{DynamicResource Hud.Border}" StrokeThickness="7"/>
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Width="130" Height="130"
                                             Foreground="{DynamicResource Hud.Amber}"
                                             Value="{Binding HeapPercent, Mode=OneWay}"
                                             Maximum="100"/>
                                <TextBlock Style="{StaticResource Gauge.Value}" VerticalAlignment="Center">
                                    <Run Text="{Binding HeapPercent, Mode=OneWay}"/><Run Text="%" FontSize="12" Foreground="#6E767D"/>
                                </TextBlock>
                            </Grid>
                            <!-- TrackedText renders a single glyph run, so it has no Inlines —
                                 compose the caption into one string instead of using <Run>s. -->
                            <c:TrackedText Style="{StaticResource Hud.StatCaption}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0">
                                <c:TrackedText.Text>
                                    <MultiBinding StringFormat="HEAP {0}/{1} MB">
                                        <Binding Path="HeapUsedMb" Mode="OneWay"/>
                                        <Binding Path="HeapMaxMb"  Mode="OneWay"/>
                                    </MultiBinding>
                                </c:TrackedText.Text>
                            </c:TrackedText>
                        </StackPanel>

                    </UniformGrid>
                </StackPanel>
            </c:HudPanel>

            <!-- ══════════════════════════════ ROW 3: Stat tiles ══ -->
            <UniformGrid Columns="6">

                <c:HudPanel Tint="Accent" Margin="0,0,8,0">
                    <Grid Margin="16">
                        <StackPanel>
                            <Grid>
                                <c:TrackedText Text="FPS" Style="{StaticResource Hud.StatCaption}"/>
                                <Rectangle Height="2" Width="42" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Fill="{DynamicResource Hud.Accent}"/>
                            </Grid>
                            <TextBlock Text="{Binding Fps, StringFormat='{}{0:F1}'}"
                                       Style="{StaticResource Hud.StatValue}" Margin="0,8,0,0"/>
                            <TextBlock Text="Server game loop speed. 30+ is healthy."
                                       Style="{StaticResource Tile.Desc}"/>
                        </StackPanel>
                        <TextBlock Text="01" Style="{StaticResource Tile.Index}"/>
                    </Grid>
                </c:HudPanel>

                <c:HudPanel Tint="Blue" Margin="0,0,8,0">
                    <Grid Margin="16">
                        <StackPanel>
                            <Grid>
                                <c:TrackedText Text="ENTITIES" Style="{StaticResource Hud.StatCaption}"/>
                                <Rectangle Height="2" Width="42" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Fill="{DynamicResource Hud.Blue}"/>
                            </Grid>
                            <TextBlock Text="{Binding EntityCount}"
                                       Style="{StaticResource Hud.StatValue}" Margin="0,8,0,0"/>
                            <TextBlock Text="All active objects: players, zombies, animals."
                                       Style="{StaticResource Tile.Desc}"/>
                        </StackPanel>
                        <TextBlock Text="02" Style="{StaticResource Tile.Index}"/>
                    </Grid>
                </c:HudPanel>

                <c:HudPanel Tint="Amber" Margin="0,0,8,0">
                    <Grid Margin="16">
                        <StackPanel>
                            <Grid>
                                <c:TrackedText Text="RSS" Style="{StaticResource Hud.StatCaption}"/>
                                <Rectangle Height="2" Width="42" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Fill="{DynamicResource Hud.Amber}"/>
                            </Grid>
                            <TextBlock Style="{StaticResource Hud.StatValue}" Margin="0,8,0,0">
                                <Run Text="{Binding RssMb, Mode=OneWay}"/><Run Text=" MB" FontSize="13" Foreground="#6E767D"/>
                            </TextBlock>
                            <TextBlock Text="Total physical RAM used by the server process."
                                       Style="{StaticResource Tile.Desc}"/>
                        </StackPanel>
                        <TextBlock Text="03" Style="{StaticResource Tile.Index}"/>
                    </Grid>
                </c:HudPanel>

                <c:HudPanel Tint="Violet" Margin="0,0,8,0">
                    <Grid Margin="16">
                        <StackPanel>
                            <Grid>
                                <c:TrackedText Text="CHUNKS" Style="{StaticResource Hud.StatCaption}"/>
                                <Rectangle Height="2" Width="42" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Fill="{DynamicResource Hud.Violet}"/>
                            </Grid>
                            <TextBlock Text="{Binding Chunks, Mode=OneWay}"
                                       Style="{StaticResource Hud.StatValue}" Margin="0,8,0,0"/>
                            <TextBlock Text="World sections loaded in memory around players."
                                       Style="{StaticResource Tile.Desc}"/>
                        </StackPanel>
                        <TextBlock Text="04" Style="{StaticResource Tile.Index}"/>
                    </Grid>
                </c:HudPanel>

                <c:HudPanel Tint="Rust" Margin="0,0,8,0">
                    <Grid Margin="16">
                        <StackPanel>
                            <Grid>
                                <c:TrackedText Text="CGO" Style="{StaticResource Hud.StatCaption}"/>
                                <Rectangle Height="2" Width="42" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Fill="{DynamicResource Hud.Rust}"/>
                            </Grid>
                            <TextBlock Text="{Binding Cgo, Mode=OneWay}"
                                       Style="{StaticResource Hud.StatValue}" Margin="0,8,0,0"/>
                            <TextBlock Text="Active chunk objects: loot, doors, physics blocks."
                                       Style="{StaticResource Tile.Desc}"/>
                        </StackPanel>
                        <TextBlock Text="05" Style="{StaticResource Tile.Index}"/>
                    </Grid>
                </c:HudPanel>

                <c:HudPanel Tint="Green">
                    <Grid Margin="16">
                        <StackPanel>
                            <Grid>
                                <c:TrackedText Text="ITEMS" Style="{StaticResource Hud.StatCaption}"/>
                                <Rectangle Height="2" Width="42" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Fill="{DynamicResource Hud.Green}"/>
                            </Grid>
                            <TextBlock Text="{Binding Items, Mode=OneWay}"
                                       Style="{StaticResource Hud.StatValue}" Margin="0,8,0,0"/>
                            <TextBlock Text="Dropped item stacks on the ground in the world."
                                       Style="{StaticResource Tile.Desc}"/>
                        </StackPanel>
                        <TextBlock Text="06" Style="{StaticResource Tile.Index}"/>
                    </Grid>
                </c:HudPanel>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
