<Window x:Class="SevenDaysManager.Views.HudDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="460"
        WindowStartupLocation="CenterOwner"
        FontSize="14">

    <!-- Square, bracketed, hazard-striped. Replaces the OS MessageBox, which cannot be
         styled at all (it is drawn by Windows, not WPF). -->
    <Border Background="{DynamicResource Hud.Bg}"
            BorderBrush="{DynamicResource Hud.BorderStrong}"
            BorderThickness="1"
            VerticalAlignment="Top">
        <Grid VerticalAlignment="Top">
            <!-- The content stack drives the height; the atmosphere just paints over it.
                 (HudAtmosphere's scan-sweep band is a fixed 260px tall, so if it were allowed to
                 measure it would force the window to 260px minimum under SizeToContent="Height",
                 leaving a dead gap under the buttons.) -->
            <c:HudAtmosphere Panel.ZIndex="0"/>

            <StackPanel Panel.ZIndex="1" VerticalAlignment="Top">

                <!-- Header: hazard tape + icon + title -->
                <Grid Height="54">
                    <Rectangle Fill="{DynamicResource Hud.BgElevated}"/>
                    <Rectangle x:Name="HazardStripe"
                               Fill="{DynamicResource Hud.HazardTile}" Opacity="0.35"/>
                    <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                        <c:HudIcon x:Name="TitleIcon"
                                                 Width="17" Height="17"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <c:TrackedText x:Name="TitleText"
                                       Style="{StaticResource Hud.PanelHeader}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Message -->
                <TextBlock x:Name="MessageText"
                           Style="{StaticResource Hud.Body}"
                           FontSize="13"
                           Foreground="{DynamicResource Hud.Fg}"
                           Margin="20,20,20,22"
                           TextWrapping="Wrap"/>

                <!-- Buttons -->
                <Border Background="{DynamicResource Hud.BgElevated}"
                        BorderBrush="{DynamicResource Hud.Border}"
                        BorderThickness="0,1,0,0"
                        Padding="18,11">
                    <StackPanel x:Name="ButtonRow"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"/>
                </Border>
            </StackPanel>

            <c:HudBrackets x:Name="Brackets" Panel.ZIndex="2" Tint="Amber"/>
        </Grid>
    </Border>
</Window>
