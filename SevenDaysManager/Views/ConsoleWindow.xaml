<Window x:Class="SevenDaysManager.Views.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:SevenDaysManager.Models"
        Title="Server Console"
        Width="900" Height="620"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#FF121212"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ServerName, StringFormat='Console — {0}'}"
                               FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#757575"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.8"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Output area -->
        <Border Grid.Row="1" Background="#0D0D0D">
            <ScrollViewer x:Name="OutputScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4">
                <ItemsControl x:Name="OutputList"
                              ItemsSource="{Binding Lines}"
                              Padding="10,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ConsoleLine}">
                            <TextBlock Text="{Binding Text}"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Padding="0,1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.Error}">
                                                <Setter Property="Foreground" Value="#EF5350"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.Warning}">
                                                <Setter Property="Foreground" Value="#FFB300"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.Chat}">
                                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.System}">
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Command input -->
        <Border Grid.Row="2" Background="#1A1A1A" Padding="10,8"
                BorderThickness="0,1,0,0" BorderBrush="#333333">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text=">" FontFamily="Consolas, Courier New" FontSize="14"
                           Foreground="#4CAF50" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <TextBox x:Name="CommandBox"
                         Grid.Column="1"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas, Courier New"
                         FontSize="13"
                         Foreground="#E0E0E0"
                         Background="Transparent"
                         BorderThickness="0"
                         CaretBrush="#4CAF50"
                         VerticalAlignment="Center"
                         materialDesign:HintAssist.Hint="Enter command…"
                         materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
                         Style="{StaticResource MaterialDesignTextBox}"
                         KeyDown="CommandBox_KeyDown"/>

                <Button Grid.Column="2"
                        Content="Send"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Height="34" Padding="16,0" Margin="8,0,0,0"
                        Command="{Binding SendCommandCommand}"
                        IsDefault="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
