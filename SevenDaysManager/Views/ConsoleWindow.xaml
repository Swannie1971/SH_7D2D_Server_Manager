<Window x:Class="SevenDaysManager.Views.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:SevenDaysManager.Models"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        Title="Server Console"
        Width="900" Height="620"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#FF121212"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ServerName, StringFormat='Console — {0}'}"
                               FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#757575"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.8"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Output area -->
        <Border Grid.Row="1" Background="#0D0D0D">
            <ScrollViewer x:Name="OutputScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4">
                <ItemsControl x:Name="OutputList"
                              ItemsSource="{Binding Lines}"
                              Padding="10,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ConsoleLine}">
                            <TextBlock Text="{Binding Text}"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Padding="0,1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.Error}">
                                                <Setter Property="Foreground" Value="#EF5350"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.Warning}">
                                                <Setter Property="Foreground" Value="#FFB300"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.Chat}">
                                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}"
                                                         Value="{x:Static models:ConsoleLineType.System}">
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Command input -->
        <Border Grid.Row="2" Background="#1A1A1A" Padding="10,8"
                BorderThickness="0,1,0,0" BorderBrush="#333333">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Pulsing accent prompt -->
                <TextBlock Text="›"
                           FontFamily="{DynamicResource Hud.Mono}" FontSize="16"
                           Foreground="{DynamicResource Hud.Accent}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="2,0,10,0">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.25" Duration="0:0:0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>

                <TextBox x:Name="CommandBox"
                         Grid.Column="1"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Hud.TextBox}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         FontFamily="{DynamicResource Hud.Mono}" FontSize="13"
                         VerticalAlignment="Center"
                         KeyDown="CommandBox_KeyDown"/>

                <!-- SEND: chamfered accent -->
                <Button Grid.Column="2"
                        Style="{StaticResource Hud.Button.Primary}"
                        Height="34" Padding="16,0" Margin="10,0,0,0"
                        Command="{Binding SendCommandCommand}"
                        IsDefault="True">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Send" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="SEND" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.AccentInk}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
