<UserControl x:Class="SevenDaysManager.Views.GameSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Opacity"      Value="0.65"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="SettingHint" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Opacity"    Value="0.55"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12,12,16">

            <!-- ══ DIFFICULTY & PROGRESSION ══════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="DIFFICULTY &amp; PROGRESSION" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <Grid Margin="16,4,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Game Difficulty" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Overall challenge level for all players" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding DifficultyOptions}" SelectedValue="{Binding GameDifficulty}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="XP Multiplier" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="How fast players level up skills and perks" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding XpOptions}" SelectedValue="{Binding XpMultiplier}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Player Killing (PvP)" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Controls whether players can attack each other" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding PlayerKillingOptions}" SelectedValue="{Binding PlayerKillingMode}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </materialDesign:Card>

            <!-- ══ TIME & WORLD ══════════════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="TIME &amp; WORLD" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <Grid Margin="16,4,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Game Day Length" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Real-world minutes per in-game day" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding DayLengthOptions}" SelectedValue="{Binding DayNightLength}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Daylight Hours" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Hours of daylight (6–24). Fewer = longer, more dangerous nights" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding DayLightOptions}" SelectedValue="{Binding DayLightLength}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </materialDesign:Card>

            <!-- ══ ZOMBIES ════════════════════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="ZOMBIES" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <StackPanel Margin="16,4,16,16">
                        <!-- Speeds row -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Speed (Day)" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Regular zombies in daylight" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding ZombieSpeedOptions}" SelectedValue="{Binding ZombieMove}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Speed (Night)" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Regular zombies at night" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding ZombieSpeedOptions}" SelectedValue="{Binding ZombieMoveNight}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Feral Speed" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Glowing-eye zombies (always active)" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding ZombieSpeedOptions}" SelectedValue="{Binding ZombieFeralMove}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Blood Moon Speed" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Zombie speed during Blood Moon hordes" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding ZombieSpeedOptions}" SelectedValue="{Binding ZombieBMMove}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                        </Grid>
                        <!-- Spawn caps row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Max Spawned Zombies (8–128)" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Active zombies on the map at once — lower helps server performance" Style="{StaticResource SettingHint}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                    <Slider Minimum="8" Maximum="128" TickFrequency="8" IsSnapToTickEnabled="True"
                                            Value="{Binding MaxSpawnedZombies}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding MaxSpawnedZombies}" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max Spawned Animals (0–100)" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Active animals on the map at once" Style="{StaticResource SettingHint}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                    <Slider Minimum="0" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="True"
                                            Value="{Binding MaxSpawnedAnimals}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding MaxSpawnedAnimals}" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>
            </materialDesign:Card>

            <!-- ══ BLOOD MOON ═════════════════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="BLOOD MOON" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <Grid Margin="16,4,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Frequency (every N days)" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="How often a Blood Moon horde attacks. 0 = disabled" Style="{StaticResource SettingHint}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <Slider Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding BloodMoonFrequency}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding BloodMoonFrequency, StringFormat='Day {0}'}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BloodMoonFrequency}" Value="0">
                                                    <Setter Property="Text" Value="Off"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Day Variance (±)" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Random ± days so Blood Moon doesn't always land on the same day" Style="{StaticResource SettingHint}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <Slider Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding BloodMoonRange}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding BloodMoonRange, StringFormat='±{0}'}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BloodMoonRange}" Value="0">
                                                    <Setter Property="Text" Value="None"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Enemy Count (8–64)" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Max zombies spawned during a Blood Moon wave" Style="{StaticResource SettingHint}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <Slider Minimum="8" Maximum="64" TickFrequency="4" IsSnapToTickEnabled="True"
                                        Value="{Binding BloodMoonEnemyCount}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding BloodMoonEnemyCount}" VerticalAlignment="Center"
                                           HorizontalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Expander>
            </materialDesign:Card>

            <!-- ══ LOOT & DROPS ═══════════════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="LOOT &amp; DROPS" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <StackPanel Margin="16,4,16,16">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Loot Abundance" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="How much loot spawns in containers" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding LootAbundanceOptions}" SelectedValue="{Binding LootAbundance}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Loot Respawn" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Days before looted containers refill" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding LootRespawnOptions}" SelectedValue="{Binding LootRespawnDays}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Air Drops" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="How often a supply airdrop lands on the map" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding AirDropOptions}" SelectedValue="{Binding AirDropFrequency}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Drop on Death" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="What a player drops when killed" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding DropOnDeathOptions}" SelectedValue="{Binding DropOnDeath}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Drop on Quit" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="What a player drops when they disconnect" Style="{StaticResource SettingHint}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding DropOnQuitOptions}" SelectedValue="{Binding DropOnQuit}"
                                          SelectedValuePath="Value" DisplayMemberPath="Label"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>
            </materialDesign:Card>

            <!-- ══ LAND CLAIMS ════════════════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="LAND CLAIMS" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <Grid Margin="16,4,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Claim Size" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Radius of land protected around a claim block" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding LandClaimSizeOptions}" SelectedValue="{Binding LandClaimSize}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Claim Expiry" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Days before an offline player's unclaimed land disappears" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding LandClaimExpiryOptions}" SelectedValue="{Binding LandClaimExpiryTime}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Offline Raid Protection" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="How hard land claim blocks are to break while owner is offline" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding LandClaimOfflineOptions}" SelectedValue="{Binding LandClaimOfflineDurabilityModifier}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </materialDesign:Card>

            <!-- ══ NEW PLAYER PROTECTION ══════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,8" Padding="0">
                <Expander Header="NEW PLAYER PROTECTION" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <Grid Margin="16,4,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Safe Zone Level" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="New players are protected from PvP until they reach this level" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding SafeZoneLevelOptions}" SelectedValue="{Binding PlayerSafeZoneLevel}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Safe Zone Hours" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="New players are protected until this many in-game hours have passed" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding SafeZoneHoursOptions}" SelectedValue="{Binding PlayerSafeZoneHours}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </materialDesign:Card>

            <!-- ══ PERFORMANCE ════════════════════════════════════════════════ -->
            <materialDesign:Card UniformCornerRadius="10" Background="{DynamicResource GlassBrush}" Margin="0,0,0,16" Padding="0">
                <Expander Header="PERFORMANCE" IsExpanded="False"
                          Background="Transparent"
                          materialDesign:ExpanderAssist.HorizontalHeaderPadding="16,12,16,12">
                    <Grid Margin="16,4,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Max View Distance" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Caps how far players can render. Lower = less server CPU and RAM" Style="{StaticResource SettingHint}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding ViewDistanceOptions}" SelectedValue="{Binding ServerMaxAllowedViewDistance}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </materialDesign:Card>

            <!-- Save error -->
            <Border CornerRadius="6" Background="#33F44336" Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SaveError}" Foreground="#F44336" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontSize="12" Opacity="0.55"
                           Text="Changes are written to serverconfig.xml — restart the server to apply."/>
                <Button Grid.Column="1"
                        Content="Save Changes"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding RequestSaveCommand}"
                        Width="140"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>

    <!-- Confirmation overlay -->
    <Grid Panel.ZIndex="100"
          Visibility="{Binding ConfirmPending, Converter={StaticResource BoolToVis}}"
          Background="#BB000000">
        <materialDesign:Card UniformCornerRadius="14" Padding="0"
                             Width="380"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp8">
            <materialDesign:Card.Background>
                <SolidColorBrush Color="#1E1E1E"/>
            </materialDesign:Card.Background>
            <StackPanel>
                <Border CornerRadius="14,14,0,0"
                        Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}"
                        Padding="20,14">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Save Game Settings"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <StackPanel Margin="24,20,24,24">
                    <TextBlock Text="Apply these settings to serverconfig.xml?"
                               FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock Text="The server will need to be restarted before changes take effect."
                               FontSize="12" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding CancelSaveCommand}"
                                Margin="0,0,12,0" Width="90"/>
                        <Button Content="Save"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding ConfirmSaveCommand}"
                                Width="90"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>

    </Grid>
</UserControl>
