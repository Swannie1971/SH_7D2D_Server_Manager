<UserControl x:Class="SevenDaysManager.Views.GameSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- One sandbox option = label + dropdown. The dropdown's items come from the game's
             own list of allowed values for that option, so the UI structurally cannot produce
             a value the game would reject. -->
        <DataTemplate x:Key="SandboxOptionTemplate">
            <StackPanel Margin="0,0,10,12">
                <c:TrackedText Text="{Binding Display}" Style="{StaticResource Hud.SettingLabel}"/>
                <ComboBox Style="{StaticResource Hud.ComboBox}"
                          ItemsSource="{Binding Choices}"
                          SelectedItem="{Binding Selected}"
                          Margin="0,4,0,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="12"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="TwoColumn">
            <UniformGrid Columns="2"/>
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="14,14,14,16">

            <c:HudTitle Title="GAME SETTINGS" HorizontalAlignment="Left" Margin="2,0,0,10"/>

            <!-- ══ V3 NOTICE ══════════════════════════════════════════════════ -->
            <Border Background="{DynamicResource Hud.BlueSoft}"
                    BorderBrush="{DynamicResource Hud.Blue}"
                    BorderThickness="1"
                    Padding="14,11" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <c:HudIcon Kind="AlertCircleOutline" Width="16" Height="16"
                               Foreground="{DynamicResource Hud.Blue}"
                               VerticalAlignment="Top" Margin="0,1,10,0"/>
                    <StackPanel>
                        <c:TrackedText Text="V3.0 — SANDBOX CODE"
                                       Style="{StaticResource Hud.StatCaption}"
                                       Foreground="{DynamicResource Hud.Blue}"/>
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   Margin="0,5,0,0"
                                   TextWrapping="Wrap"
                                   Text="Dead Hot Summer replaced the individual gameplay properties with a single Sandbox Code. These controls build that code for you — every choice comes from the game's own list of allowed values, so what gets written is always valid."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ DIFFICULTY ════════════════════════════════════════════════ -->
            <c:HudPanel Header="DIFFICULTY" Tint="Rust" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource Hud.SettingHint}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Text="In V3.0 difficulty is a preset over the damage multipliers — there is no longer a difficulty setting of its own. Applying one replaces every gameplay option below."/>
                    <ItemsControl ItemsSource="{Binding DifficultyPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource Hud.Button}"
                                        Height="30" MinWidth="130" Margin="0,0,8,8"
                                        Command="{Binding DataContext.ApplyPresetCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <c:TrackedText Text="{Binding Name}" LetterSpacing="0.1"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="10.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource Hud.Fg}"
                                                   VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </c:HudPanel>

            <!-- ══ COMBAT ════════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Red" Margin="0,0,0,8" Padding="0">
                <Expander Header="COMBAT &amp; PROGRESSION" IsExpanded="True" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding CombatOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ ZOMBIES ═══════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Green" Margin="0,0,0,8" Padding="0">
                <Expander Header="ZOMBIES" IsExpanded="True" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding ZombieOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ BLOOD MOON ════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Rust" Margin="0,0,0,8" Padding="0">
                <Expander Header="BLOOD MOON" IsExpanded="True" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding BloodMoonOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ LOOT ══════════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Amber" Margin="0,0,0,8" Padding="0">
                <Expander Header="LOOT &amp; DROPS" IsExpanded="True" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding LootOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ WORLD & TIME ══════════════════════════════════════════════ -->
            <c:HudPanel Tint="Blue" Margin="0,0,0,8" Padding="0">
                <Expander Header="WORLD &amp; TIME" IsExpanded="True" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding WorldOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ SERVER — still plain XML properties in V3 ═════════════════ -->
            <c:HudPanel Tint="Violet" Margin="0,0,0,8" Padding="0">
                <Expander Header="SERVER &amp; PERFORMANCE" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <StackPanel Margin="16,4,16,12">
                        <TextBlock Style="{StaticResource Hud.SettingHint}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="These are still individual serverconfig.xml properties — they were never part of the sandbox system."/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="PvP Mode" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding PlayerKillingOptions}"
                                          SelectedValue="{Binding PlayerKillingMode}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Max Spawned Zombies" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding MaxZombieOptions}"
                                          SelectedValue="{Binding MaxSpawnedZombies}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Max Spawned Animals" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding MaxAnimalOptions}"
                                          SelectedValue="{Binding MaxSpawnedAnimals}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="View Distance" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding ViewDistanceOptions}"
                                          SelectedValue="{Binding ServerMaxAllowedViewDistance}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Land Claim Size" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding LandClaimSizeOptions}"
                                          SelectedValue="{Binding LandClaimSize}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Land Claim Expiry" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding LandClaimExpiryOptions}"
                                          SelectedValue="{Binding LandClaimExpiryTime}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Offline Claim Durability" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding LandClaimOfflineOptions}"
                                          SelectedValue="{Binding LandClaimOfflineDurabilityModifier}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="New Player Safe Level" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding SafeZoneLevelOptions}"
                                          SelectedValue="{Binding PlayerSafeZoneLevel}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="New Player Safe Hours" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding SafeZoneHoursOptions}"
                                          SelectedValue="{Binding PlayerSafeZoneHours}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Expander>
            </c:HudPanel>

            <!-- ══ SANDBOX CODE ══════════════════════════════════════════════ -->
            <c:HudPanel Tint="Accent" Margin="0,0,0,8" Padding="0">
                <Expander Header="SANDBOX CODE" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <StackPanel Margin="16,4,16,14">

                        <c:TrackedText Text="GENERATED CODE" Style="{StaticResource Hud.StatCaption}"/>
                        <TextBlock Style="{StaticResource Hud.SettingHint}"
                                   TextWrapping="Wrap" Margin="0,4,0,8"
                                   Text="This is what gets written to serverconfig.xml. It updates as you change the options above."/>
                        <Border Background="{DynamicResource ConsoleBrush}"
                                BorderBrush="{DynamicResource Hud.Border}"
                                BorderThickness="1"
                                Padding="12,10">
                            <TextBox Text="{Binding SandboxCode, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"
                                     FontFamily="{DynamicResource Hud.Mono}"
                                     FontSize="11.5"
                                     Foreground="{DynamicResource Hud.Accent}"/>
                        </Border>

                        <Rectangle Fill="{DynamicResource Hud.DashRule}" Height="1" Margin="0,16,0,14"/>

                        <c:TrackedText Text="IMPORT A CODE" Style="{StaticResource Hud.StatCaption}"/>
                        <TextBlock Style="{StaticResource Hud.SettingHint}"
                                   TextWrapping="Wrap" Margin="0,4,0,8"
                                   Text="Built a config in the game? Paste its code here. It gets decoded into the controls above so you can see exactly what it contains — nothing is written until you Save."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource Hud.TextBox}"
                                     Text="{Binding ImportCode, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{DynamicResource Hud.Mono}"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource Hud.Button}"
                                    Command="{Binding ImportCommand}"
                                    IsEnabled="{Binding CanImport}"
                                    Height="34" Width="110" Margin="8,0,0,0">
                                <c:TrackedText Text="IMPORT" LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.Accent}"
                                               VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding ImportStatus}"
                                   TextWrapping="Wrap"
                                   FontFamily="{DynamicResource Hud.Mono}"
                                   FontSize="11"
                                   Margin="0,10,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Green}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImportFailed}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource Hud.Red}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Rectangle Fill="{DynamicResource Hud.DashRule}" Height="1" Margin="0,16,0,14"/>

                        <c:TrackedText Text="THEME PRESETS" Style="{StaticResource Hud.StatCaption}"/>
                        <TextBlock Style="{StaticResource Hud.SettingHint}"
                                   TextWrapping="Wrap" Margin="0,4,0,8"
                                   Text="The game's built-in scenario presets. Applying one replaces every gameplay option."/>
                        <ItemsControl ItemsSource="{Binding ThemePresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource Hud.Button.Ghost}"
                                            Height="28" MinWidth="140" Margin="0,0,8,8"
                                            Command="{Binding DataContext.ApplyPresetCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <c:TrackedText Text="{Binding Name}" LetterSpacing="0.08"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource Hud.FgMuted}"
                                                       VerticalAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </c:HudPanel>

            <!-- ══ SAVE ERROR ════════════════════════════════════════════════ -->
            <Border Background="{DynamicResource Hud.RedSoft}"
                    BorderBrush="{DynamicResource Hud.Red}"
                    BorderThickness="1"
                    Padding="12,9" Margin="0,4,0,8"
                    Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SaveError}"
                           Style="{StaticResource Hud.Mono.Text}"
                           FontSize="11"
                           Foreground="{DynamicResource Hud.Red}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ══ SAVED ═════════════════════════════════════════════════════ -->
            <Border Background="{DynamicResource Hud.GreenSoft}"
                    BorderBrush="{DynamicResource Hud.Green}"
                    BorderThickness="1"
                    Padding="12,9" Margin="0,4,0,8"
                    Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <c:HudIcon Kind="CheckCircle" Width="15" Height="15"
                               Foreground="{DynamicResource Hud.Green}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Saved — SandboxCode written to serverconfig.xml. Restart the server to apply."
                               Style="{StaticResource Hud.Mono.Text}"
                               FontSize="11"
                               Foreground="{DynamicResource Hud.Green}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ══ SAVE BAR ══════════════════════════════════════════════════ -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Hud.Body}"
                           TextWrapping="Wrap"
                           Text="Changes are written to serverconfig.xml — restart the server to apply."/>
                <Button Grid.Column="1"
                        Style="{StaticResource Hud.Button.Primary}"
                        Command="{Binding RequestSaveCommand}"
                        Width="150" Height="32">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="ContentSave" Width="13" Height="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="SAVE CHANGES" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.AccentInk}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>

    <!-- Confirmation overlay — shows the exact code before it's written -->
    <Grid Panel.ZIndex="100"
          Visibility="{Binding ConfirmPending, Converter={StaticResource BoolToVis}}"
          Background="#CC000000">
        <c:HudPanel Tint="Amber" Padding="0" Width="460"
                    Background="{DynamicResource Hud.BgElevated}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <Grid Height="56">
                    <Rectangle Fill="{DynamicResource Hud.Surface2}"/>
                    <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.35"/>
                    <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <c:HudIcon Kind="ContentSave" Width="18" Height="18"
                                   Foreground="{DynamicResource Hud.Amber}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <c:TrackedText Text="SAVE GAME SETTINGS"
                                       Style="{StaticResource Hud.PanelHeader}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="24,20,24,22">
                    <TextBlock Text="Write this Sandbox Code to serverconfig.xml?"
                               Style="{StaticResource Hud.Body}"
                               FontSize="13" Foreground="{DynamicResource Hud.Fg}"
                               Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource ConsoleBrush}"
                            BorderBrush="{DynamicResource Hud.Border}"
                            BorderThickness="1"
                            Padding="10,8" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SandboxCode}"
                                   FontFamily="{DynamicResource Hud.Mono}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Hud.Accent}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="The server must be restarted before changes take effect."
                               Style="{StaticResource Hud.Body}" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL"
                                Style="{StaticResource Hud.Button.Ghost}"
                                Command="{Binding CancelSaveCommand}"
                                Margin="0,0,10,0" Width="100"/>
                        <Button Style="{StaticResource Hud.Button.Primary}"
                                Command="{Binding ConfirmSaveCommand}"
                                Width="100">
                            <c:TrackedText Text="SAVE" LetterSpacing="0.12"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.AccentInk}"
                                           VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </c:HudPanel>
    </Grid>

    </Grid>
</UserControl>
