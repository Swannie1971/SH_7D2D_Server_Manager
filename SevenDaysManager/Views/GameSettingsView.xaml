<UserControl x:Class="SevenDaysManager.Views.GameSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:SevenDaysManager.Controls"
             xmlns:conv="clr-namespace:SevenDaysManager.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:SeverityToBrushConverter x:Key="SeverityToBrush"/>

        <!-- One sandbox option = label + dropdown. The dropdown's items come from the game's
             own list of allowed values for that option, so the UI structurally cannot produce
             a value the game would reject. -->
        <DataTemplate x:Key="SandboxOptionTemplate">
            <StackPanel Margin="0,0,10,12">
                <c:TrackedText Text="{Binding Display}" Style="{StaticResource Hud.SettingLabel}"/>
                <ComboBox Style="{StaticResource Hud.ComboBox}"
                          ItemsSource="{Binding Choices}"
                          SelectedItem="{Binding Selected}"
                          Margin="0,4,0,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="12"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="TwoColumn">
            <UniformGrid Columns="2"/>
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="14,14,14,16">

            <c:HudTitle Title="GAME SETTINGS" HorizontalAlignment="Left" Margin="2,0,0,10"/>

            <!-- ══ V3 NOTICE ══════════════════════════════════════════════════
                 Amber, not blue: this isn't trivia. Anyone upgrading from an older
                 build had their difficulty/loot/zombie settings silently doing
                 nothing, so it needs to read as a warning.

                 ⚠ Grid, not a horizontal StackPanel. A StackPanel measures its
                 children against INFINITE width, so TextWrapping never engages and
                 the text runs off the edge. The star column is what gives the
                 TextBlock a real width to wrap into. -->
            <Border Background="{DynamicResource Hud.AmberSoft}"
                    BorderBrush="{DynamicResource Hud.Amber}"
                    BorderThickness="1"
                    Padding="14,11" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <c:HudIcon Grid.Column="0"
                               Kind="AlertOctagon" Width="17" Height="17"
                               Foreground="{DynamicResource Hud.Amber}"
                               VerticalAlignment="Top" Margin="0,1,11,0"/>

                    <StackPanel Grid.Column="1">
                        <c:TrackedText Text="V3.0 — GAMEPLAY MOVED TO SANDBOX CODE"
                                       Style="{StaticResource Hud.StatCaption}"
                                       Foreground="{DynamicResource Hud.Amber}"/>
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Hud.Fg}"
                                   Text="Dead Hot Summer removed the individual gameplay properties from serverconfig.xml — difficulty, XP, zombie speeds, blood moon and loot are now packed into a single Sandbox Code. Older builds of this app kept writing the old properties, which the game silently ignores."/>
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Text="The controls below build that code for you. Every choice comes from the game's own list of allowed values, so what gets written is always valid."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ DIFFICULTY ════════════════════════════════════════════════
                 HudPanel's default Padding is 0, and its header carries its own inset. The
                 panels below get theirs from the Expander's Margin="16,...", so this one needs
                 a matching 16 or its content sits flush against the border while everything
                 else is indented. -->
            <c:HudPanel Header="DIFFICULTY" Tint="Rust" Margin="0,0,0,8" Padding="18,0,18,14">
                <StackPanel>

                    <!-- Badge on the left, live code readout on the right. -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    <!-- ── Active profile badge ──────────────────────────────────
                         Reads the preset's name while the settings match it exactly, and flips
                         to CUSTOM the moment ANY option diverges — including one the preset
                         never touched. Bump the air drops on Scavenger and it is no longer
                         Scavenger, so the badge must say so. -->
                    <Border Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            BorderThickness="1"
                            Padding="10,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"  Value="{DynamicResource Hud.GreenSoft}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Hud.Green}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustom}" Value="True">
                                        <Setter Property="Background"  Value="{DynamicResource Hud.AmberSoft}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource Hud.Amber}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel Orientation="Horizontal">
                            <c:TrackedText Text="PROFILE" LetterSpacing="0.2"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="8.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.FgMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                            <c:TrackedText Text="{Binding ProfileLabel}" LetterSpacing="0.14"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10.5" FontWeight="Bold"
                                           VerticalAlignment="Center">
                                <c:TrackedText.Style>
                                    <Style TargetType="c:TrackedText">
                                        <Setter Property="Foreground" Value="{DynamicResource Hud.Green}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCustom}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Hud.Amber}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </c:TrackedText.Style>
                            </c:TrackedText>
                        </StackPanel>
                    </Border>

                    <!-- ── Live sandbox code ─────────────────────────────────────
                         The exact string that gets written to serverconfig.xml, updating as
                         the dropdowns change. Read-only, but selectable and copyable — it's a
                         readout, not an input, so there's no way to type a broken code in.
                         A TextBox (not a TextBlock) purely so the text can be selected. -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource ConsoleBrush}"
                            BorderBrush="{DynamicResource Hud.Border}"
                            BorderThickness="1"
                            Margin="16,0,0,0"
                            Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <c:TrackedText Grid.Column="0"
                                           Text="CODE" LetterSpacing="0.2"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="8.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.FgMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding SandboxCode, Mode=OneWay}"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     VerticalAlignment="Center"
                                     TextWrapping="Wrap"
                                     FontFamily="{DynamicResource Hud.Mono}"
                                     FontSize="11"
                                     Foreground="{DynamicResource Hud.Accent}"/>

                            <Button Grid.Column="2"
                                    Style="{StaticResource Hud.Button.Icon}"
                                    Width="26" Height="26"
                                    Margin="8,0,0,0"
                                    ToolTip="Copy the sandbox code"
                                    Command="{Binding CopyCodeCommand}">
                                <c:HudIcon Kind="ContentCopy" Width="13" Height="13"
                                           Foreground="{DynamicResource Hud.FgMuted}"/>
                            </Button>
                        </Grid>
                    </Border>
                    </Grid>

                    <!-- Hud.Body, not Hud.SettingHint: this is explanatory copy, not a sub-label.
                         SettingHint is FgFaint (#4D545B), the palette's "disabled/timestamp"
                         grey — unreadable for a paragraph, especially over the background image. -->
                    <TextBlock Style="{StaticResource Hud.Body}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Text="In V3.0 difficulty is a preset over the damage multipliers — there is no longer a difficulty setting of its own. Applying one replaces every gameplay option below, but you can then tweak anything you like — the profile just becomes Custom."/>
                    <!-- Buttons run green -> red across the difficulty ramp, so the scale reads
                         at a glance. The colour comes from the game's own difficulty rank
                         (Severity), not from list position. -->
                    <ItemsControl ItemsSource="{Binding DifficultyPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,8,8">
                                    <Button Height="32" MinWidth="140"
                                            BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                            Command="{Binding DataContext.ApplyPresetCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Hud.Button}">
                                                <!-- Unselected: faint wash, coloured text. -->
                                                <Setter Property="Background"
                                                        Value="{Binding Severity, Converter={StaticResource SeverityToBrush},
                                                                        ConverterParameter=fill}"/>
                                                <Style.Triggers>
                                                    <!-- Selected: filled with its own colour, dark ink on top —
                                                         unmistakable which preset is loaded. -->
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{Binding Severity, Converter={StaticResource SeverityToBrush},
                                                                                ConverterParameter=solid}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>

                                        <c:TrackedText Text="{Binding Name}" LetterSpacing="0.1"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10.5" FontWeight="Bold"
                                                       VerticalAlignment="Center">
                                            <c:TrackedText.Style>
                                                <Style TargetType="c:TrackedText">
                                                    <!-- Idle: the preset's own ramp colour on a faint wash. -->
                                                    <Setter Property="Foreground"
                                                            Value="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                                    <Style.Triggers>
                                                        <!-- Selected: near-black ink, because the button is filled
                                                             solid with the ramp colour. -->
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground"
                                                                    Value="{Binding Severity, Converter={StaticResource SeverityToBrush},
                                                                                    ConverterParameter=ink}"/>
                                                        </DataTrigger>

                                                        <!-- Hover MUST come last so it beats the IsActive setter.
                                                             Hud.Button's template swaps the background to the dark
                                                             SurfaceHover on mouse-over, and it does so from inside
                                                             the ControlTemplate — which outranks anything we set
                                                             here. So on the selected button the fill went dark while
                                                             the ink stayed near-black: black on black, unreadable.
                                                             Going light on hover keeps the label legible in both
                                                             states. -->
                                                        <DataTrigger Value="True"
                                                                     Binding="{Binding IsMouseOver,
                                                                               RelativeSource={RelativeSource AncestorType=Button}}">
                                                            <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </c:TrackedText.Style>
                                        </c:TrackedText>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </c:HudPanel>

            <!-- ══ GENERAL ═══════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Red" Margin="0,0,0,8" Padding="0">
                <Expander Header="GENERAL &amp; PROGRESSION" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding GeneralOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ ENTITIES (zombies & animals) ═════════════════════════════ -->
            <c:HudPanel Tint="Green" Margin="0,0,0,8" Padding="0">
                <Expander Header="ENTITIES — ZOMBIES &amp; ANIMALS" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding EntitiesOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ WORLD (blood moon, air drops, time, screen) ══════════════ -->
            <c:HudPanel Tint="Rust" Margin="0,0,0,8" Padding="0">
                <Expander Header="WORLD — BLOOD MOON, TIME &amp; EVENTS" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding WorldOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ RESOURCES (loot, farming, mining) ════════════════════════ -->
            <c:HudPanel Tint="Amber" Margin="0,0,0,8" Padding="0">
                <Expander Header="RESOURCES — LOOT, FARMING &amp; MINING" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding ResourcesOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ CRAFTING ══════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Blue" Margin="0,0,0,8" Padding="0">
                <Expander Header="CRAFTING" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding CraftingOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ TRADERS ═══════════════════════════════════════════════════ -->
            <c:HudPanel Tint="Green" Margin="0,0,0,8" Padding="0">
                <Expander Header="TRADERS &amp; VENDING" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding TradersOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ TASKS (quests & challenges) ═══════════════════════════════ -->
            <c:HudPanel Tint="Amber" Margin="0,0,0,8" Padding="0">
                <Expander Header="TASKS — QUESTS &amp; CHALLENGES" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding TasksOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ MISC (vehicles & silly options) ══════════════════════════ -->
            <c:HudPanel Tint="Rust" Margin="0,0,0,8" Padding="0">
                <Expander Header="MISC — VEHICLES &amp; FUN OPTIONS" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <ItemsControl Margin="16,4,16,8"
                                  ItemsSource="{Binding MiscOptions}"
                                  ItemTemplate="{StaticResource SandboxOptionTemplate}"
                                  ItemsPanel="{StaticResource TwoColumn}"/>
                </Expander>
            </c:HudPanel>

            <!-- ══ SERVER — still plain XML properties in V3 ═════════════════ -->
            <c:HudPanel Tint="Violet" Margin="0,0,0,8" Padding="0">
                <Expander Header="SERVER &amp; PERFORMANCE" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <StackPanel Margin="16,4,16,12">
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="These are still individual serverconfig.xml properties — they were never part of the sandbox system."/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="PvP Mode" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding PlayerKillingOptions}"
                                          SelectedValue="{Binding PlayerKillingMode}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Max Spawned Zombies" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding MaxZombieOptions}"
                                          SelectedValue="{Binding MaxSpawnedZombies}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Max Spawned Animals" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding MaxAnimalOptions}"
                                          SelectedValue="{Binding MaxSpawnedAnimals}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="View Distance" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding ViewDistanceOptions}"
                                          SelectedValue="{Binding ServerMaxAllowedViewDistance}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Land Claim Size" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding LandClaimSizeOptions}"
                                          SelectedValue="{Binding LandClaimSize}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Land Claim Expiry" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding LandClaimExpiryOptions}"
                                          SelectedValue="{Binding LandClaimExpiryTime}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="Offline Claim Durability" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding LandClaimOfflineOptions}"
                                          SelectedValue="{Binding LandClaimOfflineDurabilityModifier}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="New Player Safe Level" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding SafeZoneLevelOptions}"
                                          SelectedValue="{Binding PlayerSafeZoneLevel}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,12">
                                <c:TrackedText Text="New Player Safe Hours" Style="{StaticResource Hud.SettingLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}" Margin="0,4,0,0"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding SafeZoneHoursOptions}"
                                          SelectedValue="{Binding PlayerSafeZoneHours}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Expander>
            </c:HudPanel>

            <!-- ══ SANDBOX CODE ══════════════════════════════════════════════ -->
            <c:HudPanel Tint="Accent" Margin="0,0,0,8" Padding="0">
                <Expander Header="SANDBOX CODE" IsExpanded="False" Style="{StaticResource Hud.Expander}">
                    <StackPanel Margin="16,4,16,14">

                        <!-- The generated code itself lives in the always-visible readout at the
                             top of the page, so it isn't repeated here. This panel is just
                             import + the themed presets. -->
                        <c:TrackedText Text="IMPORT A CODE" Style="{StaticResource Hud.StatCaption}"/>
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   TextWrapping="Wrap" Margin="0,4,0,8"
                                   Text="Built a config in the game? Paste its code here. It gets decoded into the controls above so you can see exactly what it contains — nothing is written until you Save."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource Hud.TextBox}"
                                     Text="{Binding ImportCode, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{DynamicResource Hud.Mono}"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource Hud.Button}"
                                    Command="{Binding ImportCommand}"
                                    IsEnabled="{Binding CanImport}"
                                    Height="34" Width="110" Margin="8,0,0,0">
                                <c:TrackedText Text="IMPORT" LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.Accent}"
                                               VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding ImportStatus}"
                                   TextWrapping="Wrap"
                                   FontFamily="{DynamicResource Hud.Mono}"
                                   FontSize="11"
                                   Margin="0,10,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Green}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImportFailed}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource Hud.Red}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Rectangle Fill="{DynamicResource Hud.DashRule}" Height="1" Margin="0,16,0,14"/>

                        <c:TrackedText Text="THEME PRESETS" Style="{StaticResource Hud.StatCaption}"/>
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   TextWrapping="Wrap" Margin="0,4,0,8"
                                   Text="The game's built-in scenario presets. Applying one replaces every gameplay option."/>
                        <ItemsControl ItemsSource="{Binding ThemePresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource Hud.Button.Ghost}"
                                            Height="28" MinWidth="140" Margin="0,0,8,8"
                                            Command="{Binding DataContext.ApplyPresetCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <c:TrackedText Text="{Binding Name}" LetterSpacing="0.08"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource Hud.FgMuted}"
                                                       VerticalAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </c:HudPanel>

            <!-- ══ SAVE ERROR ════════════════════════════════════════════════ -->
            <Border Background="{DynamicResource Hud.RedSoft}"
                    BorderBrush="{DynamicResource Hud.Red}"
                    BorderThickness="1"
                    Padding="12,9" Margin="0,4,0,8"
                    Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SaveError}"
                           Style="{StaticResource Hud.Mono.Text}"
                           FontSize="11"
                           Foreground="{DynamicResource Hud.Red}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ══ SAVED ═════════════════════════════════════════════════════ -->
            <Border Background="{DynamicResource Hud.GreenSoft}"
                    BorderBrush="{DynamicResource Hud.Green}"
                    BorderThickness="1"
                    Padding="12,9" Margin="0,4,0,8"
                    Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <c:HudIcon Kind="CheckCircle" Width="15" Height="15"
                               Foreground="{DynamicResource Hud.Green}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Saved — SandboxCode written to serverconfig.xml. Restart the server to apply."
                               Style="{StaticResource Hud.Mono.Text}"
                               FontSize="11"
                               Foreground="{DynamicResource Hud.Green}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ══ SAVE BAR ══════════════════════════════════════════════════ -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Hud.Body}"
                           TextWrapping="Wrap"
                           Text="Changes are written to serverconfig.xml — restart the server to apply."/>
                <Button Grid.Column="1"
                        Style="{StaticResource Hud.Button.Primary}"
                        Command="{Binding RequestSaveCommand}"
                        Width="150" Height="32">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="ContentSave" Width="13" Height="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="SAVE CHANGES" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.AccentInk}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>

    <!-- Confirmation overlay — shows the exact code before it's written -->
    <Grid Panel.ZIndex="100"
          Visibility="{Binding ConfirmPending, Converter={StaticResource BoolToVis}}"
          Background="#CC000000">
        <c:HudPanel Tint="Amber" Padding="0" Width="460"
                    Background="{DynamicResource Hud.BgElevated}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <Grid Height="56">
                    <Rectangle Fill="{DynamicResource Hud.Surface2}"/>
                    <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.35"/>
                    <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <c:HudIcon Kind="ContentSave" Width="18" Height="18"
                                   Foreground="{DynamicResource Hud.Amber}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <c:TrackedText Text="SAVE GAME SETTINGS"
                                       Style="{StaticResource Hud.PanelHeader}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="24,20,24,22">
                    <TextBlock Text="Write this Sandbox Code to serverconfig.xml?"
                               Style="{StaticResource Hud.Body}"
                               FontSize="13" Foreground="{DynamicResource Hud.Fg}"
                               Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource ConsoleBrush}"
                            BorderBrush="{DynamicResource Hud.Border}"
                            BorderThickness="1"
                            Padding="10,8" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SandboxCode}"
                                   FontFamily="{DynamicResource Hud.Mono}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Hud.Accent}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="The server must be restarted before changes take effect."
                               Style="{StaticResource Hud.Body}" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL"
                                Style="{StaticResource Hud.Button.Ghost}"
                                Command="{Binding CancelSaveCommand}"
                                Margin="0,0,10,0" Width="100"/>
                        <Button Style="{StaticResource Hud.Button.Primary}"
                                Command="{Binding ConfirmSaveCommand}"
                                Width="100">
                            <c:TrackedText Text="SAVE" LetterSpacing="0.12"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.AccentInk}"
                                           VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </c:HudPanel>
    </Grid>

    </Grid>
</UserControl>
