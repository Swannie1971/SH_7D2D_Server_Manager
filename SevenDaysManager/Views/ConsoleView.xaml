<UserControl x:Class="SevenDaysManager.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:SevenDaysManager.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Output -->
        <Border Grid.Row="0" Background="#CC0D0D0D">
            <ScrollViewer x:Name="OutputScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Lines}" Padding="10,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ConsoleLine}">
                            <TextBlock Text="{Binding Text}"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"
                                       Padding="0,1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:ConsoleLineType.Error}">
                                                <Setter Property="Foreground" Value="#EF5350"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:ConsoleLineType.Warning}">
                                                <Setter Property="Foreground" Value="#FFB300"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:ConsoleLineType.Chat}">
                                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:ConsoleLineType.System}">
                                                <Setter Property="Foreground" Value="#666666"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input bar -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="10,7"
                BorderThickness="0,1,0,0" BorderBrush="#333333">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text=">" FontFamily="Consolas" FontSize="14"
                           Foreground="#4CAF50" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="CommandBox" Grid.Column="1"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas, Courier New" FontSize="12"
                         Foreground="#E0E0E0" Background="Transparent" BorderThickness="0"
                         CaretBrush="#4CAF50" VerticalAlignment="Center"
                         materialDesign:HintAssist.Hint="Enter command…"
                         materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
                         Style="{StaticResource MaterialDesignTextBox}"
                         KeyDown="CommandBox_KeyDown"/>
                <Button Grid.Column="2" Content="Send"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Height="32" Padding="14,0" Margin="8,0,0,0"
                        Command="{Binding SendCommandCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
