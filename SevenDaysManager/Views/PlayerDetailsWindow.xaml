<Window x:Class="SevenDaysManager.Views.PlayerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Player Details"
        Width="640" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Grid.Column="0" Kind="AccountDetails" Width="28" Height="28"
                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    <TextBlock Text="Player details" FontSize="12" Opacity="0.8"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                        Width="34" Height="34" VerticalAlignment="Top"
                        Click="Close_Click" ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Body: info grid + admin actions -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,18">
            <StackPanel>
                <UniformGrid x:Name="InfoGrid" Columns="2"/>

                <TextBlock Text="ADMIN" FontSize="11" FontWeight="Bold"
                           Opacity="0.5" Margin="4,18,0,8"/>
                <materialDesign:Card UniformCornerRadius="0" Padding="16" Background="#14FFFFFF">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Admin Level" FontWeight="SemiBold"/>
                                <TextBlock Text="0 = full admin/owner. Higher numbers = narrower permissions."
                                           FontSize="11" Opacity="0.55" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBox x:Name="AdminLevelBox" Grid.Column="1"
                                     Text="0" Width="70"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     HorizontalContentAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button x:Name="RevokeAdminButton" Content="Revoke Admin"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Width="130" Margin="0,0,10,0"
                                    Click="RevokeAdmin_Click"/>
                            <Button x:Name="GrantAdminButton" Content="Grant Admin"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Width="130"
                                    Click="GrantAdmin_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="AdminStatusText" FontSize="11" Opacity="0.7"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="20,12" Background="#14FFFFFF">
            <Button Content="Close" HorizontalAlignment="Right"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="110" Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
