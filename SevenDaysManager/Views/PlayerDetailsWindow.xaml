<Window x:Class="SevenDaysManager.Views.PlayerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        Title="Player Details"
        Width="660" Height="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontSize="14">

    <Window.Resources>
        <!-- Applied from code-behind by AddCell(). Every value here is telemetry
             (IDs, ping, coords, counts), so it's mono for tabular alignment. -->
        <Style x:Key="InfoLabel" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.Rust}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource Hud.Fg}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Hud.Bg}"
            BorderBrush="{DynamicResource Hud.BorderStrong}"
            BorderThickness="1">
        <Grid>
            <c:HudAtmosphere Panel.ZIndex="0"/>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ══ Header ══ -->
                <Grid Grid.Row="0" Height="64"
                      Background="Transparent"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Rectangle Fill="{DynamicResource Hud.BgElevated}"/>
                    <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.3"/>
                    <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <c:HudIcon Grid.Column="0" Kind="AccountDetails"
                                                 Width="19" Height="19"
                                                 Foreground="{DynamicResource Hud.Accent}"
                                                 VerticalAlignment="Center" Margin="0,0,11,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <c:TrackedText Text="PLAYER DETAILS"
                                           Style="{StaticResource Hud.PanelHeader}"
                                           FontSize="12.5"/>
                            <!-- Player name, set in code-behind -->
                            <TextBlock x:Name="TitleText"
                                       Style="{StaticResource Hud.Mono.Text}"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource Hud.Rust}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Style="{StaticResource Hud.Button.Icon}"
                                Width="28" Height="28" VerticalAlignment="Center"
                                Click="Close_Click" ToolTip="Close">
                            <c:HudIcon Kind="Close" Width="15" Height="15"
                                                     Foreground="{DynamicResource Hud.FgMuted}"/>
                        </Button>
                    </Grid>
                </Grid>

                <!-- ══ Body ══ -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,16,16,4">
                    <StackPanel>

                        <c:HudPanel Header="TELEMETRY" Tint="Blue" Margin="0,0,0,14">
                            <!-- Cells are added from code-behind -->
                            <UniformGrid x:Name="InfoGrid" Columns="2"/>
                        </c:HudPanel>

                        <c:HudPanel Header="ADMIN" Tint="Amber">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                                        <c:TrackedText Text="ADMIN LEVEL" Style="{StaticResource Hud.SettingLabel}"/>
                                        <TextBlock Text="0 = full admin/owner. Higher numbers = narrower permissions."
                                                   Style="{StaticResource Hud.SettingHint}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBox x:Name="AdminLevelBox" Grid.Column="1"
                                             Text="0" Width="70"
                                             Style="{StaticResource Hud.TextBox}"
                                             HorizontalContentAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button x:Name="RevokeAdminButton"
                                            Style="{StaticResource Hud.Button}"
                                            BorderBrush="{DynamicResource Hud.Red}"
                                            Width="140" Height="30" Margin="0,0,8,0"
                                            Click="RevokeAdmin_Click">
                                        <c:TrackedText Text="REVOKE ADMIN" LetterSpacing="0.12"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10.5" FontWeight="Bold"
                                                       Foreground="{DynamicResource Hud.Red}"
                                                       VerticalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="GrantAdminButton"
                                            Style="{StaticResource Hud.Button.Primary}"
                                            Width="140" Height="30"
                                            Click="GrantAdmin_Click">
                                        <c:TrackedText Text="GRANT ADMIN" LetterSpacing="0.12"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10.5" FontWeight="Bold"
                                                       Foreground="{DynamicResource Hud.AccentInk}"
                                                       VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>

                                <!-- Result of the last admin command; colour set in code-behind -->
                                <TextBlock x:Name="AdminStatusText"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Hud.FgSubtle}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </c:HudPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ Footer ══ -->
                <Border Grid.Row="2"
                        Background="{DynamicResource Hud.BgElevated}"
                        BorderBrush="{DynamicResource Hud.Border}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <Button Style="{StaticResource Hud.Button.Ghost}"
                            HorizontalAlignment="Right"
                            Width="110" Height="30"
                            Click="Close_Click">
                        <c:TrackedText Text="CLOSE" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.FgMuted}"
                                       VerticalAlignment="Center"/>
                    </Button>
                </Border>
            </Grid>

            <c:HudBrackets Panel.ZIndex="2" Tint="Accent"/>
        </Grid>
    </Border>
</Window>
