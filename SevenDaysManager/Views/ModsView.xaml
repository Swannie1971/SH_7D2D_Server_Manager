<UserControl x:Class="SevenDaysManager.Views.ModsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:SevenDaysManager.Models">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="PuzzlePlus" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Mod Management" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <!-- Counts -->
                    <Border Background="#33000000" CornerRadius="8" Padding="12,3" Margin="16,0,0,0"
                            Visibility="{Binding TotalCount, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="{Binding EnabledCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                            <Run Text=" enabled"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding OpenModsFolderCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                            ToolTip="Open Mods folder in Explorer">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Open Folder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LoadCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                            ToolTip="Refresh mod list">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                    </Button>
                    <!-- Sort toggle -->
                    <ToggleButton IsChecked="{Binding SortAscending}"
                                  Style="{StaticResource MaterialDesignOutlinedButton}"
                                  Height="30" Padding="14,0" Margin="0,0,8,0"
                                  ToolTip="Toggle sort order">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="SortAlphabeticalAscending"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortAscending}" Value="False">
                                                <Setter Property="Kind" Value="SortAlphabeticalDescending"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="A → Z"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SortAscending}" Value="False">
                                                <Setter Property="Text" Value="Z → A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                    <Button Command="{Binding InstallFromZipCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="30" Padding="14,0" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageDown" Width="14" Height="14"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Install from Zip" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Body ══ -->
        <Grid Grid.Row="1">
            <!-- Busy overlay -->
            <Border Background="#AA000000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="40" Height="40"/>
                    <TextBlock Text="{Binding StatusText}" Margin="0,12,0,0"
                               FontSize="13" HorizontalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding TotalCount, Converter={StaticResource BoolToVis}}">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TotalCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="PuzzleOutline" Width="64" Height="64"
                                         Opacity="0.2" HorizontalAlignment="Center"/>
                <TextBlock Text="No mods installed" FontSize="16" Opacity="0.4"
                           HorizontalAlignment="Center" Margin="0,12,0,6"/>
                <TextBlock Text="Click 'Install from Zip' or drop a mod folder into the Mods directory"
                           FontSize="12" Opacity="0.3" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Mod list -->
            <ScrollViewer Margin="16" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Mods}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ModInfo}">
                            <materialDesign:Card Margin="0,0,0,8" Padding="0"
                                                 Background="{DynamicResource GlassBrush}">
                                <Grid>
                                    <!-- Enabled/disabled colour stripe on left -->
                                    <Border Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Background" Value="#444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                        <Setter Property="Background" Value="#ED4245"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Grid Margin="16,12,12,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Mod info -->
                                        <StackPanel Grid.Column="0" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}" FontSize="14"
                                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <!-- Version badge -->
                                                <Border Background="#22FFFFFF" CornerRadius="4"
                                                        Padding="6,1" Margin="8,0,0,0"
                                                        Visibility="{Binding Version,
                                                            Converter={StaticResource BoolToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Version}" FontSize="10"
                                                               Opacity="0.7" FontFamily="Consolas"/>
                                                </Border>
                                                <!-- System mod badge -->
                                                <Border Background="#33ED4245" CornerRadius="4"
                                                        Padding="6,1" Margin="8,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Lock" Width="10" Height="10"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,4,0" Opacity="0.8"/>
                                                        <TextBlock Text="Game System" FontSize="10" Opacity="0.8"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- No ModInfo.xml warning -->
                                                <Border Background="#44FFA000" CornerRadius="4"
                                                        Padding="6,1" Margin="8,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasModInfo}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="No ModInfo.xml" FontSize="10" Opacity="0.8"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Author -->
                                            <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="by "/>
                                                <Run Text="{Binding Author, Mode=OneWay}"/>
                                            </TextBlock>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Opacity="0.6" TextWrapping="Wrap" MaxWidth="600">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <!-- Website link (hidden when no ModInfo.xml) -->
                                            <Button Command="{Binding DataContext.OpenWebsiteCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Open mod website"
                                                    Width="32" Height="32" Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource MaterialDesignIconButton}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <materialDesign:PackIcon Kind="Web" Width="16" Height="16"/>
                                            </Button>

                                            <!-- Enable/Disable toggle (locked for system mods) -->
                                            <ToggleButton
                                                IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                Command="{Binding DataContext.ToggleModCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,8,0"
                                                ToolTip="Enable / Disable mod">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton"
                                                           BasedOn="{StaticResource MaterialDesignSwitchToggleButton}">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>

                                            <!-- Delete (hidden for system mods) -->
                                            <Button Command="{Binding DataContext.DeleteModCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete mod"
                                                    Width="32" Height="32"
                                                    Foreground="#EF5350">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══ Status bar ══ -->
        <Border Grid.Row="2" Background="#1AFFFFFF" Padding="16,6"
                Visibility="{Binding StatusText, Converter={StaticResource BoolToVis}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7"/>
        </Border>

    </Grid>
</UserControl>
