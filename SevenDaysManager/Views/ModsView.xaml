<UserControl x:Class="SevenDaysManager.Views.ModsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:SevenDaysManager.Models"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Small square badge used for version / system / warning chips -->
        <Style x:Key="ModBadge" TargetType="Border">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,1"/>
            <Setter Property="Margin"          Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ModBadgeText" TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Title ══ -->
        <c:HudTitle Grid.Row="0" Title="MOD MANAGEMENT" HorizontalAlignment="Left" Margin="16,14,0,12"/>

        <!-- ══ Toolbar ══ -->
        <Grid Grid.Row="1" Margin="16,0,16,12">
            <!-- Enabled / total pill -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                    Background="{DynamicResource Hud.AccentSoft}"
                    BorderBrush="{DynamicResource Hud.Accent}" BorderThickness="1"
                    Padding="9,3">
                <TextBlock Style="{StaticResource Hud.Mono.Text}" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource Hud.Accent}">
                    <Run Text="{Binding EnabledCount, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding TotalCount, Mode=OneWay}"/><Run Text=" ENABLED"/>
                </TextBlock>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding OpenModsFolderCommand}"
                        Style="{StaticResource Hud.Button.Icon}"
                        ToolTip="Open Mods folder in Explorer" Margin="0,0,6,0">
                    <materialDesign:PackIcon Kind="FolderOpen" Width="15" Height="15"/>
                </Button>
                <Button Command="{Binding LoadCommand}"
                        Style="{StaticResource Hud.Button.Icon}"
                        ToolTip="Refresh mod list" Margin="0,0,6,0">
                    <materialDesign:PackIcon Kind="Refresh" Width="15" Height="15"/>
                </Button>

                <!-- Sort order -->
                <ToggleButton IsChecked="{Binding SortAscending}"
                              Style="{x:Null}"
                              ToolTip="Toggle sort order"
                              Margin="0,0,10,0"
                              Cursor="Hand">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd" Height="30" Padding="12,0"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource Hud.BorderStrong}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon x:Name="SortIcon"
                                                             Kind="SortAlphabeticalAscending"
                                                             Width="13" Height="13"
                                                             Foreground="{DynamicResource Hud.Rust}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <c:TrackedText x:Name="SortText" Text="A-Z" LetterSpacing="0.12"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="10.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource Hud.Fg}"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Hud.Accent}"/>
                                    <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource Hud.SurfaceHover}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="SortIcon" Property="Kind" Value="SortAlphabeticalDescending"/>
                                    <Setter TargetName="SortText" Property="Text" Value="Z-A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <Button Command="{Binding InstallFromZipCommand}"
                        Style="{StaticResource Hud.Button.Primary}"
                        Height="30" Padding="14,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageDown" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="INSTALL FROM ZIP" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.AccentInk}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Body ══ -->
        <Grid Grid.Row="2">

            <!-- Busy overlay -->
            <Border Background="#CC08080A" Panel.ZIndex="10"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="42" Height="42"
                                 Foreground="{DynamicResource Hud.Accent}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource Hud.Mono.Text}"
                               FontSize="11.5"
                               Foreground="{DynamicResource Hud.FgMuted}"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TotalCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="PuzzleOutline" Width="52" Height="52"
                                         Foreground="{DynamicResource Hud.FgFaint}"
                                         HorizontalAlignment="Center"/>
                <c:TrackedText Text="NO MODS INSTALLED"
                               Style="{StaticResource Hud.SectionLabel}"
                               Foreground="{DynamicResource Hud.FgFaint}"
                               HorizontalAlignment="Center" Margin="0,14,0,6"/>
                <TextBlock Text="Install from a zip, or drop a mod folder into the Mods directory."
                           Style="{StaticResource Hud.Body}"
                           Foreground="{DynamicResource Hud.FgFaint}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Mod list -->
            <ScrollViewer Margin="16,0,16,0" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding Mods}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ModInfo}">

                            <!-- Panel tint carries the mod's state: accent = enabled,
                                 neutral = disabled, red = locked game system mod. -->
                            <c:HudPanel Margin="0,0,0,8" Padding="0">
                                <c:HudPanel.Style>
                                    <Style TargetType="c:HudPanel" BasedOn="{StaticResource {x:Type c:HudPanel}}">
                                        <Setter Property="Tint" Value="Accent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Tint" Value="Neutral"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                <Setter Property="Tint" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </c:HudPanel.Style>

                                <Grid Margin="16,13,13,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Mod info -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource Hud.Mono.Text}"
                                                       FontSize="13" FontWeight="Bold"
                                                       VerticalAlignment="Center"/>

                                            <!-- Version -->
                                            <Border Background="{DynamicResource Hud.Surface2}"
                                                    BorderBrush="{DynamicResource Hud.Border}">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource ModBadge}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Version}"
                                                           Style="{StaticResource ModBadgeText}"
                                                           Foreground="{DynamicResource Hud.FgSubtle}"/>
                                            </Border>

                                            <!-- Locked game system mod -->
                                            <Border Background="{DynamicResource Hud.RedSoft}"
                                                    BorderBrush="{DynamicResource Hud.Red}">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource ModBadge}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Lock" Width="9" Height="9"
                                                                             Foreground="{DynamicResource Hud.Red}"
                                                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="GAME SYSTEM"
                                                               Style="{StaticResource ModBadgeText}"
                                                               Foreground="{DynamicResource Hud.Red}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- No ModInfo.xml -->
                                            <Border Background="{DynamicResource Hud.AmberSoft}"
                                                    BorderBrush="{DynamicResource Hud.Amber}">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource ModBadge}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasModInfo}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="NO MODINFO.XML"
                                                           Style="{StaticResource ModBadgeText}"
                                                           Foreground="{DynamicResource Hud.Amber}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Author -->
                                        <TextBlock Margin="0,0,0,5">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
                                                    <Setter Property="FontSize"   Value="10"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Rust}"/>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="BY "/><Run Text="{Binding Author, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- Description -->
                                        <TextBlock Text="{Binding Description}"
                                                   MaxWidth="620"
                                                   HorizontalAlignment="Left">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Body}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">

                                        <!-- Website (only when ModInfo.xml exists) -->
                                        <Button Command="{Binding DataContext.OpenWebsiteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Open mod website"
                                                Margin="0,0,6,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Hud.Button.Icon}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasModInfo}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <materialDesign:PackIcon Kind="Web" Width="14" Height="14"/>
                                        </Button>

                                        <!-- Enable / disable — locked for game system mods -->
                                        <ToggleButton IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                      Command="{Binding DataContext.ToggleModCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,8,0"
                                                      ToolTip="Enable / disable mod">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource Hud.Toggle}">
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="ToolTip"
                                                                    Value="Game system mod — cannot be disabled"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>

                                        <!-- Delete — hidden for game system mods -->
                                        <Button Command="{Binding DataContext.DeleteModCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Delete mod">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Hud.Button.Icon}">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Red}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="14" Height="14"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </c:HudPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══ Status bar ══ -->
        <Border Grid.Row="3" Margin="16,10,16,14"
                Background="{DynamicResource Hud.Surface2}"
                BorderBrush="{DynamicResource Hud.Border}" BorderThickness="1"
                Padding="12,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource Hud.Mono.Text}"
                       FontSize="11"
                       Foreground="{DynamicResource Hud.Accent}"
                       TextWrapping="Wrap"/>
        </Border>

    </Grid>
</UserControl>
