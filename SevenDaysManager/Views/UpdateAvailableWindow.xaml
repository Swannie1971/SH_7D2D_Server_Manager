<Window x:Class="SevenDaysManager.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Update Available"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <StackPanel>

        <!-- Header -->
        <Border Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Update" Width="28" Height="28"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="Update Available" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Opacity="0.8"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Margin="24,20,24,8">
            <TextBlock TextWrapping="Wrap" Opacity="0.85" LineHeight="22">
                A new version of 7D2D Server Manager is available. Click Update Now and the app will download, replace itself, and restart automatically.
            </TextBlock>

            <!-- Release notes snippet -->
            <Border x:Name="NotesPanel" Background="#1AFFFFFF" CornerRadius="6"
                    Padding="12,10" Margin="0,16,0,0"
                    Visibility="Collapsed">
                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NotesText" FontSize="12" Opacity="0.7"
                               TextWrapping="Wrap" FontFamily="Consolas"/>
                </ScrollViewer>
            </Border>

            <!-- Download progress (hidden until download starts) -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,16,0,0">
                <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                <TextBlock x:Name="StatusText" FontSize="12" Opacity="0.7"
                           Margin="0,6,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="24,12,24,24">
            <Button x:Name="NotNowButton" Content="Not Now"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="110" Margin="0,0,12,0"
                    Click="NotNow_Click"/>
            <Button x:Name="DownloadButton"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="160" Click="Download_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CloudDownload" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="DownloadButtonText" Text="Update Now" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </StackPanel>
</Window>
