<UserControl x:Class="SevenDaysManager.Views.DiscordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:SevenDaysManager.Views"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Title ══ -->
        <c:HudTitle Grid.Row="0" Title="DISCORD" HorizontalAlignment="Left" Margin="16,14,0,12"/>

        <!-- ══ Master switch + actions ══ -->
        <Grid Grid.Row="1" Margin="16,0,16,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton IsChecked="{Binding Enabled}"
                              Style="{StaticResource Hud.Toggle}"
                              VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
                            <Setter Property="FontSize"   Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Text"       Value="NOTIFICATIONS DISABLED"/>
                            <Setter Property="Foreground" Value="{DynamicResource Hud.FgFaint}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Enabled}" Value="True">
                                    <Setter Property="Text"       Value="NOTIFICATIONS ENABLED"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding TestDiscordCommand}"
                        Style="{StaticResource Hud.Button}"
                        IsEnabled="{Binding Enabled}"
                        Height="30" Padding="14,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="Send" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="SEND TEST" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.Fg}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource Hud.Button.Primary}"
                        Height="30" Padding="14,0">
                    <StackPanel Orientation="Horizontal">
                        <c:HudIcon Kind="ContentSave" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <c:TrackedText Text="SAVE" LetterSpacing="0.12"
                                       FontFamily="{DynamicResource Hud.Mono}"
                                       FontSize="10.5" FontWeight="Bold"
                                       Foreground="{DynamicResource Hud.AccentInk}"
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Body ══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="16,0,16,16" IsEnabled="{Binding Enabled}">

                <!-- Default webhook -->
                <c:TrackedText Text="DEFAULT WEBHOOK" Style="{StaticResource Hud.SectionLabel}"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <c:HudPanel Tint="Blue" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <c:TrackedText Text="WEBHOOK URL" Style="{StaticResource Hud.FieldLabel}"/>
                        <TextBox Text="{Binding DefaultWebhook, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Hud.TextBox}"
                                 FontSize="11"/>

                        <TextBlock Text="{Binding TestStatus, Mode=OneWay}"
                                   Style="{StaticResource Hud.Mono.Text}"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource Hud.Accent}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>

                        <TextBlock Style="{StaticResource Hud.Body}" Margin="0,10,0,0"
                                   Text="Each event below can override this with its own webhook. Leave an event's URL blank to use this default."/>
                        <TextBlock Style="{StaticResource Hud.Body}"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource Hud.FgFaint}"
                                   Margin="0,6,0,0"
                                   Text="Discord → Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL"/>
                    </StackPanel>
                </c:HudPanel>

                <!-- Events -->
                <c:TrackedText Text="EVENTS" Style="{StaticResource Hud.SectionLabel}"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <views:DiscordEventCard Grid.Column="0" Grid.Row="0" DataContext="{Binding EvtServerStart}"/>
                    <views:DiscordEventCard Grid.Column="2" Grid.Row="0" DataContext="{Binding EvtServerStop}"/>
                    <views:DiscordEventCard Grid.Column="0" Grid.Row="1" DataContext="{Binding EvtServerRestart}"/>
                    <views:DiscordEventCard Grid.Column="2" Grid.Row="1" DataContext="{Binding EvtServerCrash}"/>
                    <views:DiscordEventCard Grid.Column="0" Grid.Row="2" DataContext="{Binding EvtServerUpdated}"/>
                    <views:DiscordEventCard Grid.Column="2" Grid.Row="2" DataContext="{Binding EvtRestartWarn}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
