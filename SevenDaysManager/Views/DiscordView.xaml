<UserControl x:Class="SevenDaysManager.Views.DiscordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:SevenDaysManager.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="MessageBadge" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Discord Notifications" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <ToggleButton IsChecked="{Binding Enabled}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Margin="20,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12" Opacity="0.7">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disabled"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding TestDiscordCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                            IsEnabled="{Binding Enabled}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Send" Width="14" Height="14"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Send Test" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="30" Padding="14,0" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="14" Height="14"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Body ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16" IsEnabled="{Binding Enabled}">

                <!-- Default webhook -->
                <materialDesign:Card Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="DEFAULT WEBHOOK URL" FontSize="10" FontWeight="SemiBold"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding DefaultWebhook, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="https://discord.com/api/webhooks/..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="12" FontFamily="Consolas"/>
                        </Grid>
                        <TextBlock Text="{Binding TestStatus, Mode=OneWay}"
                                   FontSize="11" Margin="0,6,0,0" Opacity="0.7"/>
                        <TextBlock FontSize="10" Opacity="0.4" TextWrapping="Wrap" Margin="0,8,0,0">
                            Each event below can use its own webhook instead. Leave blank on an event to use this default.
                            Discord → Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Event cards — 2-column grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <views:DiscordEventCard Grid.Column="0" Grid.Row="0" DataContext="{Binding EvtServerStart}"/>
                    <views:DiscordEventCard Grid.Column="2" Grid.Row="0" DataContext="{Binding EvtServerStop}"/>
                    <views:DiscordEventCard Grid.Column="0" Grid.Row="1" DataContext="{Binding EvtServerRestart}"/>
                    <views:DiscordEventCard Grid.Column="2" Grid.Row="1" DataContext="{Binding EvtServerCrash}"/>
                    <views:DiscordEventCard Grid.Column="0" Grid.Row="2" DataContext="{Binding EvtServerUpdated}"/>
                    <views:DiscordEventCard Grid.Column="2" Grid.Row="2" DataContext="{Binding EvtRestartWarn}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
