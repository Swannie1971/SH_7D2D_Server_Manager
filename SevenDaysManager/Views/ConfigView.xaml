<UserControl x:Class="SevenDaysManager.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="16">

                <c:HudTitle Title="CONFIG" HorizontalAlignment="Left" Margin="2,0,0,16"/>

                <!-- ══ SERVER IDENTITY ══ -->
                <c:TrackedText Text="SERVER IDENTITY" Style="{StaticResource Hud.SectionLabel}"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <c:HudPanel Tint="Accent" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <c:TrackedText Text="SERVER NAME" Style="{StaticResource Hud.FieldLabel}"/>
                        <TextBox Style="{StaticResource Hud.TextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <c:TrackedText Text="DESCRIPTION" Style="{StaticResource Hud.FieldLabel}"/>
                        <TextBox Style="{StaticResource Hud.TextBox}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <c:TrackedText Text="WEBSITE URL" Style="{StaticResource Hud.FieldLabel}"/>
                        <TextBox Style="{StaticResource Hud.TextBox}"
                                 Text="{Binding WebsiteUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <c:TrackedText Text="JOIN PASSWORD" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <c:TrackedText Text="VISIBILITY" Style="{StaticResource Hud.FieldLabel}"/>
                                <!-- No DisplayMemberPath: Hud.ComboBox's default ItemTemplate
                                     renders the item's Label (or the item itself). -->
                                <ComboBox Style="{StaticResource Hud.ComboBox}"
                                          SelectedValuePath="Value"
                                          ItemsSource="{Binding VisibilityOptions}"
                                          SelectedValue="{Binding ServerVisibility}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </c:HudPanel>

                <!-- ══ WORLD ══ -->
                <c:TrackedText Text="WORLD" Style="{StaticResource Hud.SectionLabel}"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <c:HudPanel Tint="Violet" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <c:TrackedText Text="GAME WORLD" Style="{StaticResource Hud.FieldLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}"
                                          ItemsSource="{Binding GameWorldOptions}"
                                          SelectedItem="{Binding GameWorld}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <c:TrackedText Text="SAVE NAME" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Seed + size only apply to a random-gen world -->
                        <Grid Visibility="{Binding IsRwg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <c:TrackedText Text="WORLD SEED" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding WorldGenSeed, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <c:TrackedText Text="WORLD SIZE" Style="{StaticResource Hud.FieldLabel}"/>
                                <ComboBox Style="{StaticResource Hud.ComboBox}"
                                          ItemsSource="{Binding WorldGenSizeOptions}"
                                          SelectedItem="{Binding WorldGenSize}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </c:HudPanel>

                <!-- ══ NETWORK ══ -->
                <c:TrackedText Text="NETWORK" Style="{StaticResource Hud.SectionLabel}"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <c:HudPanel Tint="Blue" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <c:TrackedText Text="GAME PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <c:TrackedText Text="TELNET PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <c:TrackedText Text="WEB DASHBOARD PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding WebDashboardPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <c:TrackedText Text="MAX PLAYERS" Style="{StaticResource Hud.FieldLabel}"/>
                        <TextBox Style="{StaticResource Hud.TextBox}"
                                 Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </c:HudPanel>

                <!-- ══ OPTIONS ══ -->
                <c:TrackedText Text="OPTIONS" Style="{StaticResource Hud.SectionLabel}"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <c:HudPanel Tint="Amber" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <c:TrackedText Text="EAC — ANTI-CHEAT" Style="{StaticResource Hud.StatCaption}"
                                           HorizontalAlignment="Left"/>
                            <TextBlock Text="Easy Anti-Cheat protection."
                                       Style="{StaticResource Hud.Body}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource Hud.Toggle}"
                                      IsChecked="{Binding EacEnabled}" VerticalAlignment="Center"/>
                    </Grid>
                </c:HudPanel>

                <!-- Error -->
                <Border Background="{DynamicResource Hud.RedSoft}"
                        BorderBrush="{DynamicResource Hud.Red}" BorderThickness="1"
                        Padding="12,8" Margin="0,0,0,8"
                        Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SaveError}"
                               Style="{StaticResource Hud.Mono.Text}" FontSize="11"
                               Foreground="{DynamicResource Hud.Red}" TextWrapping="Wrap"/>
                </Border>

                <!-- Saved -->
                <Border Background="{DynamicResource Hud.GreenSoft}"
                        BorderBrush="{DynamicResource Hud.Green}" BorderThickness="1"
                        Padding="12,8" Margin="0,0,0,8"
                        Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="6" Height="6" Fill="{DynamicResource Hud.Green}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <c:TrackedText Text="SAVED — SERVERCONFIG.XML UPDATED"
                                       Style="{StaticResource Hud.PillText}"
                                       Foreground="{DynamicResource Hud.Green}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{DynamicResource Hud.BgElevated}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Hud.Border}"
                Padding="16,12">
            <Button Style="{StaticResource Hud.Button.Primary}"
                    HorizontalAlignment="Right"
                    Width="150" Height="32"
                    Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="13" Height="13"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <c:TrackedText Text="SAVE CONFIG" LetterSpacing="0.12"
                                   FontFamily="{DynamicResource Hud.Mono}"
                                   FontSize="10.5" FontWeight="Bold"
                                   Foreground="{DynamicResource Hud.AccentInk}"
                                   VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</UserControl>
