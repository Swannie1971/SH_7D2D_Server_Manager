<UserControl x:Class="SevenDaysManager.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">

                <TextBlock Text="SERVER IDENTITY" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBox materialDesign:HintAssist.Hint="Server Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>
                        <TextBox materialDesign:HintAssist.Hint="Description (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>
                        <TextBox materialDesign:HintAssist.Hint="Website URL (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WebsiteUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="Join Password (optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox Grid.Column="2"
                                      materialDesign:HintAssist.Hint="Visibility"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      DisplayMemberPath="Label" SelectedValuePath="Value"
                                      ItemsSource="{Binding VisibilityOptions}"
                                      SelectedValue="{Binding ServerVisibility}"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <TextBlock Text="WORLD" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox materialDesign:HintAssist.Hint="Game World"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding GameWorldOptions}"
                                      SelectedItem="{Binding GameWorld}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Save Name"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Visibility="{Binding IsRwg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="World Seed (optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding WorldGenSeed, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox Grid.Column="2" materialDesign:HintAssist.Hint="World Size"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding WorldGenSizeOptions}"
                                      SelectedItem="{Binding WorldGenSize}"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <TextBlock Text="NETWORK" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="Game Port"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Telnet Port"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="4" materialDesign:HintAssist.Hint="Web Dashboard Port"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding WebDashboardPort, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="Max Players"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </materialDesign:Card>

                <TextBlock Text="OPTIONS" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="EAC (Anti-Cheat)" FontWeight="SemiBold"/>
                            <TextBlock Text="Easy Anti-Cheat protection" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding EacEnabled}" VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Error -->
                <Border CornerRadius="6" Background="#33F44336" Padding="12,8" Margin="0,0,0,8"
                        Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SaveError}" Foreground="#F44336" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Saved -->
                <Border CornerRadius="6" Background="#334CAF50" Padding="12,8" Margin="0,0,0,8"
                        Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Saved — serverconfig.xml updated."
                                   Foreground="#4CAF50" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Padding="16,10">
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Content="Save Config" HorizontalAlignment="Right"
                    Width="130" Command="{Binding SaveCommand}"/>
        </Border>
    </Grid>
</UserControl>
