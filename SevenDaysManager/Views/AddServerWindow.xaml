<Window x:Class="SevenDaysManager.Views.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:SevenDaysManager.Converters"
        Title="Add New Server"
        Width="560" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
    </Window.Resources>

    <StackPanel>
        <!-- Header -->
        <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="Add New Server" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                <TextBlock Text="Configure a new 7 Days to Die dedicated server"
                           FontSize="11" Opacity="0.7"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20">

            <!-- ── Server Banner Image ──────────────────────────────────── -->
            <TextBlock Text="SERVER BANNER" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Margin="0,0,0,20" Height="160">
                <Grid>
                    <!-- Base always-visible background -->
                    <Image Source="pack://application:,,,/Assets/bg.jpg"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Chosen logo centered + respects transparency -->
                    <Image Source="{Binding LogoPath, Converter={StaticResource PathToImage}}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="12"/>
                    <!-- Choose button overlaid bottom-right -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="20"
                            Command="{Binding BrowseLogoCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,12,12" Height="36" Padding="14,0"
                            Background="#CC000000" BorderBrush="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImageEdit" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Choose Image" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- ── General ──────────────────────────────────────────────── -->
            <TextBlock Text="GENERAL" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Server Name"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── World ────────────────────────────────────────────────── -->
            <TextBlock Text="WORLD" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox materialDesign:HintAssist.Hint="Game World"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding GameWorldOptions}"
                                  SelectedItem="{Binding GameWorld}"/>
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Save Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- RWG-only fields -->
                    <Grid Visibility="{Binding IsRwg, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox materialDesign:HintAssist.Hint="World Seed (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WorldGenSeed, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="2"
                                  materialDesign:HintAssist.Hint="World Size"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding WorldGenSizeOptions}"
                                  SelectedItem="{Binding WorldGenSize}"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Network ──────────────────────────────────────────────── -->
            <TextBlock Text="NETWORK" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox materialDesign:HintAssist.Hint="Game Port"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Telnet Port"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="4"
                                 materialDesign:HintAssist.Hint="Web Dashboard Port"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WebDashboardPort, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox materialDesign:HintAssist.Hint="Max Players"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Join Password (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Options ──────────────────────────────────────────────── -->
            <TextBlock Text="OPTIONS" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="EAC (Anti-Cheat)" FontWeight="SemiBold"/>
                        <TextBlock Text="Easy Anti-Cheat protection" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  IsChecked="{Binding EacEnabled}"
                                  VerticalAlignment="Center"/>
                </Grid>
            </materialDesign:Card>

            <!-- ── Buttons ──────────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Content="Cancel" Width="100" Margin="0,0,8,0"
                        Click="CancelButton_Click"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="Add Server" Width="120"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
