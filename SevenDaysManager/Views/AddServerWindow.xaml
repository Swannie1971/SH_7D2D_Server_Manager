<Window x:Class="SevenDaysManager.Views.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:SevenDaysManager.Converters"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        Title="Add New Server"
        Width="600" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
    </Window.Resources>

    <Border Background="{DynamicResource Hud.Bg}"
            BorderBrush="{DynamicResource Hud.BorderStrong}"
            BorderThickness="1"
            VerticalAlignment="Top">
        <Grid VerticalAlignment="Top">
            <c:HudAtmosphere Panel.ZIndex="0"/>

            <StackPanel Panel.ZIndex="1" VerticalAlignment="Top">

                <!-- ══ Header ══ -->
                <Grid Height="64"
                      Background="Transparent"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Rectangle Fill="{DynamicResource Hud.BgElevated}"/>
                    <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.3"/>
                    <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <c:HudIcon Kind="ServerPlus" Width="19" Height="19"
                                                 Foreground="{DynamicResource Hud.Accent}"
                                                 VerticalAlignment="Center" Margin="0,0,11,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <c:TrackedText Text="ADD NEW SERVER"
                                           Style="{StaticResource Hud.PanelHeader}"
                                           FontSize="12.5"/>
                            <TextBlock Text="Configure a new 7 Days to Die dedicated server"
                                       Style="{StaticResource Hud.Mono.Text}"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource Hud.FgFaint}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="16,16,16,0">

                    <!-- ══ Banner ══ -->
                    <c:HudPanel Header="SERVER BANNER" Tint="Violet" Margin="0,0,0,14">
                        <Grid Height="150">
                            <Image Source="pack://application:,,,/Assets/bg.jpg"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <!-- Chosen logo, centred, transparency preserved -->
                            <Image Source="{Binding LogoPath, Converter={StaticResource PathToImage}}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="12"/>
                            <Rectangle Fill="{DynamicResource Hud.ScanlineTile}" IsHitTestVisible="False"/>

                            <Button Style="{StaticResource Hud.Button}"
                                    Command="{Binding BrowseLogoCommand}"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="0,0,10,10" Height="28" Padding="12,0"
                                    Background="#CC08080A">
                                <StackPanel Orientation="Horizontal">
                                    <c:HudIcon Kind="ImageEdit" Width="13" Height="13"
                                                             Foreground="{DynamicResource Hud.Accent}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <c:TrackedText Text="CHOOSE IMAGE" LetterSpacing="0.12"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="9.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource Hud.Fg}"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </c:HudPanel>

                    <!-- ══ General ══ -->
                    <c:HudPanel Header="GENERAL" Tint="Accent" Margin="0,0,0,14">
                        <StackPanel>
                            <c:TrackedText Text="SERVER NAME" Style="{StaticResource Hud.FieldLabel}"/>
                            <TextBox Style="{StaticResource Hud.TextBox}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Editable, not just displayed: this drives WHERE SteamCMD actually
                                 writes the server. It auto-fills from Name + the default install
                                 root while untouched, and stops following the moment the user
                                 types in it or clicks Browse (AddServerViewModel tracks this). -->
                            <c:TrackedText Text="INSTALL LOCATION" Style="{StaticResource Hud.FieldLabel}"
                                           Margin="0,12,0,0"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding InstallDir, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{DynamicResource Hud.Mono}"
                                         FontSize="12"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource Hud.Button}"
                                        Command="{Binding BrowseInstallDirCommand}"
                                        Margin="8,0,0,0" Height="30" Padding="12,0">
                                    <c:TrackedText Text="BROWSE" LetterSpacing="0.1"
                                                   FontFamily="{DynamicResource Hud.Mono}"
                                                   FontSize="10.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource Hud.Fg}"
                                                   VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Server files (~15 GB) will be installed here. Pick a drive with enough free space."
                                       Style="{StaticResource Hud.SettingHint}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </c:HudPanel>

                    <!-- ══ World ══ -->
                    <c:HudPanel Header="WORLD" Tint="Green" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <c:TrackedText Text="GAME WORLD" Style="{StaticResource Hud.FieldLabel}"/>
                                    <ComboBox Style="{StaticResource Hud.ComboBox}"
                                              ItemsSource="{Binding GameWorldOptions}"
                                              SelectedItem="{Binding GameWorld}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <c:TrackedText Text="SAVE NAME" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Seed + size only mean anything for a randomly generated world -->
                            <Grid Visibility="{Binding IsRwg, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <c:TrackedText Text="WORLD SEED (OPTIONAL)" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding WorldGenSeed, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <c:TrackedText Text="WORLD SIZE" Style="{StaticResource Hud.FieldLabel}"/>
                                    <ComboBox Style="{StaticResource Hud.ComboBox}"
                                              ItemsSource="{Binding WorldGenSizeOptions}"
                                              SelectedItem="{Binding WorldGenSize}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </c:HudPanel>

                    <!-- ══ Network ══ -->
                    <c:HudPanel Header="NETWORK" Tint="Blue" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <c:TrackedText Text="GAME PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <c:TrackedText Text="TELNET PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <c:TrackedText Text="WEB DASHBOARD" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding WebDashboardPort, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <c:TrackedText Text="MAX PLAYERS" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <c:TrackedText Text="JOIN PASSWORD (OPTIONAL)" Style="{StaticResource Hud.FieldLabel}"/>
                                    <TextBox Style="{StaticResource Hud.TextBox}"
                                             Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </c:HudPanel>

                    <!-- ══ Options ══ -->
                    <c:HudPanel Header="OPTIONS" Tint="Amber" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <c:TrackedText Text="EAC (ANTI-CHEAT)" Style="{StaticResource Hud.SettingLabel}"/>
                                <TextBlock Text="Easy Anti-Cheat protection"
                                           Style="{StaticResource Hud.SettingHint}"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource Hud.Toggle}"
                                          IsChecked="{Binding EacEnabled}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </c:HudPanel>
                </StackPanel>

                <!-- ══ Buttons ══ -->
                <Border Background="{DynamicResource Hud.BgElevated}"
                        BorderBrush="{DynamicResource Hud.Border}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Hud.Button.Ghost}"
                                Width="110" Height="30" Margin="0,0,8,0"
                                Click="CancelButton_Click">
                            <c:TrackedText Text="CANCEL" LetterSpacing="0.12"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.FgMuted}"
                                           VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource Hud.Button.Primary}"
                                Width="150" Height="30"
                                Click="SaveButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <c:HudIcon Kind="Plus" Width="13" Height="13"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <c:TrackedText Text="ADD SERVER" LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.AccentInk}"
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <c:HudBrackets Panel.ZIndex="2" Tint="Accent"/>
        </Grid>
    </Border>
</Window>
