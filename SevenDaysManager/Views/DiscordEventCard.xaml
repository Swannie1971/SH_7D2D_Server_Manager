<UserControl x:Class="SevenDaysManager.Views.DiscordEventCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SevenDaysManager.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <!-- Left accent bar colour-coded to the event's colour -->
    <Border Margin="0,0,0,10">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                <Setter Property="BorderBrush" Value="#57F287"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Color}" Value="red">
                        <Setter Property="BorderBrush" Value="#ED4245"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Color}" Value="orange">
                        <Setter Property="BorderBrush" Value="#FEA800"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Color}" Value="blue">
                        <Setter Property="BorderBrush" Value="#5865F2"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Color}" Value="yellow">
                        <Setter Property="BorderBrush" Value="#FEE75C"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Color}" Value="purple">
                        <Setter Property="BorderBrush" Value="#9B59B6"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Color}" Value="grey">
                        <Setter Property="BorderBrush" Value="#95A5A6"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel>
            <!-- Card header -->
            <Border Padding="14,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding EventName}" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ToggleButton IsChecked="{Binding Enabled}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Card body — only shown when enabled -->
            <StackPanel Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}"
                        Margin="14,0,14,14">

                <!-- Webhook URL override -->
                <TextBlock Text="WEBHOOK URL" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding WebhookOverride, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="(uses default webhook)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="12" FontFamily="Consolas" Margin="0,0,0,12"/>

                <!-- Message -->
                <TextBlock FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,4">
                    <Run Text="MESSAGE TEXT"/>
                    <Run Text=" — VARS: " Foreground="#888"/>
                    <Run Text="{Binding Variables, Mode=OneWay}" Foreground="#888"/>
                </TextBlock>
                <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="12" TextWrapping="Wrap" MinHeight="60"
                         AcceptsReturn="True" Margin="0,0,0,12"/>

                <!-- Color + Cooldown row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="COLOR" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{x:Static vm:DiscordEventViewModel.ColorOptions}"
                                  SelectedItem="{Binding Color}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="COOLDOWN (SEC)"/>
                            <Run Text=" — 0 = NONE" Foreground="#666"/>
                        </TextBlock>
                        <TextBox Text="{Binding CooldownSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="12" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Thumbnail URL + Role mention row -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="THUMBNAIL URL"/>
                            <Run Text=" (use {IMAGE} for server logo)" Foreground="#666" FontSize="9"/>
                        </TextBlock>
                        <TextBox Text="{Binding ThumbnailUrl, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="https://… or {IMAGE}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="11" FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="ROLE MENTION ID"/>
                            <Run Text=" (pings this role)" Foreground="#666" FontSize="9"/>
                        </TextBlock>
                        <TextBox Text="{Binding RoleMentionId, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="123456789012345678  (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="11" FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
