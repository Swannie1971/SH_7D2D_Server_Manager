<Window x:Class="SevenDaysManager.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:SevenDaysManager.ViewModels"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        Title="App Settings"
        Width="720" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Hud.Bg}"
        TextElement.Foreground="{DynamicResource Hud.Fg}"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:AppSettingsViewModel/>
    </Window.DataContext>

    <Grid>
        <c:HudAtmosphere Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: hazard-stripe background -->
            <Grid Grid.Row="0" Height="66">
                <Rectangle Fill="{DynamicResource Hud.BgElevated}"/>
                <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.35"/>
                <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                <StackPanel VerticalAlignment="Center" Margin="24,0">
                    <c:TrackedText Text="APP SETTINGS" Style="{StaticResource Hud.PageTitle}"/>
                    <c:TrackedText Text="GLOBAL PREFERENCES" Style="{StaticResource Hud.SectionLabel}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>

                    <!-- ══ APPEARANCE ══ -->
                    <c:TrackedText Text="APPEARANCE" Style="{StaticResource Hud.SectionLabel}" Margin="0,0,0,8"/>
                    <c:HudPanel Tint="Accent" Padding="18" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Hud.Body}" Margin="0,0,0,16"
                                       Text="The tactical palette is fixed. You control the display font, the backdrop, and how translucent the panels sit over it."/>

                            <!-- Background image -->
                            <c:TrackedText Text="BACKGROUND IMAGE" Style="{StaticResource Hud.StatCaption}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="11"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Hud.Mono.Text}">
                                        <Setter Property="Foreground" Value="{DynamicResource Hud.FgSubtle}"/>
                                        <Setter Property="Text" Value="— using bundled default —"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasCustomBackground}" Value="True">
                                                <Setter Property="Text" Value="{Binding BackgroundImagePath}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Hud.Accent}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Button Content="CHOOSE IMAGE"
                                        Style="{StaticResource Hud.Button}"
                                        Command="{Binding BrowseBackgroundImageCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="RESET"
                                        Style="{StaticResource Hud.Button.Ghost}"
                                        Command="{Binding ResetBackgroundImageCommand}"
                                        Visibility="{Binding HasCustomBackground, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <!-- Display font — headers and titles only; data stays mono -->
                            <c:TrackedText Text="DISPLAY FONT" Style="{StaticResource Hud.StatCaption}" Margin="0,0,0,8"/>
                            <ComboBox Style="{StaticResource Hud.ComboBox}"
                                      ItemsSource="{Binding FontOptions}"
                                      SelectedItem="{Binding DisplayFont}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Render each option IN its own face, so the list previews itself -->
                                            <TextBlock Text="{Binding Label}"
                                                       FontFamily="{Binding Family}"
                                                       FontSize="13" FontWeight="Bold"
                                                       MinWidth="110"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Note}"
                                                       FontFamily="{DynamicResource Hud.Mono}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Hud.FgFaint}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Live sample: this is a real TrackedText on the real styles, so it
                                 changes the instant a font is picked. -->
                            <Border Background="{DynamicResource Hud.Surface2}"
                                    BorderBrush="{DynamicResource Hud.Border}"
                                    BorderThickness="1"
                                    Padding="12,10" Margin="0,10,0,4">
                                <StackPanel>
                                    <c:TrackedText Text="SERVER OVERVIEW"
                                                   Style="{StaticResource Hud.PageTitle}"
                                                   FontSize="16"/>
                                    <c:TrackedText Text="BLOOD MOON — DAY 21"
                                                   Style="{StaticResource Hud.PanelHeader}"
                                                   Foreground="{DynamicResource Hud.Accent}"
                                                   Margin="0,6,0,0"/>
                                    <TextBlock Text="8/16 players · 26900 · 192.168.1.44"
                                               Style="{StaticResource Hud.Mono.Text}"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource Hud.FgFaint}"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Style="{StaticResource Hud.SettingHint}"
                                       Margin="0,0,0,16"
                                       Text="Headers and titles only. Ports, IPs and counts stay monospaced so columns stay aligned."/>

                            <!-- Panel opacity -->
                            <Grid Margin="0,0,0,6">
                                <c:TrackedText Text="PANEL OPACITY" Style="{StaticResource Hud.StatCaption}"/>
                                <TextBlock Text="{Binding CardOpacity, StringFormat='{}{0}%'}"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           Foreground="{DynamicResource Hud.Accent}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider Minimum="30" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True"
                                    Value="{Binding CardOpacity}"
                                    Foreground="{DynamicResource Hud.Accent}"/>
                        </StackPanel>
                    </c:HudPanel>

                    <!-- ══ PATHS ══ -->
                    <c:TrackedText Text="PATHS" Style="{StaticResource Hud.SectionLabel}" Margin="0,0,0,8"/>
                    <c:HudPanel Tint="Rust" Padding="18" Margin="0,0,0,18">
                        <StackPanel>
                            <c:TrackedText Text="DEFAULT SERVER INSTALL ROOT" Style="{StaticResource Hud.StatCaption}" Margin="0,0,0,6"/>
                            <TextBlock Style="{StaticResource Hud.Body}" Margin="0,0,0,10"
                                       Text="New servers are created as sub-folders here."/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding DefaultInstallRoot, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2" Content="BROWSE"
                                        Style="{StaticResource Hud.Button}"
                                        Command="{Binding BrowseInstallRootCommand}"/>
                            </Grid>

                            <c:TrackedText Text="STEAMCMD LOCATION" Style="{StaticResource Hud.StatCaption}" Margin="0,18,0,6"/>
                            <Border Background="{DynamicResource Hud.Surface2}"
                                    BorderBrush="{DynamicResource Hud.Border}" BorderThickness="1"
                                    Padding="12,10">
                                <TextBlock Text="{Binding SteamCmdExePreview}"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Hud.FgSubtle}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </c:HudPanel>

                    <!-- ══ BEHAVIOUR ══ -->
                    <c:TrackedText Text="BEHAVIOUR" Style="{StaticResource Hud.SectionLabel}" Margin="0,0,0,8"/>
                    <c:HudPanel Tint="Blue" Padding="18">
                        <StackPanel>
                            <!-- Start minimized -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <c:TrackedText Text="START MINIMIZED" Style="{StaticResource Hud.StatCaption}"/>
                                    <TextBlock Style="{StaticResource Hud.Body}" Margin="0,4,0,0"
                                               Text="Minimizes to tray on launch — useful when starting on boot."/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              Style="{StaticResource Hud.Toggle}"
                                              IsChecked="{Binding StartMinimized}"
                                              VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource Hud.Border}" Margin="0,16"/>

                            <!-- Auto-start on login -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <c:TrackedText Text="AUTO-START ON LOGIN" Style="{StaticResource Hud.StatCaption}"/>
                                    <TextBlock Style="{StaticResource Hud.Body}" Margin="0,4,0,0"
                                               Text="Registers with Windows to launch when you log in."/>
                                    <c:TrackedText Text="⚠ REQUIRES A PUBLISHED BUILD"
                                               Style="{StaticResource Hud.StatCaption}"
                                               Foreground="{DynamicResource Hud.Amber}"
                                               Margin="0,6,0,0"
                                               Visibility="{Binding IsDevBuild, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding AutoStartOnLogin}"
                                              VerticalAlignment="Center">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton" BasedOn="{StaticResource Hud.Toggle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDevBuild}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>
                        </StackPanel>
                    </c:HudPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Hud.BgElevated}"
                    BorderBrush="{DynamicResource Hud.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="24,14">
                <Button Content="SAVE &amp; CLOSE"
                        Style="{StaticResource Hud.Button.Primary}"
                        HorizontalAlignment="Right"
                        Width="150"
                        Click="CloseButton_Click"/>
            </Border>
        </Grid>
    </Grid>
</Window>
