<Window x:Class="SevenDaysManager.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:SevenDaysManager.ViewModels"
        Title="App Settings"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:AppSettingsViewModel/>
    </Window.DataContext>

    <StackPanel>

        <!-- Header -->
        <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" Padding="20,16" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="App Settings" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                <TextBlock Text="Theme, colours and global preferences"
                           FontSize="11" Opacity="0.7"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="24,0,24,24">

        <!-- Dark / Light toggle -->
        <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Dark Mode" FontWeight="SemiBold"/>
                    <TextBlock Text="Toggle between dark and light theme"
                               FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                </StackPanel>
                <ToggleButton Grid.Column="1"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              IsChecked="{Binding IsDark}"
                              VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>

        <!-- Primary color -->
        <TextBlock Text="PRIMARY COLOR" FontSize="11" FontWeight="Bold"
                   Opacity="0.5" Margin="0,0,0,10"/>
        <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{Binding SelectedPrimary.Name, StringFormat='Selected: {0}', FallbackValue='Selected: none'}"
                           FontSize="12" Opacity="0.7" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Swatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPrimaryCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Width="32" Height="32" Margin="3"
                                    Padding="0"
                                    ToolTip="{Binding Name}"
                                    Style="{StaticResource MaterialDesignIconButton}">
                                <Grid Width="32" Height="32">
                                    <Ellipse Fill="{Binding Brush}" Width="28" Height="28"/>
                                    <!-- checkmark when selected as primary -->
                                    <materialDesign:PackIcon Kind="Check"
                                                             Width="16" Height="16"
                                                             Foreground="White"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Visibility="{Binding IsSelectedPrimary,
                                                                Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </materialDesign:Card>

        <!-- Secondary color -->
        <TextBlock Text="SECONDARY / ACCENT COLOR" FontSize="11" FontWeight="Bold"
                   Opacity="0.5" Margin="0,0,0,10"/>
        <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="{Binding SelectedSecondary.Name, StringFormat='Selected: {0}', FallbackValue='Selected: none'}"
                           FontSize="12" Opacity="0.7" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Swatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectSecondaryCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Width="32" Height="32" Margin="3"
                                    Padding="0"
                                    ToolTip="{Binding Name}"
                                    Style="{StaticResource MaterialDesignIconButton}">
                                <Grid Width="32" Height="32">
                                    <Ellipse Fill="{Binding Brush}" Width="28" Height="28"/>
                                    <materialDesign:PackIcon Kind="CheckCircle"
                                                             Width="16" Height="16"
                                                             Foreground="White"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Visibility="{Binding IsSelectedSecondary,
                                                                Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </materialDesign:Card>

        <!-- Paths -->
        <TextBlock Text="PATHS" FontSize="11" FontWeight="Bold"
                   Opacity="0.5" Margin="0,0,0,10"/>
        <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <!-- Default install root -->
                <TextBlock Text="Default Server Install Root" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="New servers are created as sub-folders here"
                           FontSize="11" Opacity="0.55" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="e.g. C:\GameServers\7DaysToDie"
                             Text="{Binding DefaultInstallRoot, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding BrowseInstallRootCommand}"
                            Height="56" Padding="12,0">
                        <materialDesign:PackIcon Kind="FolderOpen"/>
                    </Button>
                </Grid>

                <!-- SteamCMD (auto-derived) -->
                <TextBlock Text="SteamCMD Location" FontWeight="SemiBold" Margin="0,20,0,4"/>
                <TextBlock Text="Managed automatically inside the install root — no configuration needed."
                           FontSize="11" Opacity="0.55" Margin="0,0,0,8"/>
                <Border Background="#1AFFFFFF" CornerRadius="4" Padding="12,10">
                    <TextBlock Text="{Binding SteamCmdExePreview}"
                               FontSize="12" Opacity="0.7" FontFamily="Consolas"
                               TextWrapping="Wrap"/></Border>
            </StackPanel>
        </materialDesign:Card>

        <!-- Close -->
        <Button Content="Save &amp; Close"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Right"
                Width="130"
                Click="CloseButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
