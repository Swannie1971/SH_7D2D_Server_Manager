<UserControl x:Class="SevenDaysManager.Views.ServerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:SevenDaysManager.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Banner -->
            <TextBlock Text="SERVER BANNER" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Margin="0,0,0,16" Height="140">
                <Grid>
                    <Image Source="pack://application:,,,/Assets/bg.jpg" Stretch="UniformToFill"/>
                    <Image Source="{Binding LogoPath, Converter={StaticResource PathToImage}}"
                           Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="20"
                            Command="{Binding BrowseLogoCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,12,12" Height="32" Padding="12,0"
                            Background="#CC000000" BorderBrush="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImageEdit" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Change" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- Name -->
            <TextBlock Text="GENERAL" FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBox materialDesign:HintAssist.Hint="Server Name"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>
                    <TextBlock FontSize="11" Opacity="0.5"
                               Text="{Binding InstallDir, StringFormat='Install folder: {0}'}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Save error -->
            <Border CornerRadius="6" Background="#33F44336" Padding="12,8" Margin="0,0,0,8"
                    Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SaveError}" Foreground="#F44336" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <Button Content="Save Changes"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left"
                    Width="140" Margin="0,0,0,24"/>

            <!-- Danger zone -->
            <TextBlock Text="DANGER ZONE" FontSize="11" FontWeight="Bold"
                       Foreground="#F44336" Opacity="0.8" Margin="0,0,0,10"/>
            <materialDesign:Card UniformCornerRadius="10" Padding="16"
                                 BorderThickness="1" BorderBrush="#44F44336">
                <StackPanel>
                    <!-- Normal state (hide when ConfirmDelete=true) -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConfirmDelete}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Delete Server" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Removes this server from the manager. Server files on disk are NOT deleted."
                                   FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Content="Delete Server"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#F44336" BorderBrush="#F44336"
                                Command="{Binding DeleteCommand}"
                                HorizontalAlignment="Left" Width="140"/>
                    </StackPanel>

                    <!-- Confirm state -->
                    <StackPanel Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Are you sure?" FontWeight="SemiBold" Foreground="#F44336" Margin="0,0,0,8"/>

                        <CheckBox Content="Also delete server files from disk"
                                  IsChecked="{Binding DeleteFiles}"
                                  Margin="0,0,0,4"/>
                        <TextBlock FontSize="11" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{Binding InstallDir, StringFormat='({0})'}"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#F44336" BorderBrush="#F44336"
                                    Command="{Binding DeleteCommand}"
                                    Width="150" Margin="0,0,8,0">
                                <Button.Content>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Remove from Manager"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DeleteFiles}" Value="True">
                                                        <Setter Property="Text" Value="Delete Everything"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                            <Button Content="Cancel"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding CancelDeleteCommand}"
                                    Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
