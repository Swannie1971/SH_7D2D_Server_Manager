<UserControl x:Class="SevenDaysManager.Views.ServerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:SevenDaysManager.Converters"
             xmlns:c="clr-namespace:SevenDaysManager.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="16">

            <c:HudTitle Title="SETTINGS" HorizontalAlignment="Left" Margin="2,0,0,16"/>

            <!-- ══ BANNER ══ -->
            <c:TrackedText Text="SERVER BANNER" Style="{StaticResource Hud.SectionLabel}"
                           HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <c:HudPanel Tint="Violet" Padding="0" Margin="0,0,0,16" Height="150">
                <Grid>
                    <Image Source="{Binding LogoPath, Converter={StaticResource PathToImage}}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="14"/>
                    <Button Style="{StaticResource Hud.Button}"
                            Command="{Binding BrowseLogoCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,12,12" Height="28" Padding="12,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImageEdit" Width="12" Height="12"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <c:TrackedText Text="CHANGE" LetterSpacing="0.12"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.Fg}"
                                           VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </c:HudPanel>

            <!-- ══ GENERAL ══ -->
            <c:TrackedText Text="GENERAL" Style="{StaticResource Hud.SectionLabel}"
                           HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <c:HudPanel Tint="Accent" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <c:TrackedText Text="SERVER NAME" Style="{StaticResource Hud.FieldLabel}"/>
                    <TextBox Style="{StaticResource Hud.TextBox}"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <c:TrackedText Text="INSTALL FOLDER" Style="{StaticResource Hud.FieldLabel}"/>
                    <Border Background="{DynamicResource Hud.Surface2}"
                            BorderBrush="{DynamicResource Hud.Border}" BorderThickness="1"
                            Padding="11,8">
                        <TextBlock Text="{Binding InstallDir}"
                                   Style="{StaticResource Hud.Mono.Text}"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource Hud.FgSubtle}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </c:HudPanel>

            <!-- Save error -->
            <Border Background="{DynamicResource Hud.RedSoft}"
                    BorderBrush="{DynamicResource Hud.Red}" BorderThickness="1"
                    Padding="12,8" Margin="0,0,0,10"
                    Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SaveError}"
                           Style="{StaticResource Hud.Mono.Text}"
                           FontSize="11"
                           Foreground="{DynamicResource Hud.Red}"
                           TextWrapping="Wrap"/>
            </Border>

            <Button Style="{StaticResource Hud.Button.Primary}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left"
                    Width="160" Height="32" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="13" Height="13"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <c:TrackedText Text="SAVE CHANGES" LetterSpacing="0.12"
                                   FontFamily="{DynamicResource Hud.Mono}"
                                   FontSize="10.5" FontWeight="Bold"
                                   Foreground="{DynamicResource Hud.AccentInk}"
                                   VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- ══ BEHAVIOUR ══ -->
            <c:TrackedText Text="BEHAVIOUR" Style="{StaticResource Hud.SectionLabel}"
                           HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <c:HudPanel Tint="Blue" Padding="16" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <c:TrackedText Text="AUTO-START ON APP LAUNCH"
                                       Style="{StaticResource Hud.StatCaption}"
                                       HorizontalAlignment="Left"/>
                        <TextBlock Style="{StaticResource Hud.Body}" Margin="0,4,0,0"
                                   Text="Start this server automatically when the app opens."/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1"
                                  Style="{StaticResource Hud.Toggle}"
                                  IsChecked="{Binding AutoStart}"
                                  VerticalAlignment="Center"/>
                </Grid>
            </c:HudPanel>

            <!-- ══ DANGER ZONE ══ -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <c:TrackedText Text="DANGER ZONE"
                               Style="{StaticResource Hud.SectionLabel}"
                               Foreground="{DynamicResource Hud.Red}"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <!-- Hazard tape says "stop and read this" better than any label -->
                <Rectangle Grid.Column="1" Height="8" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Fill="{DynamicResource Hud.HazardTile}"
                           Opacity="0.5"/>
            </Grid>

            <c:HudPanel Tint="Red" Padding="16" Margin="0,0,0,16">
                <StackPanel>

                    <!-- Stage 1: arm the delete -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConfirmDelete}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <c:TrackedText Text="DELETE SERVER" Style="{StaticResource Hud.StatCaption}"
                                       Foreground="{DynamicResource Hud.Red}"
                                       HorizontalAlignment="Left"/>
                        <TextBlock Style="{StaticResource Hud.Body}" Margin="0,5,0,14"
                                   Text="Removes this server from the manager. Files on disk are NOT deleted unless you choose to."/>
                        <Button Style="{StaticResource Hud.Button}"
                                BorderBrush="{DynamicResource Hud.Red}"
                                Command="{Binding DeleteCommand}"
                                HorizontalAlignment="Left" Width="160" Height="32">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TrashCanOutline" Width="13" Height="13"
                                                         Foreground="{DynamicResource Hud.Red}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <c:TrackedText Text="DELETE SERVER" LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.Red}"
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Stage 2: confirm -->
                    <StackPanel Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="AlertOctagon" Width="16" Height="16"
                                                     Foreground="{DynamicResource Hud.Red}"
                                                     VerticalAlignment="Center" Margin="0,0,9,0"/>
                            <c:TrackedText Text="ARE YOU SURE?"
                                           Style="{StaticResource Hud.PanelHeader}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Hud.Red}"
                                           VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox Content="ALSO DELETE SERVER FILES FROM DISK"
                                  IsChecked="{Binding DeleteFiles}"
                                  Style="{StaticResource Hud.CheckBox}"
                                  Margin="0,0,0,7"/>
                        <Border Background="{DynamicResource Hud.Surface2}"
                                BorderBrush="{DynamicResource Hud.Border}" BorderThickness="1"
                                Padding="11,7" Margin="0,0,0,14">
                            <TextBlock Text="{Binding InstallDir}"
                                       Style="{StaticResource Hud.Mono.Text}"
                                       FontSize="10"
                                       Foreground="{DynamicResource Hud.FgSubtle}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <!-- Chamfered red — the label changes with the checkbox, so it
                                 always states exactly what is about to happen. -->
                            <Button Style="{StaticResource Hud.Button.Stop}"
                                    Command="{Binding DeleteCommand}"
                                    Width="190" Height="34" Margin="0,0,8,0">
                                <c:TrackedText LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="#12060A"
                                               VerticalAlignment="Center">
                                    <c:TrackedText.Style>
                                        <Style TargetType="c:TrackedText">
                                            <Setter Property="Text" Value="REMOVE FROM MANAGER"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DeleteFiles}" Value="True">
                                                    <Setter Property="Text" Value="DELETE EVERYTHING"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </c:TrackedText.Style>
                                </c:TrackedText>
                            </Button>

                            <Button Style="{StaticResource Hud.Button.Ghost}"
                                    Command="{Binding CancelDeleteCommand}"
                                    Width="110" Height="34">
                                <c:TrackedText Text="CANCEL" LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.FgMuted}"
                                               VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </c:HudPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
