<Window x:Class="SevenDaysManager.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Server Config"
        Width="620" SizeToContent="Height"
        MaxHeight="860"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,16">
            <StackPanel>
                <TextBlock Text="{Binding ServerName, StringFormat='Config: {0}'}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                <TextBlock Text="{Binding InstallDir}"
                           FontSize="11" Opacity="0.7"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- Scrollable form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- ── Identity ─────────────────────────────────────────────── -->
                <TextBlock Text="SERVER IDENTITY" FontSize="11" FontWeight="Bold"
                           Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBox materialDesign:HintAssist.Hint="Server Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>
                        <TextBox materialDesign:HintAssist.Hint="Description (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>
                        <TextBox materialDesign:HintAssist.Hint="Website URL (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WebsiteUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="Join Password (optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox Grid.Column="2"
                                      materialDesign:HintAssist.Hint="Visibility"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      ItemsSource="{Binding VisibilityOptions}"
                                      SelectedValue="{Binding ServerVisibility}"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ── World ────────────────────────────────────────────────── -->
                <TextBlock Text="WORLD" FontSize="11" FontWeight="Bold"
                           Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox materialDesign:HintAssist.Hint="Game World"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding GameWorldOptions}"
                                      SelectedItem="{Binding GameWorld}"/>
                            <TextBox Grid.Column="2"
                                     materialDesign:HintAssist.Hint="Save Name"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <!-- RWG only -->
                        <Grid Visibility="{Binding IsRwg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="World Seed (optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding WorldGenSeed, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox Grid.Column="2"
                                      materialDesign:HintAssist.Hint="World Size"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding WorldGenSizeOptions}"
                                      SelectedItem="{Binding WorldGenSize}"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ── Network ──────────────────────────────────────────────── -->
                <TextBlock Text="NETWORK" FontSize="11" FontWeight="Bold"
                           Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="Game Port"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2"
                                     materialDesign:HintAssist.Hint="Telnet Port"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="4"
                                     materialDesign:HintAssist.Hint="Web Dashboard Port"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding WebDashboardPort, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="Max Players"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ── Options ──────────────────────────────────────────────── -->
                <TextBlock Text="OPTIONS" FontSize="11" FontWeight="Bold"
                           Opacity="0.5" Margin="0,0,0,10"/>
                <materialDesign:Card UniformCornerRadius="10" Padding="16" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="EAC (Anti-Cheat)" FontWeight="SemiBold"/>
                            <TextBlock Text="Easy Anti-Cheat protection" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding EacEnabled}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Error -->
                <Border CornerRadius="6" Background="#33F44336" Padding="12,8" Margin="0,0,0,12"
                        Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SaveError}" Foreground="#F44336" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Saved confirmation -->
                <Border CornerRadius="6" Background="#334CAF50" Padding="12,8"
                        Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Config saved and serverconfig.xml written."
                                   Foreground="#4CAF50" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Content="Close" Width="100" Margin="0,0,8,0"
                        Click="CloseButton_Click"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="Save Config" Width="130"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
