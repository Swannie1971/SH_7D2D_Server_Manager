<Window x:Class="SevenDaysManager.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:c="clr-namespace:SevenDaysManager.Controls"
        Title="Server Config"
        Width="640" Height="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{DynamicResource Hud.Bg}"
            BorderBrush="{DynamicResource Hud.BorderStrong}"
            BorderThickness="1">
        <Grid>
            <c:HudAtmosphere Panel.ZIndex="0"/>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ══ Header ══ -->
                <Grid Grid.Row="0" Height="64"
                      Background="Transparent"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Rectangle Fill="{DynamicResource Hud.BgElevated}"/>
                    <Rectangle Fill="{DynamicResource Hud.HazardTile}" Opacity="0.3"/>
                    <Border BorderBrush="{DynamicResource Hud.Border}" BorderThickness="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <c:HudIcon Kind="Cog" Width="19" Height="19"
                                                 Foreground="{DynamicResource Hud.Accent}"
                                                 VerticalAlignment="Center" Margin="0,0,11,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <c:TrackedText Text="SERVER CONFIG"
                                           Style="{StaticResource Hud.PanelHeader}"
                                           FontSize="12.5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock Text="{Binding ServerName}"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource Hud.Rust}"/>
                                <TextBlock Text="{Binding InstallDir}"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="10"
                                           Foreground="{DynamicResource Hud.FgFaint}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="380"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ══ Scrollable form ══ -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,16,16,4">

                        <!-- ══ Identity ══ -->
                        <c:HudPanel Header="SERVER IDENTITY" Tint="Accent" Margin="0,0,0,14">
                            <StackPanel>
                                <c:TrackedText Text="SERVER NAME" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"/>

                                <c:TrackedText Text="DESCRIPTION (OPTIONAL)" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"/>

                                <c:TrackedText Text="WEBSITE URL (OPTIONAL)" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding WebsiteUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <c:TrackedText Text="JOIN PASSWORD (OPTIONAL)" Style="{StaticResource Hud.FieldLabel}"/>
                                        <TextBox Style="{StaticResource Hud.TextBox}"
                                                 Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <c:TrackedText Text="VISIBILITY" Style="{StaticResource Hud.FieldLabel}"/>
                                        <ComboBox Style="{StaticResource Hud.ComboBox}"
                                                  SelectedValuePath="Value"
                                                  ItemsSource="{Binding VisibilityOptions}"
                                                  SelectedValue="{Binding ServerVisibility}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </c:HudPanel>

                        <!-- ══ World ══ -->
                        <c:HudPanel Header="WORLD" Tint="Green" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <c:TrackedText Text="GAME WORLD" Style="{StaticResource Hud.FieldLabel}"/>
                                        <ComboBox Style="{StaticResource Hud.ComboBox}"
                                                  ItemsSource="{Binding GameWorldOptions}"
                                                  SelectedItem="{Binding GameWorld}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <c:TrackedText Text="SAVE NAME" Style="{StaticResource Hud.FieldLabel}"/>
                                        <TextBox Style="{StaticResource Hud.TextBox}"
                                                 Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Seed + size only mean anything for a randomly generated world -->
                                <Grid Visibility="{Binding IsRwg, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <c:TrackedText Text="WORLD SEED (OPTIONAL)" Style="{StaticResource Hud.FieldLabel}"/>
                                        <TextBox Style="{StaticResource Hud.TextBox}"
                                                 Text="{Binding WorldGenSeed, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <c:TrackedText Text="WORLD SIZE" Style="{StaticResource Hud.FieldLabel}"/>
                                        <ComboBox Style="{StaticResource Hud.ComboBox}"
                                                  ItemsSource="{Binding WorldGenSizeOptions}"
                                                  SelectedItem="{Binding WorldGenSize}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </c:HudPanel>

                        <!-- ══ Network ══ -->
                        <c:HudPanel Header="NETWORK" Tint="Blue" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <c:TrackedText Text="GAME PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                        <TextBox Style="{StaticResource Hud.TextBox}"
                                                 Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <c:TrackedText Text="TELNET PORT" Style="{StaticResource Hud.FieldLabel}"/>
                                        <TextBox Style="{StaticResource Hud.TextBox}"
                                                 Text="{Binding TelnetPort, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <c:TrackedText Text="WEB DASHBOARD" Style="{StaticResource Hud.FieldLabel}"/>
                                        <TextBox Style="{StaticResource Hud.TextBox}"
                                                 Text="{Binding WebDashboardPort, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <c:TrackedText Text="MAX PLAYERS" Style="{StaticResource Hud.FieldLabel}"/>
                                <TextBox Style="{StaticResource Hud.TextBox}"
                                         Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </c:HudPanel>

                        <!-- ══ Options ══ -->
                        <c:HudPanel Header="OPTIONS" Tint="Amber" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <c:TrackedText Text="EAC (ANTI-CHEAT)" Style="{StaticResource Hud.SettingLabel}"/>
                                    <TextBlock Text="Easy Anti-Cheat protection"
                                               Style="{StaticResource Hud.SettingHint}"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              Style="{StaticResource Hud.Toggle}"
                                              IsChecked="{Binding EacEnabled}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </c:HudPanel>

                        <!-- ══ Save error ══ -->
                        <Border Background="{DynamicResource Hud.RedSoft}"
                                BorderBrush="{DynamicResource Hud.Red}"
                                BorderThickness="1"
                                Padding="12,9" Margin="0,0,0,10"
                                Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <c:HudIcon Kind="AlertOctagon" Width="15" Height="15"
                                                         Foreground="{DynamicResource Hud.Red}"
                                                         VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <TextBlock Text="{Binding SaveError}"
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Hud.Red}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- ══ Saved confirmation ══ -->
                        <Border Background="{DynamicResource Hud.GreenSoft}"
                                BorderBrush="{DynamicResource Hud.Green}"
                                BorderThickness="1"
                                Padding="12,9" Margin="0,0,0,10"
                                Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <c:HudIcon Kind="CheckCircle" Width="15" Height="15"
                                                         Foreground="{DynamicResource Hud.Green}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Config saved — serverconfig.xml written."
                                           Style="{StaticResource Hud.Mono.Text}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Hud.Green}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ Buttons ══ -->
                <Border Grid.Row="2"
                        Background="{DynamicResource Hud.BgElevated}"
                        BorderBrush="{DynamicResource Hud.Border}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Hud.Button.Ghost}"
                                Width="110" Height="30" Margin="0,0,8,0"
                                Click="CloseButton_Click">
                            <c:TrackedText Text="CLOSE" LetterSpacing="0.12"
                                           FontFamily="{DynamicResource Hud.Mono}"
                                           FontSize="10.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Hud.FgMuted}"
                                           VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource Hud.Button.Primary}"
                                Width="150" Height="30"
                                Command="{Binding SaveCommand}">
                            <StackPanel Orientation="Horizontal">
                                <c:HudIcon Kind="ContentSave" Width="13" Height="13"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <c:TrackedText Text="SAVE CONFIG" LetterSpacing="0.12"
                                               FontFamily="{DynamicResource Hud.Mono}"
                                               FontSize="10.5" FontWeight="Bold"
                                               Foreground="{DynamicResource Hud.AccentInk}"
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <c:HudBrackets Panel.ZIndex="2" Tint="Accent"/>
        </Grid>
    </Border>
</Window>
